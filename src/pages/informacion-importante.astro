---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getInfoContent } from '../i18n/infoPage';
const content = getInfoContent('es');

const ICONS: Record<string, string> = {
  'Entrada y salida': '🕐',
  'Respeto por los demás huéspedes': '🤝',
  'No se permiten fiestas ni eventos': '🚫',
  'Horario de silencio': '🔇',
  'No fumar': '🚭',
  'Número de huéspedes': '👥',
  'Acceso al apartamento': '🔑',
  'Cuidado del apartamento': '🏠',
  'Limpieza': '✨',
  'Basura': '♻️',
  'Toallas y ropa de cama': '🛏️',
  'Aire acondicionado, calefacción y luces': '🌡️',
  'Bicicletas': '🚲',
  'Mascotas': '🐾',
  'Seguridad': '🔒',
  'Cancelación': '📋',
  'Si algo no va bien, dímelo durante la estancia': '💬',
};
---
<BaseLayout
  title={content.metaTitle}
  description={content.metaDescription}
>
  <!-- HERO -->
  <div class="inner-hero">
    <span class="eyebrow">Aromatik Apartments · Girona</span>
    <h1>{content.pageTitle}</h1>
    <p class="hero-sub">{content.heroText}</p>
  </div>

  <!-- INTRO PERSONAL -->
  <section class="section section-intro">
    <div class="container-sm">
      <div class="intro-card">
        <div class="intro-avatar">A</div>
        <div class="intro-text">
          <p>{content.intro}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIONES -->
  <section class="section section-rules">
    <div class="container-rules">
      <div class="rules-grid">
        {content.sections.map((section) => (
          <div class="rule-card">
            <div class="rule-icon">{ICONS[section.title] ?? '📌'}</div>
            <div class="rule-body">
              <h2>{section.title}</h2>
              <p>{section.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GRACIAS -->
  <section class="section section-thanks">
    <div class="container-sm">
      <div class="thanks-card">
        <h2>{content.thanksTitle}</h2>
        <p>{content.thanksText}</p>
        <p class="signature">{content.signature}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-cta">
    <div class="container-sm">
      <div class="info-cta-box">
        <h2>{content.ctaTitle}</h2>
        <p>{content.ctaText}</p>
        <a href="/contacto" class="btn btn-dark">{content.ctaBtn}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* INNER HERO */
  .inner-hero {
    background: var(--cream);
    text-align: center;
    padding: 7rem 2rem 4rem;
    border-bottom: 1px solid #e7e0d8;
  }
  .inner-hero .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #9e9689;
    margin-bottom: 1rem;
  }
  .inner-hero h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--black);
    margin: 0 0 1.25rem;
    line-height: 1.2;
  }
  .hero-sub {
    font-size: 1rem;
    color: #6b6560;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* CONTAINERS */
  .container-sm { max-width: 760px; margin: 0 auto; padding: 0 1.5rem; }
  .container-rules { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .section { padding: 3.5rem 0; }

  /* INTRO CARD */
  .section-intro { background: var(--white); border-bottom: 1px solid #e7e0d8; }
  .intro-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: var(--cream);
    border: 1px solid #e7e0d8;
    border-radius: 12px;
    padding: 2rem;
  }
  .intro-avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--white);
    font-family: var(--serif);
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .intro-text p {
    margin: 0;
    font-size: 0.95rem;
    color: #3a3631;
    line-height: 1.8;
  }

  /* RULES GRID — 2-col desktop, 1-col mobile */
  .section-rules { background: var(--white); }
  .rules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .rule-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--cream);
    border: 1px solid #e7e0d8;
    border-radius: 10px;
    padding: 1.4rem 1.5rem;
    transition: box-shadow 0.2s;
  }
  .rule-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
  }

  .rule-icon {
    flex-shrink: 0;
    font-size: 1.5rem;
    line-height: 1;
    margin-top: 2px;
  }

  .rule-body h2 {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 0.45rem;
    line-height: 1.3;
  }
  .rule-body p {
    margin: 0;
    font-size: 0.88rem;
    color: #6b6560;
    line-height: 1.75;
  }

  /* GRACIAS */
  .section-thanks {
    background: var(--cream);
    border-top: 1px solid #e7e0d8;
    border-bottom: 1px solid #e7e0d8;
  }
  .thanks-card {
    text-align: center;
    padding: 1rem 0;
  }
  .thanks-card h2 {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 1rem;
  }
  .thanks-card p {
    font-size: 0.95rem;
    color: #6b6560;
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto 0.5rem;
  }
  .signature {
    font-family: var(--serif);
    font-size: 1rem !important;
    color: var(--gold) !important;
    margin-top: 1.5rem !important;
    font-style: italic;
  }

  /* CTA */
  .section-cta { background: var(--white); }
  .info-cta-box {
    text-align: center;
    padding: 2.5rem;
    border: 1px solid #e7e0d8;
    border-radius: 12px;
    background: var(--cream);
  }
  .info-cta-box h2 {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 0.75rem;
  }
  .info-cta-box p {
    font-size: 0.93rem;
    color: #6b6560;
    margin: 0 0 1.5rem;
    line-height: 1.7;
  }

  @media (max-width: 700px) {
    .rules-grid { grid-template-columns: 1fr; }
    .intro-card { flex-direction: column; gap: 1rem; padding: 1.5rem; }
    .info-cta-box { padding: 1.75rem 1.25rem; }
    .section { padding: 2.5rem 0; }
    .rule-card { padding: 1.2rem; }
  }
</style>
