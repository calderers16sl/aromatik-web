  return apartments.map(apt => ({ params: { slug: apt.slug }, props: { apt, allApartments: apartments } }));
}

const { apt, allApartments } = Astro.props;
const hasPhotos = apt.photos && apt.photos.length > 0;
---
<BaseLayout title={apt.name} description={apt.description}>

  <!-- ═══════════════════════════════════════════════════
       CARRUSEL DE FOTOS (hero + galería unificados)
       Swipe táctil nativo en móvil · Flechas en desktop
  ════════════════════════════════════════════════════ -->
  {hasPhotos && (
    <div class="carousel-wrap" id="carouselWrap">
      <!-- Pista deslizante -->
      <div class="carousel-track" id="cTrack" role="region" aria-label={`Fotos de ${apt.name}`}>
        {apt.photos.map((photo, i) => (
          <div class="carousel-slide" data-index={i}>
            <img
              src={`/images/apartamentos/${apt.slug}/${photo}`}
              alt={`${apt.name} - foto ${i + 1}`}
              class="c-img"
              data-index={i}
              loading={i === 0 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>

      <!-- Contador  "3 / 21" -->
      <div class="c-counter" id="cCounter" aria-live="polite">1 / {apt.photos.length}</div>

      <!-- Flechas (visibles en desktop, ocultas en móvil táctil) -->
      <button class="c-btn c-prev" id="cPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="c-btn c-next" id="cNext" aria-label="Foto siguiente">&#10095;</button>

      <!-- Indicador "desliza" solo la primera vez en móvil -->
      <div class="c-hint" id="cHint" aria-hidden="true">
        <span>← desliza →</span>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════

  <!-- ═══════════════════════════════════════
       CONTENIDO DEL APARTAMENTO
  ══════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="apt-layout">

      <!-- Info principal -->
      <div class="apt-main">
        <h1 class="apt-title">Apartamento {apt.name}</h1>

        <div class="apt-stats">
          <span class="stat-badge">👥 {apt.guests} personas</span>
          <span class="stat-badge">🛏 {apt.bedrooms} dormitorio{apt.bedrooms > 1 ? 's' : ''}</span>
          <span class="stat-badge">🚿 {apt.bathrooms} baño{apt.bathrooms > 1 ? 's' : ''}</span>
          <span class="stat-badge">📐 {apt.size} m²</span>
        </div>

        <div class="apt-divider"></div>

        <p class="apt-description">{apt.description}</p>

        <div class="apt-section">
          <h2 class="apt-section-title">Servicios incluidos</h2>
          <ul class="apt-amenities">
            {apt.amenities.map(a => (
              <li class="amenity-item">
                <span class="amenity-check">✓</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="location-box">
          <span class="location-icon">📍</span>
          <div>
            <p class="location-title">Barri Vell de Girona</p>
            <p class="location-sub">Aparcament La Copa · gratuito · 10 min a pie</p>
          </div>
        </div>
      </div>

      <!-- Sidebar reserva -->
      <div class="apt-sidebar">
        <div class="booking-card">
          <div class="booking-card-header">
            <h3 class="booking-card-title">¿Te gusta?</h3>
            <p class="booking-card-sub">Reserva directo al mejor precio.</p>
          </div>
          <a href="/reservar" class="btn-reservar">Ver disponibilidad</a>
          <a href="/contacto" class="btn-contactar">Hacer una pregunta</a>
          <p class="booking-note">Sin intermediarios · Confirmación inmediata</p>
        </div>
      </div>
    </div>

    <!-- Motor de reservas -->
    <div class="booking-section">
      <h2 class="section-heading">Reservar {apt.name}</h2>
      <BookingWidget smoobuId={apt.smoobuId} />
    </div>

    <!-- Otros apartamentos -->
    <div class="otros-section">
      <h2 class="section-heading">Otros apartamentos</h2>
      <div class="otros-grid">
        {allApartments.filter(a => a.slug !== apt.slug).slice(0, 4).map(a => (
          <a href={`/apartamentos/${a.slug}`} class="otro-card group">
            <div class="otro-img-wrap">
              <img
                src={`/images/apartamentos/${a.slug}/foto-1.jpg`}
                alt={a.name}
                class="otro-img group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="otro-info">
              <div class="otro-name">{a.name}</div>
              <div class="otro-meta">{a.guests} pers. · {a.bedrooms} dorm. · {a.size} m²</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  </div>

  <!-- ═══════════════════════════════════════
       LIGHTBOX (pantalla completa al click)
  ══════════════════════════════════════════ -->
  {hasPhotos && (
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label={`Galería de ${apt.name}`}>
      <button class="lb-close" id="lbClose" aria-label="Cerrar">✕</button>
      <button class="lb-prev" id="lbPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="lb-next" id="lbNext" aria-label="Foto siguiente">&#10095;</button>
      <div class="lb-content">
        <img id="lb-img" src="" alt="" />
        <p id="lb-counter" class="lb-counter-text"></p>
      </div>
    </div>
  )}

</BaseLayout>

<!-- ═══════════════════════════════════════════════════
     ESTILOS
════════════════════════════════════════════════════ -->
<style>
  /* ── CARRUSEL ────────────────────────────────────── */
  .carousel-wrap {
    position: relative;
    width: 100%;
    height: min(72vw, 520px);
    background: #1c1917;
    overflow: hidden;
    user-select: none;
  }
  .carousel-track {
    display: flex; height: 100%;
    overflow-x: scroll; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; scrollbar-width: none; cursor: grab;
  }
  .carousel-track:active { cursor: grabbing; }
  .carousel-track::-webkit-scrollbar { display: none; }
  .carousel-slide { flex: 0 0 100%; width: 100%; height: 100%; scroll-snap-align: start; scroll-snap-stop: always; }
  .c-img { width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in; }
  .c-counter { position: absolute; bottom: 16px; right: 16px; background: rgba(0,0,0,0.6); color: #fff; font-size: 0.8rem; letter-spacing: 0.08em; padding: 4px 10px; border-radius: 20px; pointer-events: none; }
  .c-hint { position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.45); color: rgba(255,255,255,0.9); font-size: 0.75rem; padding: 4px 12px; border-radius: 20px; pointer-events: none; animation: fadeHint 3s ease forwards; }
  @keyframes fadeHint { 0%,60% { opacity:1; } 100% { opacity:0; } }
  .c-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.25); border: none; color: #fff; font-size: 1.2rem; width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, opacity 0.2s; z-index: 10; opacity: 0; }
  .carousel-wrap:hover .c-btn { opacity: 1; }
  .c-btn:hover { background: rgba(255,255,255,0.35); }
  .c-prev { left: 12px; } .c-next { right: 12px; }
  @media (hover: none) { .c-btn { opacity: 0.5; } }

  /* ── LAYOUT APARTAMENTO ──────────────────────────── */
  .apt-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .apt-layout { grid-template-columns: 1fr; }
    .apt-sidebar { order: -1; }
  }

  /* ── INFO PRINCIPAL ──────────────────────────────── */
  .apt-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.4rem;
    font-weight: 400;
    color: #1c1917;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  @media (max-width: 640px) { .apt-title { font-size: 1.85rem; } }

  .apt-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    color: #44403c;
    font-size: 0.82rem;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .apt-divider {
    border: none;
    border-top: 1px solid #e7e5e4;
    margin: 1.25rem 0;
  }

  .apt-description {
    font-size: 1.05rem;
    color: #57534e;
    line-height: 1.85;
    margin-bottom: 2rem;
  }

  /* ── SERVICIOS ───────────────────────────────────── */
  .apt-section { margin-bottom: 2rem; }
  .apt-section-title {
    font-size: 0.72rem;
    font-weight: 600;
    color: #9c9490;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e7e5e4;
  }
  .apt-amenities {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (max-width: 480px) { .apt-amenities { grid-template-columns: 1fr; } }
  .amenity-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: #57534e;
    padding: 0.5rem 0.75rem;
    background: #fafaf9;
    border: 1px solid #f0efed;
    border-radius: 8px;
  }
  .amenity-check {
    color: #d0b050;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── UBICACIÓN ───────────────────────────────────── */
  .location-box {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    background: #fdf8ec;
    border: 1px solid #e8c870;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-top: 0.5rem;
  }
  .location-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
  .location-title { font-weight: 600; font-size: 0.875rem; color: #7a5c10; margin: 0 0 0.2rem; }
  .location-sub { font-size: 0.8rem; color: #8a6a20; margin: 0; }

  /* ── SIDEBAR BOOKING ─────────────────────────────── */
  .apt-sidebar { }
  .booking-card {
    position: sticky;
    top: 88px;
    background: #fff;
    border: 1.5px solid #e7e5e4;
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  }
  .booking-card-header { margin-bottom: 1.25rem; }
  .booking-card-title { font-family: 'Playfair Display', Georgia, serif; font-size: 1.2rem; font-weight: 400; color: #1c1917; margin: 0 0 0.3rem; }
  .booking-card-sub { font-size: 0.83rem; color: #78716c; margin: 0; }

  .btn-reservar {
    display: block;
    width: 100%;
    text-align: center;
    background: #d0b050;
    color: #fff;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
    margin-bottom: 0.75rem;
  }
  .btn-reservar:hover { background: #b89a40; }

  .btn-contactar {
    display: block;
    width: 100%;
    text-align: center;
    border: 1.5px solid #e7e5e4;
    color: #44403c;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-size: 0.82rem;
    text-decoration: none;
    transition: border-color 0.2s;
    margin-bottom: 1rem;
  }
  .btn-contactar:hover { border-color: #a8a29e; }

  .booking-note {
    font-size: 0.72rem;
    color: #a8a29e;
    text-align: center;
    margin: 0;
  }

  /* ── BOOKING WIDGET ──────────────────────────────── */
  .booking-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid #e7e5e4;
  }
  .section-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 400;
    text-align: center;
    color: #1c1917;
    margin-bottom: 2rem;
  }

  /* ── OTROS APARTAMENTOS ──────────────────────────── */
  .otros-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid #e7e5e4;
  }
  .otros-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .otros-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .otro-card {
    display: block;
    text-decoration: none;
    background: #fff;
    border: 1.5px solid #e7e5e4;
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.25s, border-color 0.25s, transform 0.25s;
  }
  .otro-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    border-color: #d0b050;
    transform: translateY(-3px);
  }
  .otro-img-wrap {
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: #e7e5e4;
  }
  @media (max-width: 640px) { .otro-img-wrap { height: 130px; } }
  .otro-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .otro-info {
    padding: 0.875rem 1rem;
    border-top: 1px solid #f0efed;
  }
  .otro-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1c1917;
    margin-bottom: 0.2rem;
  }
  .otro-meta {
    font-size: 0.75rem;
    color: #78716c;
  }

  /* ── LIGHTBOX ────────────────────────────────────── */
  .lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.93); z-index: 1000; align-items: center; justify-content: center; touch-action: pan-x; }
  .lightbox.active { display: flex; }
  .lb-content { display: flex; flex-direction: column; align-items: center; max-width: 92vw; max-height: 92vh; }
  .lb-content img { max-width: 92vw; max-height: 82vh; object-fit: contain; border-radius: 4px; }
  .lb-counter-text { color: rgba(255,255,255,0.65); font-size: 0.82rem; margin-top: 12px; letter-spacing: 0.06em; }
  .lb-close { position: fixed; top: 18px; right: 20px; background: rgba(255,255,255,0.2); border: none; color: #fff; font-size: 1.3rem; width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; z-index: 1001; }
  .lb-close:hover { background: rgba(255,255,255,0.3); }
  .lb-prev, .lb-next { position: fixed; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.2); border: none; color: #fff; font-size: 1.3rem; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; z-index: 1001; }
  .lb-prev { left: 14px; } .lb-next { right: 14px; }
  .lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.3); }
</style>

<!-- ═══════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════ -->
<script define:vars={{ photos: apt.photos, slug: apt.slug, aptName: apt.name }}>
  if (!photos || photos.length === 0) return;

  /* ── CARRUSEL ── */
  const track    = document.getElementById('cTrack');
  const counter  = document.getElementById('cCounter');
  const btnPrev  = document.getElementById('cPrev');
  const btnNext  = document.getElementById('cNext');
  let currentIdx = 0;

  /* Actualiza contador leyendo la posición de scroll */
  function updateCounter() {
    if (!track || !counter) return;
    const idx = Math.round(track.scrollLeft / track.clientWidth);
    if (idx !== currentIdx) {
      currentIdx = idx;
      counter.textContent = `${idx + 1} / ${photos.length}`;
    }
  }

  /* Desplaza la pista al índice indicado (animado) */
  function scrollTo(idx) {
    if (!track) return;
    idx = Math.max(0, Math.min(photos.length - 1, idx));
    track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
    currentIdx = idx;
    if (counter) counter.textContent = `${idx + 1} / ${photos.length}`;
  }

  if (track) {
    track.addEventListener('scroll', updateCounter, { passive: true });
  }
  if (btnPrev) btnPrev.addEventListener('click', () => scrollTo(currentIdx - 1));
  if (btnNext) btnNext.addEventListener('click', () => scrollTo(currentIdx + 1));

  /* Click en foto → abrir lightbox */
  document.querySelectorAll('.c-img').forEach(img => {
    img.addEventListener('click', () => {
      openLightbox(parseInt(img.dataset.index));
    });
  });

  /* Oculta el hint "desliza" después de la animación CSS */
  const hint = document.getElementById('cHint');
  if (hint) setTimeout(() => { hint.style.display = 'none'; }, 3200);

  /* ── LIGHTBOX ── */
  const lb      = document.getElementById('lightbox');
  const lbImg   = document.getElementById('lb-img');
  const lbCnt   = document.getElementById('lb-counter');
  let lbCurrent = 0;

  function showLbPhoto() {
    if (!lbImg || !lbCnt) return;
    lbImg.src = `/images/apartamentos/${slug}/${photos[lbCurrent]}`;
    lbImg.alt = `${aptName} - foto ${lbCurrent + 1}`;
    lbCnt.textContent = `${lbCurrent + 1} / ${photos.length}`;
  }

  function openLightbox(idx) {
    lbCurrent = idx;
    showLbPhoto();
    if (lb) {
      lb.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    if (lb) {
      lb.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  function lbNext() { lbCurrent = (lbCurrent + 1) % photos.length; showLbPhoto(); }
  function lbPrev() { lbCurrent = (lbCurrent - 1 + photos.length) % photos.length; showLbPhoto(); }

  const btnLbClose = document.getElementById('lbClose');
  const btnLbPrev  = document.getElementById('lbPrev');
  const btnLbNext  = document.getElementById('lbNext');

  if (btnLbClose) btnLbClose.addEventListener('click', closeLightbox);
  if (btnLbPrev)  btnLbPrev.addEventListener('click', lbPrev);
  if (btnLbNext)  btnLbNext.addEventListener('click', lbNext);

  /* Click en el fondo oscuro → cerrar */
  if (lb) lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });

  /* Teclado */
  document.addEventListener('keydown', e => {
    if (!lb || !lb.classList.contains('active')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowRight') lbNext();
    if (e.key === 'ArrowLeft')  lbPrev();
  });

  /* Swipe táctil en lightbox */
  let lbTouchX = 0;
  if (lb) {
    lb.addEventListener('touchstart', e => { lbTouchX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - lbTouchX;
      if (Math.abs(dx) > 40) { dx < 0 ? lbNext() : lbPrev(); }
    }, { passive: true });
  }
</script>
