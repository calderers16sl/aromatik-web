     JAVASCRIPT
════════════════════════════════════════════════════ -->
<script define:vars={{ photos: apt.photos, slug: apt.slug, aptName: apt.name }}>
  if (!photos || photos.length === 0) return;


  /* ── CARRUSEL ── */
  const track    = document.getElementById('cTrack');
  const counter  = document.getElementById('cCounter');
  const btnPrev  = document.getElementById('cPrev');
  const btnNext  = document.getElementById('cNext');
  let currentIdx = 0;

  /* Actualiza contador leyendo la posición de scroll */
  function updateCounter() {
    if (!track || !counter) return;
    const idx = Math.round(track.scrollLeft / track.clientWidth);
    if (idx !== currentIdx) {
      currentIdx = idx;
      counter.textContent = `${idx + 1} / ${photos.length}`;
    }
  }

  /* Desplaza la pista al índice indicado (animado) */
  function scrollTo(idx) {
    if (!track) return;
    idx = Math.max(0, Math.min(photos.length - 1, idx));
    track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
    currentIdx = idx;
    if (counter) counter.textContent = `${idx + 1} / ${photos.length}`;
  }

  if (track) {
    track.addEventListener('scroll', updateCounter, { passive: true });
  }
  if (btnPrev) btnPrev.addEventListener('click', () => scrollTo(currentIdx - 1));
  if (btnNext) btnNext.addEventListener('click', () => scrollTo(currentIdx + 1));

  /* Click en foto → abrir lightbox */
  document.querySelectorAll('.c-img').forEach(img => {
    img.addEventListener('click', () => {
      openLightbox(parseInt(img.dataset.index));
    });
  });

  /* Oculta el hint "desliza" después de la animación CSS */
  const hint = document.getElementById('cHint');
  if (hint) setTimeout(() => { hint.style.display = 'none'; }, 3200);

  /* ── LIGHTBOX ── */
  const lb      = document.getElementById('lightbox');
  const lbImg   = document.getElementById('lb-img');
  const lbCnt   = document.getElementById('lb-counter');
  let lbCurrent = 0;

  function showLbPhoto() {
    if (!lbImg || !lbCnt) return;
    lbImg.src = `/images/apartamentos/${slug}/${photos[lbCurrent]}`;
    lbImg.alt = `${aptName} - foto ${lbCurrent + 1}`;
    lbCnt.textContent = `${lbCurrent + 1} / ${photos.length}`;
  }

  function openLightbox(idx) {
    lbCurrent = idx;
    showLbPhoto();
    if (lb) {
      lb.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    if (lb) {
      lb.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  function lbNext() { lbCurrent = (lbCurrent + 1) % photos.length; showLbPhoto(); }
  function lbPrev() { lbCurrent = (lbCurrent - 1 + photos.length) % photos.length; showLbPhoto(); }

  const btnLbClose = document.getElementById('lbClose');
  const btnLbPrev  = document.getElementById('lbPrev');
  const btnLbNext  = document.getElementById('lbNext');

  if (btnLbClose) btnLbClose.addEventListener('click', closeLightbox);
  if (btnLbPrev)  btnLbPrev.addEventListener('click', lbPrev);
  if (btnLbNext)  btnLbNext.addEventListener('click', lbNext);

  /* Click en el fondo oscuro → cerrar */
  if (lb) lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });

  /* Teclado */
  document.addEventListener('keydown', e => {
    if (!lb || !lb.classList.contains('active')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowRight') lbNext();
    if (e.key === 'ArrowLeft')  lbPrev();
  });

  /* Swipe táctil en lightbox */
  let lbTouchX = 0;
  if (lb) {
    lb.addEventListener('touchstart', e => { lbTouchX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - lbTouchX;
      if (Math.abs(dx) > 40) { dx < 0 ? lbNext() : lbPrev(); }
    }, { passive: true });
  }
</script>
