const { apt, allApartments } = Astro.props;
const hasPhotos = apt.photos && apt.photos.length > 0;
---
<BaseLayout title={apt.name} description={apt.description}>

  <!-- ═══════════════════════════════════════════════════
       CARRUSEL DE FOTOS (hero + galería unificados)
       Swipe táctil nativo en móvil · Flechas en desktop
  ════════════════════════════════════════════════════ -->
  {hasPhotos && (
    <div class="carousel-wrap" id="carouselWrap">
      <!-- Pista deslizante -->
      <div class="carousel-track" id="cTrack" role="region" aria-label={`Fotos de ${apt.name}`}>
        {apt.photos.map((photo, i) => (
          <div class="carousel-slide" data-index={i}>
            <img
              src={`/images/apartamentos/${apt.slug}/${photo}`}
              alt={`${apt.name} - foto ${i + 1}`}
              class="c-img"
              data-index={i}
              loading={i === 0 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>

      <!-- Contador  "3 / 21" -->
      <div class="c-counter" id="cCounter" aria-live="polite">1 / {apt.photos.length}</div>

      <!-- Flechas (visibles en desktop, ocultas en móvil táctil) -->
      <button class="c-btn c-prev" id="cPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="c-btn c-next" id="cNext" aria-label="Foto siguiente">&#10095;</button>

      <!-- Indicador "desliza" solo la primera vez en móvil -->
      <div class="c-hint" id="cHint" aria-hidden="true">
        <span>← desliza →</span>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════
       CONTENIDO DEL APARTAMENTO
  ══════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-12">

      <!-- Info principal -->
      <div class="md:col-span-2">
        <h1 class="text-4xl font-light mb-2">Apartamento {apt.name}</h1>
        <p class="text-stone-500 mb-6">{apt.guests} personas · {apt.bedrooms} dorm. · {apt.bathrooms} baño · {apt.size} m²</p>
        <p class="text-lg text-stone-700 leading-relaxed mb-8">{apt.description}</p>

        <h2 class="font-semibold text-lg mb-4">Servicios incluidos</h2>
        <ul class="grid grid-cols-2 gap-2">
          {apt.amenities.map(a => (
            <li class="flex items-center gap-2 text-stone-600 text-sm">
              <span class="text-green-600">✓</span> {a}
            </li>
          ))}
        </ul>

        <div class="mt-8 p-4 bg-stone-50 rounded-xl text-sm text-stone-600">
          <strong>📍 Ubicación:</strong> Casco antiguo de Girona · Aparcament La Copa (gratuito, 10 min a pie)
        </div>
      </div>

      <!-- Sidebar reserva -->
      <div>
        <div class="sticky top-24 bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
          <h3 class="font-semibold text-lg mb-2">¿Te gusta?</h3>
          <p class="text-sm text-stone-600 mb-6">Consulta disponibilidad y reserva directamente.</p>
          <a href="/reservar" class="block w-full text-center bg-green-800 text-white py-3 rounded-full font-medium hover:bg-green-700 transition-colors mb-3">
            Ver disponibilidad
          </a>
          <a href="/contacto" class="block w-full text-center border border-stone-300 py-3 rounded-full text-sm hover:bg-stone-50 transition-colors">
            Hacer una pregunta
          </a>
        </div>
      </div>
    </div>

    <!-- Motor de reservas -->
    <div class="mt-16">
      <h2 class="text-2xl font-light text-center mb-8">Reservar {apt.name}</h2>
      <BookingWidget smoobuId={apt.smoobuId} />
    </div>

    <!-- Otros apartamentos -->
    <div class="mt-16">
      <h2 class="text-2xl font-light text-center mb-8">Otros apartamentos</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {allApartments.filter(a => a.slug !== apt.slug).slice(0, 4).map(a => (
          <a href={`/apartamentos/${a.slug}`} class="group rounded-xl border border-stone-200 hover:shadow-md transition-all overflow-hidden block">
            <div class="h-28 bg-stone-100 overflow-hidden">
              <img
                src={`/images/apartamentos/${a.slug}/foto-1.jpg`}
                alt={a.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-3 text-center">
              <div class="text-sm font-medium">{a.name}</div>
              <div class="text-xs text-stone-500">{a.guests} pers.</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       LIGHTBOX (pantalla completa al click)
  ══════════════════════════════════════════ -->
  {hasPhotos && (
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label={`Galería de ${apt.name}`}>
      <button class="lb-close" id="lbClose" aria-label="Cerrar">✕</button>
      <button class="lb-prev" id="lbPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="lb-next" id="lbNext" aria-label="Foto siguiente">&#10095;</button>
      <div class="lb-content">
        <img id="lb-img" src="" alt="" />
        <p id="lb-counter" class="lb-counter-text"></p>
      </div>
    </div>
  )}

</BaseLayout>

<!-- ═══════════════════════════════════════════════════
     ESTILOS
════════════════════════════════════════════════════ -->
<style>
  /* ── CARRUSEL ────────────────────────────────────── */
  .carousel-wrap {
    position: relative;
    width: 100%;
    /* Altura: en móvil ocupa casi la pantalla, en desktop es más compacto */
    height: min(72vw, 520px);
    background: #1c1917;
    overflow: hidden;
    user-select: none;
  }

  .carousel-track {
    display: flex;
    height: 100%;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; /* iOS momentum */
    scrollbar-width: none;            /* Firefox */
    cursor: grab;
  }
  .carousel-track:active { cursor: grabbing; }
  .carousel-track::-webkit-scrollbar { display: none; }

  .carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .c-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
    /* Sin transición para que el swipe se sienta instantáneo */
  }

  /* Contador */
  .c-counter {
    position: absolute;
    bottom: 16px;
    right: 16px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 20px;
    pointer-events: none;
  }

  /* Hint "desliza" */
  .c-hint {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.45);
    color: rgba(255,255,255,0.9);
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 20px;
    pointer-events: none;
    animation: fadeHint 3s ease forwards;
    backdrop-filter: blur(4px);
  }
  @keyframes fadeHint {
    0%   { opacity: 1; }
    60%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Flechas: ocultas en móvil táctil, visibles en hover en desktop */
  .c-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.25);
    border: none;
    color: #fff;
    font-size: 1.2rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, opacity 0.2s;
    z-index: 10;
    opacity: 0;                  /* ocultas por defecto */
  }
  .carousel-wrap:hover .c-btn { opacity: 1; }   /* aparecen al hover */
  .c-btn:hover { background: rgba(255,255,255,0.35); }
  .c-prev { left: 12px; }
  .c-next { right: 12px; }

  /* En móvil puro (sin hover) siempre las mostramos sutilmente */
  @media (hover: none) {
    .c-btn { opacity: 0.5; }
  }

  /* ── LIGHTBOX ────────────────────────────────────── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.93);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    touch-action: pan-x; /* swipe táctil en lightbox */
  }
  .lightbox.active { display: flex; }

  .lb-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 92vw;
    max-height: 92vh;
  }
  .lb-content img {
    max-width: 92vw;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .lb-counter-text {
    color: rgba(255,255,255,0.65);
    font-size: 0.82rem;
    margin-top: 12px;
    letter-spacing: 0.06em;
  }
  .lb-close {
    position: fixed;
    top: 18px;
    right: 20px;
    background: rgba(255,255,255,0.2);
    border: none;
    color: #fff;
    font-size: 1.3rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 1001;
  }
  .lb-close:hover { background: rgba(255,255,255,0.3); }
  .lb-prev,
  .lb-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.2);
    border: none;
    color: #fff;
    font-size: 1.3rem;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 1001;
  }
  .lb-prev { left: 14px; }
  .lb-next { right: 14px; }
  .lb-prev:hover,
  .lb-next:hover { background: rgba(255,255,255,0.3); }
</style>

<!-- ═══════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════ -->
<script define:vars={{ photos: apt.photos, slug: apt.slug, aptName: apt.name }}>
  if (!photos || photos.length === 0) return;

  /* ── CARRUSEL ── */
  const track    = document.getElementById('cTrack');
  const counter  = document.getElementById('cCounter');
  const btnPrev  = document.getElementById('cPrev');
  const btnNext  = document.getElementById('cNext');
  let currentIdx = 0;

  /* Actualiza contador leyendo la posición de scroll */
  function updateCounter() {
    if (!track || !counter) return;
    const idx = Math.round(track.scrollLeft / track.clientWidth);
    if (idx !== currentIdx) {
      currentIdx = idx;
      counter.textContent = `${idx + 1} / ${photos.length}`;
    }
  }

  /* Desplaza la pista al índice indicado (animado) */
  function scrollTo(idx) {
    if (!track) return;
    idx = Math.max(0, Math.min(photos.length - 1, idx));
    track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
    currentIdx = idx;
    if (counter) counter.textContent = `${idx + 1} / ${photos.length}`;
  }

  if (track) {
    track.addEventListener('scroll', updateCounter, { passive: true });
  }
  if (btnPrev) btnPrev.addEventListener('click', () => scrollTo(currentIdx - 1));
  if (btnNext) btnNext.addEventListener('click', () => scrollTo(currentIdx + 1));

  /* Click en foto → abrir lightbox */
  document.querySelectorAll('.c-img').forEach(img => {
    img.addEventListener('click', () => {
      openLightbox(parseInt(img.dataset.index));
    });
  });

  /* Oculta el hint "desliza" después de la animación CSS */
  const hint = document.getElementById('cHint');
  if (hint) setTimeout(() => { hint.style.display = 'none'; }, 3200);

  /* ── LIGHTBOX ── */
  const lb      = document.getElementById('lightbox');
  const lbImg   = document.getElementById('lb-img');
  const lbCnt   = document.getElementById('lb-counter');
  let lbCurrent = 0;

  function showLbPhoto() {
    if (!lbImg || !lbCnt) return;
    lbImg.src = `/images/apartamentos/${slug}/${photos[lbCurrent]}`;
    lbImg.alt = `${aptName} - foto ${lbCurrent + 1}`;
    lbCnt.textContent = `${lbCurrent + 1} / ${photos.length}`;
  }

  function openLightbox(idx) {
    lbCurrent = idx;
    showLbPhoto();
    if (lb) {
      lb.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    if (lb) {
      lb.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  function lbNext() { lbCurrent = (lbCurrent + 1) % photos.length; showLbPhoto(); }
  function lbPrev() { lbCurrent = (lbCurrent - 1 + photos.length) % photos.length; showLbPhoto(); }

  const btnLbClose = document.getElementById('lbClose');
  const btnLbPrev  = document.getElementById('lbPrev');
  const btnLbNext  = document.getElementById('lbNext');

  if (btnLbClose) btnLbClose.addEventListener('click', closeLightbox);
  if (btnLbPrev)  btnLbPrev.addEventListener('click', lbPrev);
  if (btnLbNext)  btnLbNext.addEventListener('click', lbNext);

  /* Click en el fondo oscuro → cerrar */
  if (lb) lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });

  /* Teclado */
  document.addEventListener('keydown', e => {
    if (!lb || !lb.classList.contains('active')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowRight') lbNext();
    if (e.key === 'ArrowLeft')  lbPrev();
  });

  /* Swipe táctil en lightbox */
  let lbTouchX = 0;
  if (lb) {
    lb.addEventListener('touchstart', e => { lbTouchX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - lbTouchX;
      if (Math.abs(dx) > 40) { dx < 0 ? lbNext() : lbPrev(); }
    }, { passive: true });
  }
</script>
