const { apt, allApartments } = Astro.props;
const hasPhotos = apt.photos && apt.photos.length > 0;
const t = getT('es');
const siteUrl = "https://aromatik.apartments";
const aptUrl = `${siteUrl}/apartamentos/${apt.slug}`;

const apartmentSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Apartment",
  "name": `Apartamento ${apt.name} — Barri Vell de Girona`,
  "description": apt.seoDescription ?? apt.description,
  "url": aptUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": apt.address,
    "addressLocality": "Girona",
    "addressRegion": "Cataluña",
    "postalCode": "17004",
    "addressCountry": "ES"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 41.9833, "longitude": 2.8249 },
  "numberOfRooms": apt.bedrooms,
  "floorSize": { "@type": "QuantitativeValue", "value": apt.size, "unitCode": "MTK" },
  "occupancy": { "@type": "QuantitativeValue", "maxValue": apt.guests },
  "petsAllowed": true,
  "image": apt.photos.slice(0, 5).map((p: string) => `${siteUrl}/images/apartamentos/${apt.slug}/${p}`),
  "containedInPlace": {
    "@type": "LodgingBusiness",
    "name": "Aromatik Apartments",
    "url": siteUrl
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "url": aptUrl
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Apartamentos", "item": `${siteUrl}/#apartamentos` },
    { "@type": "ListItem", "position": 3, "name": apt.name, "item": aptUrl }
  ]
});
---
<BaseLayout title={apt.seoTitle ?? `Apartamento ${apt.name} — Barri Vell de Girona | Aromatik`} description={apt.seoDescription ?? apt.description}>
  <script type="application/ld+json" set:html={apartmentSchema} slot="head" />
  <script type="application/ld+json" set:html={breadcrumbSchema} slot="head" />

  <!-- ═══════════════════════════════════════════════════
       CARRUSEL DE FOTOS (hero + galería unificados)
       Swipe táctil nativo en móvil · Flechas en desktop
  ════════════════════════════════════════════════════ -->
  {hasPhotos && (
    <div class="carousel-wrap" id="carouselWrap">
      <!-- Pista deslizante -->
      <div class="carousel-track" id="cTrack" role="region" aria-label={`Fotos de ${apt.name}`}>
        {apt.photos.map((photo, i) => (
          <div class="carousel-slide" data-index={i}>
            <img
              src={`/images/apartamentos/${apt.slug}/${photo}`}
              alt={i === 0 ? `${apt.h1 ?? `Apartamento ${apt.name} en el Barri Vell de Girona`}` : `${apt.name} — foto ${i + 1} — apartamento turístico en Girona`}
              class="c-img"
              data-index={i}
              loading={i === 0 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>

      <!-- Contador  "3 / 21" -->
      <div class="c-counter" id="cCounter" aria-live="polite">1 / {apt.photos.length}</div>

      <!-- Flechas (visibles en desktop, ocultas en móvil táctil) -->
      <button class="c-btn c-prev" id="cPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="c-btn c-next" id="cNext" aria-label="Foto siguiente">&#10095;</button>

      <!-- Indicador "desliza" solo la primera vez en móvil -->
      <div class="c-hint" id="cHint" aria-hidden="true">
        <span>{t.aptSwipeHint}</span>
      </div>
    </div>
  )}

  <!-- CONTENIDO DEL APARTAMENTO -->
  <div class="apt-container">
    <div class="apt-layout">

      <!-- Info principal -->
      <div class="apt-main">
        <h1 class="apt-title">{apt.h1 ?? `Apartamento ${apt.name}`}</h1>

        <div class="apt-stats">
          <span class="stat-badge">👥 {apt.guests} personas</span>
          <span class="stat-badge">🛏 {apt.bedrooms} dormitorio{apt.bedrooms > 1 ? 's' : ''}</span>
          <span class="stat-badge">🚿 {apt.bathrooms} baño{apt.bathrooms > 1 ? 's' : ''}</span>
          <span class="stat-badge">📐 {apt.size} m²</span>
        </div>

        <div class="apt-divider"></div>

        <p class="apt-description">{apt.description}</p>

        <div class="apt-section">
          <h2 class="apt-section-title">{t.aptServicesTitle}</h2>
          <ul class="apt-amenities">
            {apt.amenities.map(a => (
              <li class="amenity-item">
                <span class="amenity-check">✓</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Sidebar reserva -->
      <div class="apt-sidebar">
        <div class="booking-card">
          <div class="booking-card-header">
            <h3 class="booking-card-title">{t.aptBookTitle}</h3>
            <p class="booking-card-sub">{t.aptBookSubtitle}</p>
          </div>
          <a href="#reservar-widget" class="btn-reservar js-scroll-reservar">{t.aptBookCta}</a>
          <a href="/contacto" class="btn-contactar">{t.aptContactCta}</a>
          <p class="booking-note">{t.aptBookNote}</p>
        </div>
      </div>
    </div>

    <!-- Motor de reservas -->
    <div class="booking-section" id="reservar-widget">
      <h2 class="section-heading">{t.aptBookingTitle(apt.name)}</h2>
      <BookingWidget smoobuId={apt.smoobuId} />
    </div>


    <!-- Otros apartamentos -->
    <div class="otros-section">
      <h2 class="section-heading">{t.aptOtherTitle}</h2>
      <div class="apts-grid">
        {allApartments.filter(a => a.slug !== apt.slug).slice(0, 4).map(a => {
          const count = Math.min(5, a.photos.length);
          const photoNums = Array.from({ length: count }, (_, i) => i + 1);
          return (
            <a href={`/apartamentos/${a.slug}`} class="apt-card">
              <div class="apt-card-img" style={`background-color:#e7e5e4`}>
                {photoNums.map((n, i) => (
                  <img
                    src={`/images/apartamentos/${a.slug}/foto-${n}.jpg`}
                    alt={`${a.name} - foto ${n}`}
                    class={i > 0 ? 'c-hidden' : ''}
                    loading="lazy"
                  />
                ))}
                {count > 1 && (
                  <>
                    <button class="apt-card-prev" aria-label="Anterior">&#8249;</button>
                    <button class="apt-card-next" aria-label="Siguiente">&#8250;</button>
                    <div class="apt-card-dots">
                      {photoNums.map((_, i) => (
                        <span class={`apt-card-dot${i === 0 ? ' c-active' : ''}`}></span>
                      ))}
                    </div>
                  </>
                )}
              </div>
              <div class="apt-card-body">
                <h3>{a.name}</h3>
                <p class="apt-meta">{a.guests} pers. · {a.bedrooms} dorm. · {a.size} m²</p>
                <span class="apt-link">{t.aptsViewBtn}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>

  <HostCard />
  <ReviewsCarousel />

  <!-- ═══════════════════════════════════════
       LIGHTBOX (pantalla completa al click)
  ══════════════════════════════════════════ -->
  {hasPhotos && (
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label={`Galería de ${apt.name}`}>
      <button class="lb-close" id="lbClose" aria-label="Cerrar">✕</button>
      <button class="lb-prev" id="lbPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="lb-next" id="lbNext" aria-label="Foto siguiente">&#10095;</button>
      <div class="lb-content">
        <img id="lb-img" src="" alt="" />
        <p id="lb-counter" class="lb-counter-text"></p>
      </div>
    </div>
  )}

</BaseLayout>

<!-- ═══════════════════════════════════════════════════
     ESTILOS
════════════════════════════════════════════════════ -->
<style>
  /* ── CONTENEDOR PRINCIPAL ──────────────────────── */
  .apt-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  @media (max-width: 640px) { .apt-container { padding: 2rem 1rem; } }

  /* ── CARRUSEL ────────────────────────────────────── */
  .carousel-wrap {
    position: relative;
    width: 100%;
    height: min(72vw, 520px);
    background: #1c1917;
    overflow: hidden;
    user-select: none;
  }
  .carousel-track {
    display: flex; height: 100%;
    overflow-x: scroll; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; scrollbar-width: none; cursor: grab;
  }
  .carousel-track:active { cursor: grabbing; }
  .carousel-track::-webkit-scrollbar { display: none; }
  .carousel-slide { flex: 0 0 100%; width: 100%; height: 100%; scroll-snap-align: start; scroll-snap-stop: always; }
  .c-img { width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in; }
  .c-counter { position: absolute; bottom: 16px; right: 16px; background: rgba(0,0,0,0.6); color: #fff; font-size: 0.8rem; letter-spacing: 0.08em; padding: 4px 10px; border-radius: 20px; pointer-events: none; }
  .c-hint { position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.45); color: rgba(255,255,255,0.9); font-size: 0.75rem; padding: 4px 12px; border-radius: 20px; pointer-events: none; animation: fadeHint 3s ease forwards; }
  @keyframes fadeHint { 0%,60% { opacity:1; } 100% { opacity:0; } }
  .c-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.25); border: none; color: #fff; font-size: 1.2rem; width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, opacity 0.2s; z-index: 10; opacity: 0; }
  .carousel-wrap:hover .c-btn { opacity: 1; }
  .c-btn:hover { background: rgba(255,255,255,0.35); }
  .c-prev { left: 12px; } .c-next { right: 12px; }
  @media (hover: none) { .c-btn { opacity: 0.5; } }

  /* ── LAYOUT APARTAMENTO ──────────────────────────── */
  .apt-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .apt-layout { grid-template-columns: 1fr; }
    .apt-sidebar { order: -1; }
  }

