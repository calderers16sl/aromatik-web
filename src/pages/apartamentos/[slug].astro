      emoji: "💜",
      photos: ['foto-1.jpg','foto-2.jpg','foto-3.jpg','foto-4.jpg','foto-5.jpg','foto-6.jpg','foto-7.jpg','foto-8.jpg','foto-9.jpg','foto-10.jpg','foto-11.jpg','foto-12.jpg','foto-13.jpg','foto-14.jpg','foto-15.jpg','foto-16.jpg','foto-17.jpg','foto-18.jpg','foto-19.jpg'] },
    { name: "Limón", slug: "limon", guests: 2, bedrooms: 1, bathrooms: 1, size: 30, smoobuId: 1037266,
      description: "Fresco y luminoso apartamento con vistas a la ciudad. Un dormitorio en el casco histórico de Girona, perfecto para parejas y viajeros con mascotas.",
