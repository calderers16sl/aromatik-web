    { name: "Lavanda", slug: "lavanda", guests: 2, bedrooms: 1, bathrooms: 1, size: 50, smoobuId: 1033339,
      description: "Tranquilo apartamento con vistas al río Onyar. Perfecto para parejas que buscan un refugio de calma en pleno centro histórico de Girona.",
      amenities: ["WiFi", "Aire acondicionado", "Cocina equipada", "Nevera", "Microondas", "Cafetera", "Lavadora", "Ascensor", "Vistas al río", "Calefacción", "Secador de pelo", "Self check-in"],
      emoji: "💜",
      photos: ['foto-1.jpg','foto-2.jpg','foto-3.jpg','foto-4.jpg','foto-5.jpg','foto-6.jpg','foto-7.jpg','foto-8.jpg','foto-9.jpg','foto-10.jpg','foto-11.jpg','foto-12.jpg','foto-13.jpg','foto-14.jpg','foto-15.jpg','foto-16.jpg','foto-17.jpg','foto-18.jpg','foto-19.jpg'] },
    { name: "Limón", slug: "limon", guests: 2, bedrooms: 1, bathrooms: 1, size: 30, smoobuId: 1037266,
      description: "Fresco y luminoso apartamento con vistas a la ciudad. Un dormitorio en el casco histórico de Girona, perfecto para parejas y viajeros con mascotas.",
      amenities: ["WiFi", "Aire acondicionado", "Cocina equipada", "Nevera", "Microondas", "Cafetera", "Lavadora", "TV", "Vistas a la ciudad", "Calefacción", "Secador de pelo", "Self check-in", "Se admiten mascotas"],
      emoji: "🍋",
      photos: ['foto-1.jpg','foto-2.jpg','foto-3.jpg','foto-4.jpg','foto-5.jpg','foto-6.jpg','foto-7.jpg','foto-8.jpg','foto-9.jpg','foto-10.jpg','foto-11.jpg','foto-12.jpg','foto-13.jpg','foto-14.jpg','foto-15.jpg','foto-16.jpg','foto-17.jpg','foto-18.jpg','foto-19.jpg','foto-20.jpg','foto-21.jpg'] },
    { name: "Bergamota", slug: "bergamota", guests: 6, bedrooms: 3, bathrooms: 2, size: 120, smoobuId: 1034422,
      description: "Espectacular ático con vistas al río en el casco antiguo. Tres dormitorios, dos baños completos, bañera, cocina de alta gama con Nespresso y balcón privado.",
      amenities: ["WiFi", "Aire acondicionado", "Cocina completa", "Nevera", "Microondas", "Horno", "Cafetera Nespresso", "Lavadora", "Ascensor", "Balcón", "Vistas al río", "Bañera", "Calefacción", "Secador de pelo", "Self check-in"],
      emoji: "🍊",
      photos: ['foto-1.jpg','foto-2.jpg','foto-3.jpg','foto-4.jpg','foto-5.jpg','foto-6.jpg','foto-7.jpg','foto-8.jpg','foto-9.jpg','foto-10.jpg','foto-11.jpg','foto-12.jpg','foto-13.jpg','foto-14.jpg','foto-15.jpg','foto-16.jpg','foto-17.jpg','foto-18.jpg','foto-19.jpg','foto-20.jpg','foto-21.jpg'] },
    { name: "Árbol de té", slug: "arbol-de-te", guests: 6, bedrooms: 3, bathrooms: 2, size: 130, smoobuId: 1315321,
      description: "Lujoso ático de diseño en el centro de Girona. Tres dormitorios, dos baños, cocina completa y todo el equipamiento para grupos o familias que quieren lo mejor del Barri Vell.",
      amenities: ["WiFi", "Aire acondicionado", "Cocina equipada", "Nevera", "Microondas", "Cafetera", "Lavadora", "Ascensor", "TV", "Calefacción", "Secador de pelo", "Self check-in", "Se admiten mascotas"],
      emoji: "🌱",
      photos: ['foto-1.jpg','foto-2.jpg','foto-3.jpg','foto-4.jpg','foto-5.jpg','foto-6.jpg','foto-7.jpg','foto-8.jpg','foto-9.jpg','foto-10.jpg','foto-11.jpg','foto-12.jpg','foto-13.jpg','foto-14.jpg','foto-15.jpg','foto-16.jpg','foto-17.jpg','foto-18.jpg','foto-19.jpg','foto-20.jpg','foto-21.jpg','foto-22.jpg','foto-23.jpg'] },
    { name: "Geranio", slug: "geranio", guests: 2, bedrooms: 1, bathrooms: 1, size: 40, smoobuId: 1599430,
      description: "Alegre apartamento en el barrio viejo de Girona. Un dormitorio con todo lo necesario para una estancia cómoda en el corazón del casco antiguo.",
      amenities: ["WiFi", "Aire acondicionado", "Cocina equipada", "Nevera", "Microondas", "Cafetera", "Lavadora", "Ascensor", "TV", "Calefacción", "Secador de pelo", "Self check-in"],
      emoji: "🌺",
      photos: ['foto-1.jpg','foto-2.jpg','foto-3.jpg','foto-4.jpg','foto-5.jpg','foto-6.jpg','foto-7.jpg','foto-8.jpg','foto-9.jpg','foto-10.jpg','foto-11.jpg','foto-12.jpg','foto-13.jpg','foto-14.jpg','foto-15.jpg','foto-16.jpg','foto-17.jpg','foto-18.jpg','foto-19.jpg','foto-20.jpg'] },
  ];
  return apartments.map(apt => ({ params: { slug: apt.slug }, props: { apt, allApartments: apartments } }));
}

const { apt, allApartments } = Astro.props;
const hasPhotos = apt.photos && apt.photos.length > 0;
---
<BaseLayout title={apt.name} description={apt.description}>

  <!-- ═══════════════════════════════════════════════════
       CARRUSEL DE FOTOS (hero + galería unificados)
       Swipe táctil nativo en móvil · Flechas en desktop
  ════════════════════════════════════════════════════ -->
  {hasPhotos && (
    <div class="carousel-wrap" id="carouselWrap">
      <!-- Pista deslizante -->
      <div class="carousel-track" id="cTrack" role="region" aria-label={`Fotos de ${apt.name}`}>
        {apt.photos.map((photo, i) => (
          <div class="carousel-slide" data-index={i}>
            <img
              src={`/images/apartamentos/${apt.slug}/${photo}`}
              alt={`${apt.name} - foto ${i + 1}`}
              class="c-img"
              data-index={i}
              loading={i === 0 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>

      <!-- Contador  "3 / 21" -->
      <div class="c-counter" id="cCounter" aria-live="polite">1 / {apt.photos.length}</div>

      <!-- Flechas (visibles en desktop, ocultas en móvil táctil) -->
      <button class="c-btn c-prev" id="cPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="c-btn c-next" id="cNext" aria-label="Foto siguiente">&#10095;</button>

      <!-- Indicador "desliza" solo la primera vez en móvil -->
      <div class="c-hint" id="cHint" aria-hidden="true">
        <span>← desliza →</span>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════
       CONTENIDO DEL APARTAMENTO
  ══════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-12">

      <!-- Info principal -->
      <div class="md:col-span-2">
        <h1 class="text-4xl font-light mb-2">Apartamento {apt.name}</h1>
        <p class="text-stone-500 mb-6">{apt.guests} personas · {apt.bedrooms} dorm. · {apt.bathrooms} baños · {apt.size} m²</p>
        <p class="text-lg text-stone-700 leading-relaxed mb-8">{apt.description}</p>

        <h2 class="font-semibold text-lg mb-4">Servicios incluidos</h2>
        <ul class="grid grid-cols-2 gap-2">
          {apt.amenities.map(a => (
            <li class="flex items-center gap-2 text-stone-600 text-sm">
              <span class="text-green-600">✓</span> {a}
            </li>
          ))}
        </ul>

        <div class="mt-8 p-4 bg-stone-50 rounded-xl text-sm text-stone-600">
          <strong>📍 Ubicación:</strong> Casco antiguo de Girona · Aparcament La Copa (gratuito, 10 min a pie)
        </div>
      </div>

      <!-- Sidebar reserva -->
      <div>
        <div class="sticky top-24 bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
          <h3 class="font-semibold text-lg mb-2">¿Te gusta?</h3>
          <p class="text-sm text-stone-600 mb-6">Consulta disponibilidad y reserva directamente.</p>
          <a href="/reservar" class="block w-full text-center bg-green-800 text-white py-3 rounded-full font-medium hover:bg-green-700 transition-colors mb-3">
            Ver disponibilidad
          </a>
          <a href="/contacto" class="block w-full text-center border border-stone-300 py-3 rounded-full text-sm hover:bg-stone-50 transition-colors">
            Hacer una pregunta
          </a>
        </div>
      </div>
    </div>

    <!-- Motor de reservas -->
    <div class="mt-16">
      <h2 class="text-2xl font-light text-center mb-8">Reservar {apt.name}</h2>
      <BookingWidget smoobuId={apt.smoobuId} />
    </div>

    <!-- Otros apartamentos -->
    <div class="mt-16">
      <h2 class="text-2xl font-light text-center mb-8">Otros apartamentos</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {allApartments.filter(a => a.slug !== apt.slug).slice(0, 4).map(a => (
          <a href={`/apartamentos/${a.slug}`} class="group rounded-xl border border-stone-200 hover:shadow-md transition-all overflow-hidden block">
            <div class="h-28 bg-stone-100 overflow-hidden">
              <img
                src={`/images/apartamentos/${a.slug}/foto-1.jpg`}
                alt={a.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-3 text-center">
              <div class="text-sm font-medium">{a.name}</div>
              <div class="text-xs text-stone-500">{a.guests} pers.</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       LIGHTBOX (pantalla completa al click)
  ══════════════════════════════════════════ -->
  {hasPhotos && (
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label={`Galería de ${apt.name}`}>
      <button class="lb-close" id="lbClose" aria-label="Cerrar">✕</button>
      <button class="lb-prev" id="lbPrev" aria-label="Foto anterior">&#10094;</button>
      <button class="lb-next" id="lbNext" aria-label="Foto siguiente">&#10095;</button>
      <div class="lb-content">
        <img id="lb-img" src="" alt="" />
        <p id="lb-counter" class="lb-counter-text"></p>
      </div>
    </div>
  )}

</BaseLayout>

<!-- ═══════════════════════════════════════════════════
     ESTILOS
════════════════════════════════════════════════════ -->
<style>
  /* ── CARRUSEL ────────────────────────────────────── */
  .carousel-wrap {
    position: relative;
    width: 100%;
    height: min(72vw, 520px);
    background: #1c1917;
    overflow: hidden;
    user-select: none;
  }

  .carousel-track {
    display: flex;
    height: 100%;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
  }
  .carousel-track:active { cursor: grabbing; }
  .carousel-track::-webkit-scrollbar { display: none; }

  .carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .c-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
  }

  .c-counter {
    position: absolute;
    bottom: 16px;
    right: 16px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 20px;
    pointer-events: none;
  }

  .c-hint {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.45);
    color: rgba(255,255,255,0.9);
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 20px;
    pointer-events: none;
    animation: fadeHint 3s ease forwards;
    backdrop-filter: blur(4px);
  }
  @keyframes fadeHint {
    0%   { opacity: 1; }
    60%  { opacity: 1; }
    100% { opacity: 0; }
  }

  .c-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.25);
    border: none;
    color: #fff;
    font-size: 1.2rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, opacity 0.2s;
    z-index: 10;
    opacity: 0;
  }
  .carousel-wrap:hover .c-btn { opacity: 1; }
  .c-btn:hover { background: rgba(255,255,255,0.35); }
  .c-prev { left: 12px; }
  .c-next { right: 12px; }
  @media (hover: none) { .c-btn { opacity: 0.5; } }

  /* ── CONTENIDO DEL APARTAMENTO ───────────────────── */
  .apt-title {
    font-size: 2.4rem;
    font-weight: 300;
    color: #1c1917;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  @media (max-width: 640px) { .apt-title { font-size: 1.9rem; } }

  .apt-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #f5f5f4;
    border: 1px solid #e7e5e4;
    color: #44403c;
    font-size: 0.82rem;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .apt-divider {
    border: none;
    border-top: 1px solid #e7e5e4;
    margin: 1.5rem 0;
  }

  .apt-description {
    font-size: 1.1rem;
    color: #57534e;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* Servicios */
  .apt-section { margin-bottom: 2rem; }
  .apt-section-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1c1917;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e7e5e4;
  }
  .amenities-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (max-width: 480px) { .amenities-grid { grid-template-columns: 1fr; } }
  .amenity-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: #57534e;
    padding: 0.5rem 0.75rem;
    background: #fafaf9;
    border: 1px solid #f0efed;
    border-radius: 0.5rem;
  }
  .amenity-check {
    color: #d0b050;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Ubicación */
  .location-box {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    background: #fdf8ec;
    border: 1px solid #e8c870;
    border-radius: 0.875rem;
    padding: 1rem 1.25rem;
    margin-top: 1.5rem;
  }
  .location-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
  .location-title { font-weight: 600; font-size: 0.9rem; color: #7a5c10; margin: 0 0 0.2rem; }
  .location-sub { font-size: 0.8rem; color: #8a6a20; margin: 0; }

  /* Sidebar booking card */
  .booking-card {
    position: sticky;
    top: 88px;
    background: #fff;
    border: 1.5px solid #d6d3d1;
    border-radius: 1.25rem;
    padding: 1.75rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  }
  .booking-card-header { margin-bottom: 1.25rem; }
  .booking-card-title { font-size: 1.2rem; font-weight: 600; color: #1c1917; margin: 0 0 0.3rem; }
  .booking-card-sub { font-size: 0.85rem; color: #78716c; margin: 0; }
  .btn-primary {
    display: block;
    width: 100%;
    text-align: center;
    background: #d0b050;
    color: #fff;
    padding: 0.875rem 1.5rem;
    border-radius: 9999px;
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s;
    margin-bottom: 0.75rem;
  }
  .btn-primary:hover { background: #b89a40; }
  .btn-secondary {
    display: block;
    width: 100%;
    text-align: center;
    border: 1.5px solid #d6d3d1;
    color: #44403c;
    padding: 0.875rem 1.5rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
    margin-bottom: 1rem;
  }
  .btn-secondary:hover { background: #fafaf9; border-color: #a8a29e; }
  .booking-note {
    font-size: 0.72rem;
    color: #a8a29e;
    text-align: center;
    margin: 0;
  }

  /* Motor reservas */
  .booking-section { margin-top: 4rem; }
  .section-heading {
    font-size: 1.75rem;
    font-weight: 300;
    text-align: center;
    color: #1c1917;
    margin-bottom: 2rem;
  }

  /* ── OTROS APARTAMENTOS ──────────────────────────── */
  .otros-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid #e7e5e4;
  }
  .otros-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .otros-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .otro-card {
    display: block;
    text-decoration: none;
    background: #fff;
    border: 1.5px solid #e7e5e4;
    border-radius: 1rem;
    overflow: hidden;
    transition: box-shadow 0.25s, border-color 0.25s, transform 0.25s;
  }
  .otro-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    border-color: #a8a29e;
    transform: translateY(-2px);
  }

  .otro-img-wrap {
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: #e7e5e4;
  }
  @media (max-width: 640px) { .otro-img-wrap { height: 130px; } }

  .otro-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .otro-info {
    padding: 0.875rem 1rem;
    border-top: 1px solid #f0efed;
  }
  .otro-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1c1917;
    margin-bottom: 0.25rem;
  }
  .otro-meta {
    font-size: 0.75rem;
    color: #78716c;
  }

  /* ── LIGHTBOX ────────────────────────────────────── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.93);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    touch-action: pan-x;
  }
  .lightbox.active { display: flex; }

  .lb-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 92vw;
    max-height: 92vh;
  }
  .lb-content img {
    max-width: 92vw;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .lb-counter-text {
    color: rgba(255,255,255,0.65);
    font-size: 0.82rem;
    margin-top: 12px;
    letter-spacing: 0.06em;
  }
