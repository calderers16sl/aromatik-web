---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/BookingWidget.astro';

export function getStaticPaths() {
  const apartments = [
    { name: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, bathrooms: 1, size: 70, smoobuId: 1397576, emoji: "🌸", color: "#C8B89A",
      description: "Un apartamento luminoso con el aroma delicado del ylang-ylang. Diseñado con cuidado y equipado con todo lo necesario para disfrutar del Barri Vell de Girona. Perfecto para parejas y familias pequeñas que buscan comodidad y carácter en el corazón histórico de la ciudad.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ascensor", "Ropa de cama incluida", "Check-in flexible"] },
    { name: "Romaní", slug: "romani", guests: 2, bedrooms: 1, bathrooms: 1, size: 45, smoobuId: 1033021, emoji: "🌿", color: "#8EAB85",
      description: "Acogedor y aromático como la planta que le da nombre. Un apartamento íntimo en el centro histórico de Girona, ideal para escapadas románticas. La ubicación en el Barri Vell te pone a pasos de los principales monumentos de la ciudad.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ropa de cama incluida"] },
    { name: "Ciprés", slug: "cipres", guests: 4, bedrooms: 2, bathrooms: 1, size: 65, smoobuId: 1035631, emoji: "🌲", color: "#6B9B7E",
      description: "Elegante como el ciprés mediterráneo. Dos habitaciones bien distribuidas en el corazón del Barri Vell de Girona. Perfecto para grupos de amigos o familias que quieren explorar la ciudad medieval con toda la comodidad.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ascensor", "Ropa de cama incluida"] },
    { name: "Lavanda", slug: "lavanda", guests: 2, bedrooms: 1, bathrooms: 1, size: 50, smoobuId: 1033339, emoji: "💜", color: "#A899BB",
      description: "Tranquilo y relajante como un campo de lavanda en flor. Un refugio de calma en pleno centro histórico de Girona. La decoración cuidada y la ubicación privilegiada hacen de Lavanda una experiencia única en el Barri Vell.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ropa de cama incluida"] },
    { name: "Limón", slug: "limon", guests: 3, bedrooms: 1, bathrooms: 1, size: 55, smoobuId: 1037266, emoji: "🍋", color: "#C4BC7E",
      description: "Fresco y vibrante como el cítrico que lo inspira. Con capacidad para tres personas, es la opción perfecta para grupos pequeños que quieren descubrir Girona desde el Barri Vell con toda la comodidad.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ropa de cama incluida"] },
    { name: "Bergamota", slug: "bergamota", guests: 4, bedrooms: 2, bathrooms: 1, size: 68, smoobuId: 1034422, emoji: "🍊", color: "#C4A06E",
      description: "Sofisticado y cálido como el aroma de la bergamota. Dos habitaciones con todo el confort para disfrutar de Girona al máximo. Ubicado en el centro histórico, a pocos pasos de la Catedral y el río Onyar.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ascensor", "Ropa de cama incluida"] },
    { name: "Árbol de té", slug: "arbol-de-te", guests: 2, bedrooms: 1, bathrooms: 1, size: 48, smoobuId: 1315321, emoji: "🌱", color: "#7AAF9E",
      description: "Puro y reconfortante como el árbol de té. Un apartamento íntimo para dos, diseñado para el descanso y la desconexión en pleno corazón del Barri Vell de Girona. Calma y comodidad en un entorno histórico excepcional.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ropa de cama incluida"] },
    { name: "Geranio", slug: "geranio", guests: 4, bedrooms: 2, bathrooms: 1, size: 72, smoobuId: 1599430, emoji: "🌺", color: "#C49090",
      description: "Alegre y mediterráneo como los geranios de los balcones de Girona. El más amplio de los apartamentos de Aromatik Apartments, con dos habitaciones bien equipadas en el centro histórico. Un espacio con carácter y comodidad para grupos y familias.",
      amenities: ["WiFi fibra óptica", "Aire acondicionado", "Cocina totalmente equipada", "Lavadora", "Friendly para bicicletas", "Ascensor", "Ropa de cama incluida", "Check-in flexible"] },
  ];
  return apartments.map(apt => ({ params: { slug: apt.slug }, props: { apt, allApartments: apartments } }));
}

const { apt, allApartments } = Astro.props;
---
<BaseLayout
  title={`Apartamento ${apt.name} — Aromatik Apartments, Barri Vell Girona`}
  description={`${apt.name}: apartamento boutique para ${apt.guests} personas en el Barri Vell de Girona. ${apt.size} m², ${apt.bedrooms === 1 ? '1 habitación' : apt.bedrooms + ' habitaciones'}. Reserva directa con Aromatik Apartments.`}
>
  <!-- HERO APARTAMENTO -->
  <div class="apt-detail-hero" style={`background-color: ${apt.color}`}>
    <span class="apt-detail-emoji">{apt.emoji}</span>
  </div>

  <!-- CONTENIDO PRINCIPAL -->
  <section class="section">
    <div class="container">
      <div class="apt-detail-grid">

        <!-- INFORMACIÓN -->
        <div>
          <p class="eyebrow" style="margin-bottom:0.75rem">Un apartamento de Aromatik Apartments</p>
          <h1 class="apt-detail-title">{apt.name}</h1>
          <p class="apt-detail-meta">
            {apt.guests} personas &nbsp;·&nbsp; {apt.bedrooms === 1 ? '1 habitación' : `${apt.bedrooms} habitaciones`} &nbsp;·&nbsp; {apt.bathrooms} baño &nbsp;·&nbsp; {apt.size} m²
          </p>
          <p class="apt-detail-desc">{apt.description}</p>

          <p class="amenities-label">Servicios incluidos</p>
          <ul class="amenities-grid">
            {apt.amenities.map((a: string) => (
              <li><span class="check-icon">✓</span> {a}</li>
            ))}
          </ul>

          <div class="location-box mt-8">
            <strong>📍 Ubicación:</strong> Barri Vell de Girona — a pocos minutos a pie de la Catedral, el Call Jueu y el río Onyar.<br/>
            <span style="color:var(--stone-500)">Parking gratuito La Copa a 10 min a pie · Parkings de pago Saba disponibles cerca.</span>
          </div>
        </div>

        <!-- TARJETA RESERVA -->
        <div>
          <div class="booking-card">
            <h3>¿Te gusta {apt.name}?</h3>
            <p>Gestión local, check-in fácil, atención directa y reserva segura en el centro histórico de Girona.</p>
            <a href="/reservar" class="btn btn-green">Ver disponibilidad</a>
            <a href="/contacto" class="btn btn-border">Hacer una pregunta</a>
            <hr class="divider" style="margin:1.25rem 0"/>
            <p style="font-size:0.75rem; color:var(--stone-400); line-height:1.7; text-align:center;">
              Mejor precio garantizado al reservar directamente con Aromatik Apartments
            </p>
          </div>
        </div>

      </div>

      <!-- MOTOR DE RESERVAS -->
      <div class="mt-16">
        <h2 style="font-family:var(--serif); font-size:1.8rem; font-weight:400; text-align:center; margin-bottom:2rem;">
          Reservar apartamento {apt.name}
        </h2>
        <BookingWidget smoobuId={apt.smoobuId} />
      </div>

      <!-- OTROS APARTAMENTOS -->
      <div class="mt-16">
        <h2 style="font-family:var(--serif); font-size:1.5rem; font-weight:400; text-align:center; margin-bottom:2rem;">
          Otros apartamentos de Aromatik Apartments
        </h2>
        <div class="other-apts-grid">
          {allApartments.filter((a: any) => a.slug !== apt.slug).slice(0, 4).map((a: any) => (
            <a href={`/apartamentos/${a.slug}`} class="other-apt">
              <div class="other-apt-emoji">{a.emoji}</div>
              <div class="other-apt-name">{a.name}</div>
              <div class="other-apt-cap">{a.guests} personas</div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
