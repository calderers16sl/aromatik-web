---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto" description="Contacta con Aromatik Apartments en Girona.">
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-light text-center mb-4">Contacto</h1>
    <p class="text-center text-stone-600 mb-12">¿Tienes alguna pregunta? Escríbenos, te respondemos en menos de 1h.</p>
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="font-semibold mb-4">Datos de contacto</h2>
        <ul class="space-y-3 text-stone-600">
          <li>📞 <a href="tel:+34682636848" class="hover:text-green-700">+34 682 636 848</a></li>
          <li>✉️ <a href="mailto:calderers16sl@gmail.com" class="hover:text-green-700">calderers16sl@gmail.com</a></li>
          <li>📍 Girona, casco antiguo</li>
        </ul>
      </div>
      <form class="space-y-4" action="https://formspree.io/f/XXXXXXXX" method="POST">
        <input type="text" name="name" placeholder="Tu nombre" required class="w-full border border-stone-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-green-700" />
        <input type="email" name="email" placeholder="Tu email" required class="w-full border border-stone-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-green-700" />
        <textarea name="message" rows="5" placeholder="Tu mensaje" required class="w-full border border-stone-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-green-700"></textarea>
        <button type="submit" class="w-full bg-green-800 text-white py-3 rounded-full font-medium hover:bg-green-700 transition-colors">
          Enviar mensaje
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
