  nl: {
    title: "Huisregels", subtitle: "Zodat iedereen geniet van een perfect verblijf",
    rules: [
      { icon: "🕐", html: "<strong>Check-in:</strong> vanaf 15:00 · <strong>Check-out:</strong> voor 11:00" },
      { icon: "🤫", html: "<strong>Stille uren:</strong> respecteer de rust van de buren tussen 22:00 en 9:00. Girona is een woonstad." },
      { icon: "🚭", html: "<strong>Niet roken</strong> binnen in de appartementen. Gemeenschappelijke buitenruimtes mogen worden gebruikt indien aanwezig." },
      { icon: "🐾", html: "<strong>Huisdieren:</strong> check de beschikbaarheid bij ons voor het boeken. Sommige appartementen accepteren huisdieren op verzoek." },
      { icon: "👥", html: "<strong>Maximale bezetting:</strong> het aantal gasten dat in de boeking staat vermeld mag in geen geval worden overschreden." },
      { icon: "🎉", html: "<strong>Feesten en evenementen</strong> zijn niet toegestaan in de appartementen. De accommodatie is uitsluitend voor residentieel-toeristisch gebruik." },
      { icon: "♻️", html: "<strong>Recycling:</strong> scheid afval in de aangegeven containers. Wij leggen bij check-in het recyclingsysteem van Girona uit." },
      { icon: "🔑", html: "<strong>Sleutels:</strong> geef de sleutels terug aan het einde van uw verblijf. Verlies of beschadiging van sleutels brengt extra kosten met zich mee." },
    ],
    note: "Vragen over de huisregels? <a href='/nl/contacto'>Neem contact met ons op</a> voor aankomst en we leggen alles uit.",
  },
};
const c = copy[lang] ?? copy.en;
---
<BaseLayout title={`${c.title} — Aromatik Apartments`} description={c.subtitle} lang={lang}>
  <section class="legal-hero">
    <h1>{c.title}</h1>
    <p>{c.subtitle}</p>
  </section>
  <section class="section">
    <div class="container legal-content">
      <div class="rules-grid">
        {c.rules.map((r: any) => (
          <div class="rule-item">
            <span class="rule-icon">{r.icon}</span>
            <div set:html={r.html} />
          </div>
        ))}
      </div>
      <div class="legal-note">
        <p set:html={c.note} />
      </div>
    </div>
  </section>
</BaseLayout>
