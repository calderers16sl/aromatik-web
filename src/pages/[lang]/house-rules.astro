      { icon: "🚭", html: "<strong>No smoking</strong> inside the apartments. Shared outdoor spaces may be used if available." },
      { icon: "🐾", html: "<strong>Pets:</strong> please check availability with us before booking. Some apartments accept pets on request." },
      { icon: "👥", html: "<strong>Maximum occupancy:</strong> the number of guests stated in the booking must not be exceeded under any circumstances." },
      { icon: "🎉", html: "<strong>Parties and events</strong> are not allowed in the apartments. The accommodation is for residential-tourist use only." },
      { icon: "♻️", html: "<strong>Recycling:</strong> please sort waste into the designated bins. We explain Girona's recycling system at check-in." },
      { icon: "🔑", html: "<strong>Keys:</strong> please return the keys at the end of your stay. Lost or damaged keys incur an additional charge." },
    ],
    note: "Any questions about the house rules? <a href='/en/contacto'>Contact us</a> before arrival and we will explain everything.",
  },
  fr: {
    title: "Règlement intérieur", subtitle: "Pour que tout le monde profite d'un séjour parfait",
    rules: [
