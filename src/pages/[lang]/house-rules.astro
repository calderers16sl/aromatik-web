      { icon: "🎉", html: "<strong>Fêtes et événements</strong> non autorisés dans les appartements. L'hébergement est à usage résidentiel-touristique." },
      { icon: "♻️", html: "<strong>Recyclage :</strong> triez vos déchets dans les poubelles indiquées. Nous vous expliquons le système de recyclage de Gérone à l'arrivée." },
      { icon: "🔑", html: "<strong>Clés :</strong> restituez les clés à la fin du séjour. La perte ou l'endommagement des clés entraîne des frais supplémentaires." },
    ],
    note: "Des questions sur le règlement ? <a href='/fr/contacto'>Contactez-nous</a> avant votre arrivée et nous vous expliquerons tout.",
  },
  ca: {
    title: "Normes de la casa", subtitle: "Perquè tothom gaudeixi d'una estada perfecta",
    rules: [
      { icon: "🕐", html: "<strong>Check-in:</strong> a partir de les 15:00 · <strong>Check-out:</strong> abans de les 11:00" },
      { icon: "🤫", html: "<strong>Silenci:</strong> respecta el descans dels veïns entre les 22:00 i les 9:00. Girona és una ciutat residencial." },
      { icon: "🚭", html: "<strong>No fumar</strong> a l'interior dels apartaments. Es poden utilitzar els espais exteriors comuns si n'hi ha." },
      { icon: "🐾", html: "<strong>Mascotes:</strong> consulta la disponibilitat amb nosaltres abans de reservar. Alguns apartaments les accepten sota petició." },
