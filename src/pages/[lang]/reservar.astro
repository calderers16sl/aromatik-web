---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/BookingWidget.astro';
import { getT, NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const t = getT(lang);
---
<BaseLayout title={`${t.bookTitle} — Aromatik Apartments`} description={t.metaDescription} lang={lang}>
  <section class="reservar-hero">
    <span class="eyebrow">{t.bookEyebrow}</span>
    <h1>{t.bookTitle}</h1>
    <p>{t.bookSubtitle}</p>
  </section>
  <section class="section">
    <div class="container">
        <div class="benefit-item"><span>✓</span> {t.bookBenefit2}</div>
        <div class="benefit-item"><span>✓</span> {t.bookBenefit3}</div>
        <div class="benefit-item"><span>✓</span> {t.bookBenefit4}</div>
      </div>
      <BookingWidget />
    </div>
  </section>
</BaseLayout>
<style is:global>
.reservar-hero { text-align: center; padding: 5rem 1.5rem 3rem; background: var(--cream); margin-top: 70px; }
.reservar-hero h1 { font-family: var(--serif); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 400; margin: 0.5rem 0 1rem; }
.reservar-hero p { color: var(--stone-500); max-width: 500px; margin: 0 auto; }
</style>
