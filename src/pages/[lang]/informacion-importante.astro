---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';
import { getInfoContent } from '../../i18n/infoPage';
export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const content = getInfoContent(lang);
const langRoot = `/${lang}`;
---
<BaseLayout
  title={content.metaTitle}
  description={content.metaDescription}
  lang={lang}
>
  <!-- HERO -->
  <div class="inner-hero">
    <span class="eyebrow">Aromatik Apartments · Girona</span>
    <h1>{content.pageTitle}</h1>
    <p class="hero-sub">{content.heroText}</p>
  </div>

  <!-- INTRO PERSONAL -->
  <section class="section section-intro">
    <div class="container-sm">
      <div class="intro-card">
        <div class="intro-avatar">A</div>
        <div class="intro-text">
          <p>{content.intro}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIONES -->
  <section class="section section-rules">
    <div class="container-sm">
      <div class="rules-grid">
        {content.sections.map((section) => (
          <div class="rule-block">
            <h2>{section.title}</h2>
            <p>{section.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GRACIAS -->
  <section class="section section-thanks">
    <div class="container-sm">
      <div class="thanks-card">
        <h2>{content.thanksTitle}</h2>
        <p>{content.thanksText}</p>
        <p class="signature">{content.signature}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-cta">
    <div class="container-sm">
      <div class="info-cta-box">
        <h2>{content.ctaTitle}</h2>
        <p>{content.ctaText}</p>
        <a href={`${langRoot}/contacto`} class="btn btn-green">{content.ctaBtn}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .inner-hero {
    background: var(--cream);
    text-align: center;
    padding: 7rem 2rem 4rem;
    border-bottom: 1px solid var(--stone-200);
  }
  .inner-hero .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--stone-400);
    margin-bottom: 1rem;
  }
  .inner-hero h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--black);
    margin: 0 0 1.25rem;
    line-height: 1.2;
  }
  .hero-sub {
    font-size: 1rem;
    color: var(--stone-600);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.8;
  }
  .container-sm { max-width: 760px; margin: 0 auto; padding: 0 1.5rem; }
  .section { padding: 3.5rem 0; }
  .section-intro { background: var(--white); border-bottom: 1px solid var(--stone-200); }
  .intro-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: var(--cream);
    border: 1px solid var(--stone-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }
  .intro-avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--white);
    font-family: var(--serif);
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .intro-text p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--stone-800);
    line-height: 1.8;
  }
  .section-rules { background: var(--white); }
  .rules-grid { display: grid; gap: 0; }
  .rule-block {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--stone-200);
  }
  .rule-block:last-child { border-bottom: none; }
  .rule-block h2 {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 0.6rem;
  }
  .rule-block p {
    margin: 0;
    font-size: 0.93rem;
    color: var(--stone-600);
    line-height: 1.8;
  }
  .section-thanks { background: var(--cream); border-top: 1px solid var(--stone-200); border-bottom: 1px solid var(--stone-200); }
  .thanks-card { text-align: center; padding: 1rem 0; }
  .thanks-card h2 {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 1rem;
  }
  .thanks-card p {
    font-size: 0.95rem;
    color: var(--stone-600);
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto 0.5rem;
  }
  .signature {
    font-family: var(--serif);
    font-size: 1rem !important;
    color: var(--gold) !important;
    margin-top: 1.5rem !important;
    font-style: italic;
  }
  .section-cta { background: var(--white); }
  .info-cta-box {
    text-align: center;
    padding: 2.5rem;
    border: 1px solid var(--stone-200);
    border-radius: var(--radius-lg);
    background: var(--cream);
  }
  .info-cta-box h2 {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 0.75rem;
  }
  .info-cta-box p {
    font-size: 0.93rem;
    color: var(--stone-600);
    margin: 0 0 1.5rem;
    line-height: 1.7;
  }
  @media (max-width: 640px) {
    .intro-card { flex-direction: column; gap: 1rem; padding: 1.5rem; }
    .info-cta-box { padding: 1.75rem 1.25rem; }
    .section { padding: 2.5rem 0; }
  }
</style>
