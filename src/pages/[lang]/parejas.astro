---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostCard from '../../components/HostCard.astro';
import ReviewsCarousel from '../../components/ReviewsCarousel.astro';
import { NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const langRoot = `/${lang}`;

const copy: Record<string, any> = {
  en: {
    metaTitle: "Romantic Apartments for Couples in Girona — Aromatik Apartments",
    metaDesc: "A romantic escape to the medieval heart of Girona. Boutique apartments with views over the Onyar river and private balcony. Intimate atmosphere, best price guaranteed.",
    eyebrow: "A romantic escape to Girona",
    h1: "A medieval city,\njust the two of you",
    subtitle: "Intimate apartments with views of the Onyar river in the heart of the Barri Vell. Because the best getaways start with the right place to stay.",
    perksEyebrow: "Designed for two",
    perksTitle: "The getaway you deserve",
    perks: [
      { icon: "🌊", title: "Views of the Onyar river", desc: "The colourful houses reflected in the water. That morning wake-up with the sound of the river that stays with you." },
      { icon: "🏛️", title: "In the heart of the old town", desc: "Medieval lanes, the Cathedral five minutes away, the Jewish Quarter to get lost in. Girona is a cinematic city. Literally." },
      { icon: "🍷", title: "Walking distance from the best restaurants", desc: "The Barri Vell has some of Girona's finest restaurants. Dinner out, walk back home. No taxi, no curfew." },
      { icon: "☕", title: "Breakfast at home", desc: "Coffee maker, toaster, everything ready. The first coffee of the day in your own apartment, unhurried." },
      { icon: "🔑", title: "Arrive whenever you like", desc: "Self check-in with a door code. If the train runs late or you want to linger over dinner, no problem." },
      { icon: "🐾", title: "With your pet", desc: "If there are three of you, you're all welcome. All our apartments accept pets at no extra charge." },
    ],
    aptsEyebrow: "Perfect for two",
    aptsTitle: "Our apartments for couples",
    aptsSub: "Intimate, well-located and with the atmosphere that makes a getaway special.",
    cityEyebrow: "The city",
    cityTitle: "Girona, the perfect setting",
    cityText1: "Girona is one of those cities that has something hard to explain but easy to feel. The Jewish quarter, the Gothic Cathedral, the bridges over the Onyar, the colourful houses that enchanted the world in Game of Thrones. Every corner has its own story and charm.",
    cityText2: "From the apartment you can reach everything on foot: the Mercat del Lleó, the terraces of Carrer de la Força, the bookshops of the Barri Vell. At night the streets empty out and the city becomes even more magical.",
    cityText3: "If you fancy leaving the city, the Costa Brava is 40 minutes by car. And if you stay, Girona has enough to fill entire days without repeating yourself.",
    ctaTitle: "When's your escape?",
    ctaSub: "Book directly and get the guaranteed best price. No commission, personal attention from Arnau.",
    ctaBtn: "Check availability",
    ctaBtn2: "Ask before booking",
    tag1: "Couples' favourite", tag2: "Calm and riverside", tag3: "Private balcony",
    tagline1: "Cosy and with views of the Onyar river. Natural light, tranquil atmosphere and everything the two of you need.",
    tagline2: "The most peaceful of all. River views, careful décor and the quiet that a couples' retreat deserves.",
    tagline3: "Balcony for breakfast with city views. Fresh, bright and perfect for switching off together.",
    people: "2 people", bedrooms: "1 bedroom", viewApt: "View apartment →",
  },
  fr: {
    metaTitle: "Appartements romantiques pour couples à Gérone — Aromatik Apartments",
    metaDesc: "Une escapade romantique au cœur médiéval de Gérone. Appartements boutique avec vue sur l'Onyar et balcon privé. Ambiance intime, meilleur prix garanti.",
    eyebrow: "Escapade romantique à Gérone",
    h1: "Une ville médiévale,\njuste vous deux",
    subtitle: "Appartements intimes avec vue sur l'Onyar au cœur du Barri Vell. Parce que les meilleures escapades commencent par le bon endroit où séjourner.",
    perksEyebrow: "Conçu pour deux",
    perksTitle: "L'escapade que vous méritez",
    perks: [
      { icon: "🌊", title: "Vue sur l'Onyar", desc: "Les maisons colorées se reflétant dans l'eau. Ce réveil avec le bruit de la rivière qui ne s'oublie pas facilement." },
      { icon: "🏛️", title: "En plein cœur historique", desc: "Ruelles médiévales, la Cathédrale à cinq minutes, le Quartier Juif pour se perdre. Gérone est une ville de cinéma. Littéralement." },
      { icon: "🍷", title: "À pied des meilleurs restaurants", desc: "Le Barri Vell concentre quelques-uns des meilleurs restaurants de Gérone. Dîner dehors, rentrer à pied. Pas de taxi, pas d'horloge." },
      { icon: "☕", title: "Petit-déjeuner à la maison", desc: "Cafetière, grille-pain, tout est prêt. Le premier café de la journée dans votre appartement, sans se presser." },
      { icon: "🔑", title: "Arrivez quand vous voulez", desc: "Self check-in avec code. Si le train est en retard ou si vous voulez prolonger le dîner, aucun problème." },
      { icon: "🐾", title: "Avec votre animal", desc: "Si vous êtes trois, vous êtes tous les bienvenus. Tous nos appartements acceptent les animaux sans supplément." },
    ],
    aptsEyebrow: "Parfaits pour deux",
    aptsTitle: "Nos appartements pour couples",
    aptsSub: "Intimes, bien situés et avec cette atmosphère qui rend une escapade spéciale.",
    cityEyebrow: "La ville",
    cityTitle: "Gérone, le cadre parfait",
    cityText1: "Gérone est l'une de ces villes qui a quelque chose de difficile à expliquer mais de facile à ressentir. Le quartier juif, la Cathédrale gothique, les ponts sur l'Onyar, les maisons colorées qui ont enchanté le monde dans Game of Thrones. Chaque coin a sa propre histoire et son charme.",
    cityText2: "Depuis l'appartement, vous pouvez tout rejoindre à pied : le Mercat del Lleó, les terrasses du Carrer de la Força, les librairies du Barri Vell. Le soir, les rues se vident et la ville devient encore plus magique.",
    cityText3: "Si vous avez envie de quitter la ville, la Costa Brava est à 40 minutes en voiture. Et si vous restez, Gérone a de quoi remplir des journées entières sans se répéter.",
    ctaTitle: "C'est quand votre escapade ?",
    ctaSub: "Réservez directement et obtenez le meilleur prix garanti. Sans commission, avec l'attention personnelle d'Arnau.",
    ctaBtn: "Vérifier les disponibilités",
    ctaBtn2: "Nous contacter avant de réserver",
    tag1: "Le favori des couples", tag2: "Calme et vue rivière", tag3: "Balcon privé",
    tagline1: "Cosy et avec vue sur l'Onyar. Lumière naturelle, ambiance tranquille et tout ce dont vous avez besoin à deux.",
    tagline2: "Le plus serein de tous. Vue sur l'Onyar, décoration soignée et le calme que mérite une escapade en couple.",
    tagline3: "Balcon pour petit-déjeuner avec vue sur la ville. Frais, lumineux et parfait pour décrocher ensemble.",
    people: "2 personnes", bedrooms: "1 chambre", viewApt: "Voir l'appartement →",
  },
  ca: {
    metaTitle: "Apartaments romàntics per a parelles a Girona — Aromatik Apartments",
    metaDesc: "Escapada romàntica al cor medieval de Girona. Apartaments boutique amb vistes a l'Onyar i balcó privat. Ambient íntim, millor preu garantit.",
    eyebrow: "Escapada romàntica a Girona",
    h1: "Una ciutat medieval,\nnomés vosaltres dos",
    subtitle: "Apartaments íntims amb vistes a l'Onyar al cor del Barri Vell. Perquè les millors escapades comencen pel lloc on us quedeu.",
    perksEyebrow: "Dissenyat per a dos",
    perksTitle: "L'escapada que us mereixeu",
    perks: [
      { icon: "🌊", title: "Vistes al riu Onyar", desc: "Les cases de colors reflectides en l'aigua. Aquell despertar amb el so del riu que no s'oblida fàcilment." },
      { icon: "🏛️", title: "Al cor del casc antic", desc: "Carrerons medievals, la Catedral a cinc minuts, el Call Jueu per perdre-s'hi. Girona és una ciutat de pel·lícula. Literalment." },
      { icon: "🍷", title: "A peu dels millors restaurants", desc: "El Barri Vell concentra alguns dels millors restaurants de Girona. Sopeu fora, torneu caminant. Sense taxi, sense rellotge." },
      { icon: "☕", title: "Esmorzar a casa", desc: "Cafetera, torradora, tot llest. El primer cafè del dia al vostre propi apartament, sense pressa." },
      { icon: "🔑", title: "Arribeu quan vulgueu", desc: "Self check-in amb codi. Si el tren arriba tard o teniu ganes d'allargar el sopar, cap problema." },
      { icon: "🐾", title: "Amb la vostra mascota", desc: "Si sou tres, tots sou benvinguts. Tots els nostres apartaments accepten mascotes sense recàrrec." },
    ],
    aptsEyebrow: "Perfectes per a dos",
    aptsTitle: "Els nostres apartaments per a parelles",
    aptsSub: "Íntims, ben ubicats i amb aquella atmosfera que fa especial una escapada.",
    cityEyebrow: "La ciutat",
    cityTitle: "Girona, l'escenari perfecte",
    cityText1: "Girona és una d'aquelles ciutats que tenen alguna cosa difícil d'explicar però fàcil de sentir. El barri jueu, la Catedral gòtica, els ponts sobre l'Onyar, les cases de colors que van enamorar el món a Joc de Trons. Cada racó té la seva pròpia història i el seu encant.",
    cityText2: "Des de l'apartament podeu arribar a tot a peu: el Mercat del Lleó, les terrasses del carrer de la Força, les llibreries del Barri Vell. A la nit, els carrers es queden quasi buits i la ciutat es torna encara més màgica.",
    cityText3: "Si voleu sortir de la ciutat, la Costa Brava és a 40 minuts en cotxe. I si us quedeu, Girona té prou per omplir dies sencers sense repetir.",
    ctaTitle: "Quan és la vostra escapada?",
    ctaSub: "Reserveu directament i obteniu el millor preu garantit. Sense comissions, amb atenció personal d'Arnau.",
    ctaBtn: "Comprovar disponibilitat",
    ctaBtn2: "Preguntar abans de reservar",
    tag1: "El favorit de parelles", tag2: "Tranquil·litat i riu", tag3: "Balcó privat",
    tagline1: "Acollidor i amb vistes a l'Onyar. Llum natural, ambient tranquil i tot el que necessiteu els dos.",
    tagline2: "El més serè de tots. Vistes a l'Onyar, decoració curada i el silenci que mereix una escapada en parella.",
    tagline3: "Balcó per esmorzar amb vistes a la ciutat. Fresc, lluminós i perfecte per desconnectar junts.",
    people: "2 persones", bedrooms: "1 habitació", viewApt: "Veure apartament →",
  },
};

const c = copy[lang] ?? copy['en'];

const featuredApts = [
  { slug: "romani",  tag: c.tag1, desc: c.tagline1, photo: "/images/apartamentos/romani/foto-1.jpg",  name: "Romaní" },
  { slug: "lavanda", tag: c.tag2, desc: c.tagline2, photo: "/images/apartamentos/lavanda/foto-1.jpg", name: "Lavanda" },
  { slug: "limon",   tag: c.tag3, desc: c.tagline3, photo: "/images/apartamentos/limon/foto-1.jpg",   name: "Llimona" },
];
---
<BaseLayout title={c.metaTitle} description={c.metaDesc} lang={lang}>

  <section class="audience-hero audience-hero--parejas">
    <div class="audience-hero-overlay"></div>
    <div class="audience-hero-inner">
      <span class="audience-eyebrow">{c.eyebrow}</span>
      <h1 set:html={c.h1.replace('\n','<br/>')} />
      <p>{c.subtitle}</p>
      <div class="audience-hero-actions">
        <a href="#apartamentos-parejas" class="btn btn-white">{lang==='fr'?'Voir les appartements':lang==='ca'?'Veure apartaments':'View apartments'}</a>
        <a href={`${langRoot}/reservar#motor`} class="btn btn-outline-white">{lang==='fr'?'Réserver':lang==='ca'?'Reservar ara':'Book now'}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{c.perksEyebrow}</span>
        <h2 style="margin-top:0.75rem">{c.perksTitle}</h2>
      </div>
      <div class="audience-perks">
        {c.perks.map((p: any) => (
          <div class="audience-perk">
            <div class="audience-perk-icon">{p.icon}</div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="apartamentos-parejas" class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{c.aptsEyebrow}</span>
        <h2 style="margin-top:0.75rem">{c.aptsTitle}</h2>
        <p>{c.aptsSub}</p>
      </div>
      <div class="audience-apts">
        {featuredApts.map(apt => (
          <a href={`${langRoot}/apartamentos/${apt.slug}`} class="audience-apt-card">
            <div class="audience-apt-img" style={`background-image:url('${apt.photo}')`}>
              <span class="audience-apt-tag">{apt.tag}</span>
            </div>
            <div class="audience-apt-body">
              <h3>{apt.name}</h3>
              <p class="audience-apt-meta">{c.people} · {c.bedrooms}</p>
              <p class="audience-apt-desc">{apt.desc}</p>
              <span class="audience-apt-link">{c.viewApt}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:760px;">
      <span class="eyebrow">{c.cityEyebrow}</span>
      <h2 style="font-family:var(--serif);font-size:1.8rem;font-weight:400;margin:0.75rem 0 1.5rem;">{c.cityTitle}</h2>
      <div class="prose">
        <p>{c.cityText1}</p>
        <p>{c.cityText2}</p>
        <p>{c.cityText3}</p>
      </div>
    </div>
  </section>

  <HostCard lang={lang} />
  <ReviewsCarousel lang={lang} />

  <section class="section bg-cream">
    <div class="container" style="text-align:center;">
      <h2 style="font-family:var(--serif);font-size:2rem;font-weight:400;margin-bottom:0.75rem;">{c.ctaTitle}</h2>
      <p style="color:var(--stone-600);margin-bottom:2rem;max-width:500px;margin-left:auto;margin-right:auto;">{c.ctaSub}</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href={`${langRoot}/reservar#motor`} class="btn btn-dark">{c.ctaBtn}</a>
        <a href={`${langRoot}/contacto`} class="btn btn-border">{c.ctaBtn2}</a>
      </div>
    </div>
  </section>

</BaseLayout>
<style>
.audience-hero{position:relative;min-height:80vh;display:flex;align-items:center;justify-content:center;text-align:center;color:#fff;overflow:hidden;padding-top:70px;}
.audience-hero--parejas{background-image:url('/images/apartamentos/romani/foto-1.jpg');background-size:cover;background-position:center;}
.audience-hero-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.48);}
.audience-hero-inner{position:relative;z-index:1;max-width:780px;padding:4rem 2rem;background:rgba(0,0,0,0.28);border-radius:20px;backdrop-filter:blur(2px);margin:0 1.5rem;}
.audience-eyebrow{display:block;font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.65);margin-bottom:1rem;}
.audience-hero-inner h1{font-family:var(--serif);font-size:clamp(2rem,5vw,3.6rem);font-weight:400;line-height:1.2;margin-bottom:1.25rem;}
.audience-hero-inner p{font-size:1.05rem;color:rgba(255,255,255,0.85);max-width:560px;margin:0 auto 2rem;line-height:1.7;}
.audience-hero-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;}
.audience-perks{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:1rem;}
.audience-perk{padding:2rem 1.5rem;border:1px solid var(--stone-200);border-radius:16px;background:#fff;}
.audience-perk-icon{font-size:2rem;margin-bottom:0.75rem;}
.audience-perk h3{font-size:1rem;font-weight:600;margin-bottom:0.5rem;}
.audience-perk p{font-size:0.875rem;color:var(--stone-600);line-height:1.7;}
.audience-apts{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:1rem;}
.audience-apt-card{background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--stone-200);text-decoration:none;color:inherit;transition:box-shadow 0.2s,transform 0.2s;display:flex;flex-direction:column;}
.audience-apt-card:hover{box-shadow:0 8px 32px rgba(0,0,0,0.12);transform:translateY(-2px);}
.audience-apt-img{height:200px;background-size:cover;background-position:center;position:relative;}
.audience-apt-tag{position:absolute;top:0.75rem;left:0.75rem;background:rgba(0,0,0,0.6);color:#fff;font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.3rem 0.7rem;border-radius:99px;backdrop-filter:blur(4px);}
.audience-apt-body{padding:1.25rem 1.5rem 1.5rem;flex:1;display:flex;flex-direction:column;}
.audience-apt-body h3{font-size:1.1rem;font-weight:600;margin-bottom:0.25rem;}
.audience-apt-meta{font-size:0.8rem;color:var(--stone-500);margin-bottom:0.75rem;}
.audience-apt-desc{font-size:0.875rem;color:var(--stone-600);line-height:1.65;flex:1;}
.audience-apt-link{display:inline-block;margin-top:1rem;font-size:0.85rem;font-weight:600;color:var(--gold);}
@media(max-width:900px){.audience-perks,.audience-apts{grid-template-columns:repeat(2,1fr);}}
@media(max-width:580px){.audience-perks,.audience-apts{grid-template-columns:1fr;}.audience-hero-inner{padding:2.5rem 1.25rem;}}
</style>
