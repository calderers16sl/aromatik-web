---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostCard from '../../components/HostCard.astro';
import ReviewsCarousel from '../../components/ReviewsCarousel.astro';
import { NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const langRoot = `/${lang}`;

const copy: Record<string, any> = {
  en: {
    metaTitle: "Family Apartments in Girona — Aromatik Apartments",
    metaDesc: "Spacious 2 and 3 bedroom apartments in the heart of Girona's old town. Pet friendly, cots and high chairs on request, wide elevator for prams. Best price guaranteed.",
    eyebrow: "Girona as a family",
    h1: "The Barri Vell of Girona,\nwithout compromising on anything",
    subtitle: "2 and 3 bedroom apartments in the heart of medieval Girona. Space for everyone, fully equipped kitchen and everything a family needs to feel at home.",
    perksTitle: "Why families choose Aromatik",
    perksEyebrow: "Designed for you",
    perks: [
      { icon: "🛏️", title: "2 and 3 bedrooms", desc: "Kids sleep in their own room. So do you. No fold-out beds or emergency sofas." },
      { icon: "🍳", title: "Full kitchen", desc: "Fridge, microwave, coffee maker, toaster and everything you need for a relaxed breakfast at your own pace." },
      { icon: "🛗", title: "Wide elevator", desc: "All our buildings have a lift. Prams, big suitcases and even bikes fit comfortably. No stairs, no juggling." },
      { icon: "🐾", title: "Pet friendly", desc: "The furry members of the family are welcome too. All our apartments accept pets." },
      { icon: "🪑", title: "Cot and high chair", desc: "Available on request at no extra cost. Just let us know when booking and we'll have it ready for your arrival." },
      { icon: "📍", title: "In the historic centre", desc: "Five minutes from the Cathedral, the Arab Baths and the river Onyar. Girona is a living history park for the whole family." },
    ],
    aptsEyebrow: "Most recommended",
    aptsTitle: "Apartments for families",
    aptsSub: "We select the ones that best suit family stays.",
    cityEyebrow: "The city",
    cityTitle: "Girona: the city the whole family will love",
    cityText1: "Girona is one of the best-preserved medieval cities in Europe, and exploring it with children is an experience they won't forget. The Roman walls, the little bridges over the Onyar, the Cathedral and the winding lanes of the Jewish Quarter turn every walk into a small adventure.",
    cityText2: "From our apartments you can reach everything in less than 10 minutes on foot: parks, the market, ice cream shops and the riverside promenade. No car, no traffic.",
    cityText3: "In summer, the municipal pools are 15 minutes away on foot. The Costa Brava is 40 minutes by car. And the Pyrenees are less than an hour away.",
    ctaTitle: "Ready for your family getaway?",
    ctaSub: "Book directly and we guarantee the best available price. No commission, personal attention included.",
    ctaBtn: "Check availability",
    ctaBtn2: "Ask before booking",
    tag1: "The most spacious", tag2: "Design & space", tag3: "River views",
    tagline1: "Penthouse with 3 bedrooms, 2 bathrooms and washing machine. The favourite of families who want comfort without compromise.",
    tagline2: "3 bedrooms, dishwasher, gas hob, bathtub and private balcony. Everything a demanding family needs.",
    tagline3: "Two bedrooms with river views and a balcony. Perfect for families of 3 or 4 who want the heart of Girona.",
    guests: "Up to", people: "people", bedrooms: "bedrooms",
    viewApt: "View apartment →",
  },
  fr: {
    metaTitle: "Appartements pour familles à Gérone — Aromatik Apartments",
    metaDesc: "Appartements spacieux de 2 et 3 chambres dans le centre historique de Gérone. Animaux acceptés, lits bébé et chaises hautes disponibles. Meilleur prix garanti.",
    eyebrow: "Gérone en famille",
    h1: "Le Barri Vell de Gérone,\nsans rien sacrifier",
    subtitle: "Appartements de 2 et 3 chambres au cœur de la vieille ville médiévale de Gérone. De l'espace pour tout le monde, une cuisine équipée et tout ce dont une famille a besoin.",
    perksTitle: "Pourquoi les familles choisissent Aromatik",
    perksEyebrow: "Pensé pour vous",
    perks: [
      { icon: "🛏️", title: "2 et 3 chambres", desc: "Les enfants dorment dans leur chambre. Vous aussi. Pas de lits pliants ni de canapés de fortune." },
      { icon: "🍳", title: "Cuisine complète", desc: "Réfrigérateur, micro-ondes, cafetière, grille-pain et tout le nécessaire pour un petit-déjeuner tranquille." },
      { icon: "🛗", title: "Ascenseur spacieux", desc: "Tous nos immeubles ont un ascenseur. Poussettes, grandes valises et vélos y entrent confortablement." },
      { icon: "🐾", title: "Animaux bienvenus", desc: "Les membres poilus de la famille sont les bienvenus. Tous nos appartements acceptent les animaux." },
      { icon: "🪑", title: "Lit bébé et chaise haute", desc: "Disponibles sur demande sans supplément. Signalez-le simplement lors de votre réservation." },
      { icon: "📍", title: "En plein centre historique", desc: "À cinq minutes de la Cathédrale, des Bains Arabes et de l'Onyar. Gérone est un parc historique vivant." },
    ],
    aptsEyebrow: "Les plus recommandés",
    aptsTitle: "Appartements pour familles",
    aptsSub: "Nous sélectionnons ceux qui conviennent le mieux aux séjours en famille.",
    cityEyebrow: "La ville",
    cityTitle: "Gérone : la ville qui enchante toute la famille",
    cityText1: "Gérone est l'une des villes médiévales les mieux conservées d'Europe, et la parcourir avec des enfants est une expérience inoubliable. Les remparts romains, les petits ponts sur l'Onyar, la Cathédrale et le labyrinthe de ruelles du Barri Vell font de chaque promenade une petite aventure.",
    cityText2: "Depuis nos appartements, tout est accessible en moins de 10 minutes à pied : parcs, marché, glaciers et promenade au bord de la rivière. Pas de voiture, pas d'embouteillages.",
    cityText3: "En été, les piscines municipales sont à 15 minutes à pied. La Costa Brava est à 40 minutes en voiture. Et les Pyrénées sont à moins d'une heure.",
    ctaTitle: "Prêts pour votre escapade en famille ?",
    ctaSub: "Réservez directement et nous vous garantissons le meilleur prix disponible. Sans commission, avec une attention personnalisée.",
    ctaBtn: "Vérifier les disponibilités",
    ctaBtn2: "Nous contacter avant de réserver",
    tag1: "Le plus spacieux", tag2: "Design et espace", tag3: "Vue sur la rivière",
    tagline1: "Attique avec 3 chambres, 2 salles de bains et lave-linge. Le favori des familles qui veulent le confort sans compromis.",
    tagline2: "3 chambres, lave-vaisselle, cuisinière à gaz, baignoire et balcon privé. Tout ce qu'une famille exigeante peut vouloir.",
    tagline3: "Deux chambres avec vue sur la rivière et balcon. Parfait pour les familles de 3 ou 4 personnes.",
    guests: "Jusqu'à", people: "personnes", bedrooms: "chambres",
    viewApt: "Voir l'appartement →",
  },
  ca: {
    metaTitle: "Apartaments per a famílies a Girona — Aromatik Apartments",
    metaDesc: "Apartaments espaiosos de 2 i 3 habitacions al cor del casc antic de Girona. Animals acceptats, bressols i trones disponibles. Millor preu garantit.",
    eyebrow: "Girona en família",
    h1: "El Barri Vell de Girona,\nsense renunciar a res",
    subtitle: "Apartaments de 2 i 3 habitacions al cor de la Girona medieval. Espai per a tothom, cuina equipada i tot el que una família necessita per sentir-se com a casa.",
    perksTitle: "Per què les famílies trien Aromatik",
    perksEyebrow: "Pensat per a vosaltres",
    perks: [
      { icon: "🛏️", title: "2 i 3 habitacions", desc: "Els nens dormen al seu quart. Vosaltres també descanseu. Res de llits plegables ni sofàs d'emergència." },
      { icon: "🍳", title: "Cuina completa", desc: "Nevera, microones, cafetera, torradora i tot el necessari per esmorzar amb calma sense dependre d'horaris." },
      { icon: "🛗", title: "Ascensor ampli", desc: "Tots els nostres edificis tenen ascensor. Hi caben cotxets, maletes grans i fins i tot bicicletes." },
      { icon: "🐾", title: "Pet friendly", desc: "Els membres peluts de la família també hi són benvinguts. Tots els nostres apartaments accepten mascotes." },
      { icon: "🪑", title: "Bressol i trona", desc: "Disponibles sota petició prèvia sense cost addicional. Avisa'ns en fer la reserva i ho tindrem llest." },
      { icon: "📍", title: "Al centre històric", desc: "A cinc minuts de la Catedral, els Banys Àrabs i el riu Onyar. Girona és un parc històric per explorar en família." },
    ],
    aptsEyebrow: "Els més recomanats",
    aptsTitle: "Apartaments per a famílies",
    aptsSub: "Seleccionem els que millor s'adapten a les estades en família.",
    cityEyebrow: "La ciutat",
    cityTitle: "Girona: la ciutat que enamora tota la família",
    cityText1: "Girona és una de les ciutats medievals millor conservades d'Europa, i recórrer-la amb nens és una experiència que no oblidaran. La muralla romana, els ponts sobre l'Onyar, la Catedral i el laberint de carrerons del Call Jueu converteixen cada passeig en una petita aventura.",
    cityText2: "Des dels nostres apartaments arribareu a tot en menys de 10 minuts a peu: parcs, mercat, gelaterïes i el passeig fluvial. Sense cotxe, sense embussos.",
    cityText3: "A l'estiu, les piscines municipals són a 15 minuts a peu. La Costa Brava queda a 40 minuts en cotxe. I el Pirineu és a menys d'una hora.",
    ctaTitle: "Llests per a la vostra escapada familiar?",
    ctaSub: "Reserveu directament i us garantim el millor preu disponible. Sense comissions, amb atenció personal.",
    ctaBtn: "Comprovar disponibilitat",
    ctaBtn2: "Preguntar abans de reservar",
    tag1: "El més espaiós", tag2: "Disseny i espai", tag3: "Vistes al riu",
    tagline1: "Àtic amb 3 habitacions, 2 banys i rentadora. El favorit de les famílies que volen comoditat sense compromís.",
    tagline2: "3 habitacions, rentavaixelles, cuina de gas, banyera i balcó privat. Tot el que una família exigent necessita.",
    tagline3: "Dues habitacions amb vistes al riu i balcó. Perfecte per a famílies de 3 o 4 persones.",
    guests: "Fins a", people: "persones", bedrooms: "habitacions",
    viewApt: "Veure apartament →",
  },
};

// Fallback to English for other locales
const c = copy[lang] ?? copy['en'];

const featuredApts = [
  { slug: "bergamota", guests: 6, bedrooms: 3, tag: c.tag1, desc: c.tagline1, photo: "/images/apartamentos/bergamota/foto-1.jpg", name: "Bergamota" },
  { slug: "arbol-de-te", guests: 6, bedrooms: 3, tag: c.tag2, desc: c.tagline2, photo: "/images/apartamentos/arbol-de-te/foto-1.jpg", name: "Arbre de te" },
  { slug: "ylang-ylang", guests: 4, bedrooms: 2, tag: c.tag3, desc: c.tagline3, photo: "/images/apartamentos/ylang-ylang/foto-1.jpg", name: "Ylang-Ylang" },
];
---
<BaseLayout title={c.metaTitle} description={c.metaDesc} lang={lang}>

  <section class="audience-hero audience-hero--familias">
    <div class="audience-hero-overlay"></div>
    <div class="audience-hero-inner">
      <span class="audience-eyebrow">{c.eyebrow}</span>
      <h1 set:html={c.h1.replace('\n','<br/>')} />
      <p>{c.subtitle}</p>
      <div class="audience-hero-actions">
        <a href="#apartamentos-familias" class="btn btn-white">{lang === 'fr' ? 'Voir les appartements' : lang === 'ca' ? 'Veure apartaments' : 'View apartments'}</a>
        <a href={`${langRoot}/reservar#motor`} class="btn btn-outline-white">{lang === 'fr' ? 'Réserver maintenant' : lang === 'ca' ? 'Reservar ara' : 'Book now'}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{c.perksEyebrow}</span>
        <h2 style="margin-top:0.75rem">{c.perksTitle}</h2>
      </div>
      <div class="audience-perks">
        {c.perks.map((p: any) => (
          <div class="audience-perk">
            <div class="audience-perk-icon">{p.icon}</div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="apartamentos-familias" class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{c.aptsEyebrow}</span>
        <h2 style="margin-top:0.75rem">{c.aptsTitle}</h2>
        <p>{c.aptsSub}</p>
      </div>
      <div class="audience-apts">
        {featuredApts.map(apt => (
          <a href={`${langRoot}/apartamentos/${apt.slug}`} class="audience-apt-card">
            <div class="audience-apt-img" style={`background-image:url('${apt.photo}')`}>
              <span class="audience-apt-tag">{apt.tag}</span>
            </div>
            <div class="audience-apt-body">
              <h3>{apt.name}</h3>
              <p class="audience-apt-meta">{c.guests} {apt.guests} {c.people} · {apt.bedrooms} {c.bedrooms}</p>
              <p class="audience-apt-desc">{apt.desc}</p>
              <span class="audience-apt-link">{c.viewApt}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:760px;">
      <span class="eyebrow">{c.cityEyebrow}</span>
      <h2 style="font-family:var(--serif); font-size:1.8rem; font-weight:400; margin:0.75rem 0 1.5rem;">{c.cityTitle}</h2>
      <div class="prose">
        <p>{c.cityText1}</p>
        <p>{c.cityText2}</p>
        <p>{c.cityText3}</p>
      </div>
    </div>
  </section>

  <HostCard />
  <ReviewsCarousel />

  <section class="section bg-cream">
    <div class="container" style="text-align:center;">
      <h2 style="font-family:var(--serif); font-size:2rem; font-weight:400; margin-bottom:0.75rem;">{c.ctaTitle}</h2>
      <p style="color:var(--stone-600); margin-bottom:2rem; max-width:500px; margin-left:auto; margin-right:auto;">{c.ctaSub}</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href={`${langRoot}/reservar#motor`} class="btn btn-dark">{c.ctaBtn}</a>
        <a href={`${langRoot}/contacto`} class="btn btn-border">{c.ctaBtn2}</a>
      </div>
    </div>
  </section>

</BaseLayout>
<style>
.audience-hero { position:relative; min-height:80vh; display:flex; align-items:center; justify-content:center; text-align:center; color:#fff; overflow:hidden; padding-top:70px; }
.audience-hero--familias { background-image:url('/images/apartamentos/bergamota/foto-2.jpg'); background-size:cover; background-position:center; }
.audience-hero-overlay { position:absolute; inset:0; background:rgba(0,0,0,0.48); }
.audience-hero-inner { position:relative; z-index:1; max-width:780px; padding:4rem 2rem; background:rgba(0,0,0,0.28); border-radius:20px; backdrop-filter:blur(2px); margin:0 1.5rem; }
.audience-eyebrow { display:block; font-size:0.7rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.65); margin-bottom:1rem; }
.audience-hero-inner h1 { font-family:var(--serif); font-size:clamp(2rem,5vw,3.6rem); font-weight:400; line-height:1.2; margin-bottom:1.25rem; }
.audience-hero-inner p { font-size:1.05rem; color:rgba(255,255,255,0.85); max-width:560px; margin:0 auto 2rem; line-height:1.7; }
.audience-hero-actions { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
.audience-perks { display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; margin-top:1rem; }
.audience-perk { padding:2rem 1.5rem; border:1px solid var(--stone-200); border-radius:16px; background:#fff; }
.audience-perk-icon { font-size:2rem; margin-bottom:0.75rem; }
.audience-perk h3 { font-size:1rem; font-weight:600; margin-bottom:0.5rem; }
.audience-perk p { font-size:0.875rem; color:var(--stone-600); line-height:1.7; }
.audience-apts { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:1rem; }
.audience-apt-card { background:#fff; border-radius:16px; overflow:hidden; border:1px solid var(--stone-200); text-decoration:none; color:inherit; transition:box-shadow 0.2s,transform 0.2s; display:flex; flex-direction:column; }
.audience-apt-card:hover { box-shadow:0 8px 32px rgba(0,0,0,0.12); transform:translateY(-2px); }
.audience-apt-img { height:200px; background-size:cover; background-position:center; position:relative; }
.audience-apt-tag { position:absolute; top:0.75rem; left:0.75rem; background:rgba(0,0,0,0.6); color:#fff; font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.3rem 0.7rem; border-radius:99px; backdrop-filter:blur(4px); }
.audience-apt-body { padding:1.25rem 1.5rem 1.5rem; flex:1; display:flex; flex-direction:column; }
.audience-apt-body h3 { font-size:1.1rem; font-weight:600; margin-bottom:0.25rem; }
.audience-apt-meta { font-size:0.8rem; color:var(--stone-500); margin-bottom:0.75rem; }
.audience-apt-desc { font-size:0.875rem; color:var(--stone-600); line-height:1.65; flex:1; }
.audience-apt-link { display:inline-block; margin-top:1rem; font-size:0.85rem; font-weight:600; color:var(--gold); }
@media (max-width:900px) { .audience-perks,.audience-apts { grid-template-columns:repeat(2,1fr); } }
@media (max-width:580px) { .audience-perks,.audience-apts { grid-template-columns:1fr; } .audience-hero-inner { padding:2.5rem 1.25rem; } }
</style>
