---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getT, NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';
import ReviewsCarousel from '../../components/ReviewsCarousel.astro';
import HostCard from '../../components/HostCard.astro';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getT(lang);
const langRoot = `/${lang}`;

const CARD_PHOTOS = 5;

const apartments = [
  { name: "Ylang-Ylang", nameCa: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, photos: 21, color: "#C8B89A" },
  { name: "Romaní", nameCa: "Romaní",      slug: "romani",      guests: 2, bedrooms: 1, photos: 20, color: "#8EAB85" },
  { name: "Ciprés", nameCa: "Xiprer",      slug: "cipres",      guests: 2, bedrooms: 1, photos: 12, color: "#6B9B7E" },
  { name: "Lavanda", nameCa: "Lavanda",     slug: "lavanda",     guests: 2, bedrooms: 1, photos: 19, color: "#A899BB" },
  { name: "Limón", nameCa: "Llimona",       slug: "limon",       guests: 2, bedrooms: 1, photos: 21, color: "#C4BC7E" },
  { name: "Bergamota", nameCa: "Bergamota",   slug: "bergamota",   guests: 6, bedrooms: 3, photos: 21, color: "#C4A06E" },
  { name: "Árbol de té", nameCa: "Arbre de te", slug: "arbol-de-te", guests: 6, bedrooms: 3, photos: 23, color: "#7AAF9E" },
  { name: "Geranio", nameCa: "Gerani",     slug: "geranio",     guests: 2, bedrooms: 1, photos: 20, color: "#C49090" },
];
---
<BaseLayout title={t.metaTitle} description={t.metaDescription} lang={lang}>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <span class="hero-eyebrow">{t.heroEyebrow}</span>
      <h1 set:html={t.heroTitle.replace('\n','<br>')} />
      <div class="hero-actions">
        <a href="#apartamentos" class="btn btn-white" id="heroCta1Btn">{t.heroCta1}</a>
        <a href="#anfitrion" class="btn btn-outline-white" id="heroScrollBtn">{t.heroCta2}</a>
      </div>
      <div class="hero-badges">
        <span class="hero-badge">🚲 Cyclist friendly</span>
        <span class="hero-badge">🐾 Pet friendly</span>
      </div>
    </div>
  </section>

  <section id="apartamentos" class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{t.aptsEyebrow}</span>
        <h2 style="margin-top:0.75rem">{t.aptsTitle}</h2>
        <p>{t.aptsSubtitle}</p>
      </div>
      <div class="apts-grid">
        {apartments.map((apt) => {
          const count = Math.min(CARD_PHOTOS, apt.photos);
          const photoNums = Array.from({ length: count }, (_, i) => i + 1);
          return (
            <a href={`/${lang}/apartamentos/${apt.slug}`} class="apt-card">
              <div class="apt-card-img" style={`background-color:${apt.color}`}>
                {photoNums.map((n, i) => (
                  <img
                    src={`/images/apartamentos/${apt.slug}/foto-${n}.jpg`}
                    alt={`${apt.name} - foto ${n}`}
                    class={i > 0 ? 'c-hidden' : ''}
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                ))}
                {count > 1 && (
                  <>
                    <button class="apt-card-prev" aria-label="Anterior">&#8249;</button>
                    <button class="apt-card-next" aria-label="Siguiente">&#8250;</button>
                    <div class="apt-card-dots">
                      {photoNums.map((_, i) => (
                        <span class={`apt-card-dot${i === 0 ? ' c-active' : ''}`}></span>
                      ))}
                    </div>
                  </>
                )}
              </div>
              <div class="apt-card-body">
                <h3>{apt.nameCa}</h3>
                <p class="apt-meta">{t.aptsGuests(apt.guests)} · {t.aptsBedroom(apt.bedrooms)}</p>
                <span class="apt-link">{t.aptsViewBtn}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <HostCard />
  <ReviewsCarousel />

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{t.faqEyebrow}</span>
        <h2 style="margin-top:0.75rem">{t.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {t.faqItems.map(item => (
          <div class="faq-item">
            <p class="faq-q">{item.q}</p>
            <p class="faq-a">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section seo-barri-vell">
    <div class="container">
      <div class="seo-grid">
        <div class="seo-text">
          <span class="eyebrow">{t.seoBarriEyebrow}</span>
          <h2>{t.seoBarriTitle}</h2>
          <p>{t.seoBarriText}</p>
        </div>
        <div class="seo-features">
          <div class="seo-feature-item"><span class="seo-icon">⛪</span><div><strong>{t.seoBarriFeat1Title}</strong><span>{t.seoBarriFeat1Sub}</span></div></div>
          <div class="seo-feature-item"><span class="seo-icon">🕍</span><div><strong>{t.seoBarriFeat2Title}</strong><span>{t.seoBarriFeat2Sub}</span></div></div>
          <div class="seo-feature-item"><span class="seo-icon">🌉</span><div><strong>{t.seoBarriFeat3Title}</strong><span>{t.seoBarriFeat3Sub}</span></div></div>
          <div class="seo-feature-item"><span class="seo-icon">🚉</span><div><strong>{t.seoBarriFeat4Title}</strong><span>{t.seoBarriFeat4Sub}</span></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section seo-cycling">
    <div class="container">
      <div class="seo-grid reverse">
        <div class="seo-features">
          <div class="seo-feature-item"><span class="seo-icon">🚲</span><div><strong>{t.seoCyclingFeat1Title}</strong><span>{t.seoCyclingFeat1Sub}</span></div></div>
          <div class="seo-feature-item"><span class="seo-icon">🏔️</span><div><strong>{t.seoCyclingFeat2Title}</strong><span>{t.seoCyclingFeat2Sub}</span></div></div>
          <div class="seo-feature-item"><span class="seo-icon">🛗</span><div><strong>{t.seoCyclingFeat3Title}</strong><span>{t.seoCyclingFeat3Sub}</span></div></div>
          <div class="seo-feature-item"><span class="seo-icon">👕</span><div><strong>{t.seoCyclingFeat4Title}</strong><span>{t.seoCyclingFeat4Sub}</span></div></div>
        </div>
        <div class="seo-text">
          <span class="eyebrow">{t.seoCyclingEyebrow}</span>
          <h2>{t.seoCyclingTitle}</h2>
          <p>{t.seoCyclingText}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-cream info-banner-section">
    <div class="container">
      <div class="info-banner">
        <div class="info-banner-text">
          <span class="eyebrow">ℹ</span>
          <h2>{t.infoIndexTitle}</h2>
          <p>{t.infoIndexText}</p>
        </div>
        <a href={`${langRoot}/informacion-importante`} class="btn btn-outline-dark">{t.infoIndexBtn} →</a>
      </div>
    </div>
  </section>

  <section class="section faq-cta-section">
    <div class="container" style="text-align:center;">
      <h3 style="font-family:var(--serif); font-size:1.6rem; font-weight:400; margin-bottom:0.75rem;">{t.faqCtaTitle}</h3>
      <p style="color:var(--stone-600); font-size:0.9rem; margin-bottom:1.5rem;">{t.faqCtaDesc}</p>
      <a href={`/${lang}/contacto`} class="btn btn-dark">{t.faqCtaBtn}</a>
    </div>
  </section>

<script is:inline>
  // "Ver apartamentos" → scroll rápido directo a las cartas
  document.getElementById('heroCta1Btn')?.addEventListener('click', function(e) {
    e.preventDefault();
    var target = document.querySelector('.apts-grid');
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // "Conoce Aromatik" → scroll rápido hasta host section
  document.getElementById('heroScrollBtn')?.addEventListener('click', function(e) {
    e.preventDefault();
    var target = document.getElementById('anfitrion');
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.querySelectorAll('.apt-card').forEach(function(card) {
    var imgs = Array.from(card.querySelectorAll('.apt-card-img img'));
    var dots = Array.from(card.querySelectorAll('.apt-card-dot'));
    var prev = card.querySelector('.apt-card-prev');
    var next = card.querySelector('.apt-card-next');
    if (imgs.length <= 1) return;
    var cur = 0, timer;
    function goTo(n) {
      imgs[cur].classList.add('c-hidden');
      dots[cur] && dots[cur].classList.remove('c-active');
      cur = (n + imgs.length) % imgs.length;
      imgs[cur].classList.remove('c-hidden');
      dots[cur] && dots[cur].classList.add('c-active');
    }
    prev && prev.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); goTo(cur - 1); });
    next && next.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); goTo(cur + 1); });
    card.addEventListener('mouseenter', function() { timer = setInterval(function(){ goTo(cur + 1); }, 2500); });
    card.addEventListener('mouseleave', function() { clearInterval(timer); });
    // Swipe táctil
    var touchStartX = 0;
    card.addEventListener('touchstart', function(e) { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
    card.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) { e.preventDefault(); goTo(dx < 0 ? cur + 1 : cur - 1); }
    });
  });
</script>
</BaseLayout>
