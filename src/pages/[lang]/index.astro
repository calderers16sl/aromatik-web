---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getT, NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';
import ReviewsCarousel from '../../components/ReviewsCarousel.astro';
import HostCard from '../../components/HostCard.astro';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getT(lang);
const langRoot = `/${lang}`;

const apartments = [
  { name: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, img: "/images/apartamentos/ylang-ylang/foto-1.jpg", color: "#C8B89A" },
  { name: "Romaní", slug: "romani", guests: 2, bedrooms: 1, img: "/images/apartamentos/romani/foto-1.jpg", color: "#8EAB85" },
  { name: "Ciprés", slug: "cipres", guests: 2, bedrooms: 1, img: "/images/apartamentos/cipres/foto-1.jpg", color: "#6B9B7E" },
  { name: "Lavanda", slug: "lavanda", guests: 2, bedrooms: 1, img: "/images/apartamentos/lavanda/foto-1.jpg", color: "#A899BB" },
  { name: "Limón", slug: "limon", guests: 2, bedrooms: 1, img: "/images/apartamentos/limon/foto-1.jpg", color: "#C4BC7E" },
  { name: "Bergamota", slug: "bergamota", guests: 6, bedrooms: 3, img: "/images/apartamentos/bergamota/foto-1.jpg", color: "#C4A06E" },
  { name: "Árbol de té", slug: "arbol-de-te", guests: 6, bedrooms: 3, img: "/images/apartamentos/arbol-de-te/foto-1.jpg", color: "#7AAF9E" },
  { name: "Geranio", slug: "geranio", guests: 2, bedrooms: 1, img: "/images/apartamentos/geranio/foto-1.jpg", color: "#C49090" },
];
---
<BaseLayout title={t.metaTitle} description={t.metaDescription} lang={lang}>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <span class="hero-eyebrow">{t.heroEyebrow}</span>
      <h1 set:html={t.heroTitle.replace('\n','<br>')} />
      <div class="hero-actions">
        <a href={`#apartamentos`} class="btn btn-white">{t.heroCta1}</a>
        <a href="#anfitrion" class="btn btn-outline-white" id="heroScrollBtn">{t.heroCta2}</a>
      </div>
      <div class="hero-badges">
        <span class="hero-badge">🚲 Cyclist friendly</span>
        <span class="hero-badge">🐾 Pet friendly</span>
      </div>
    </div>
  </section>

  </div>

  <section id="apartamentos" class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{t.aptsEyebrow}</span>
        <h2 style="margin-top:0.75rem">{t.aptsTitle}</h2>
        <p>{t.aptsSubtitle}</p>
      </div>
      <div class="apts-grid">
        {apartments.map((apt) => (
          <a href={`/${lang}/apartamentos/${apt.slug}`} class="apt-card">
            <div class="apt-card-img" style={`background-image: url('${apt.img}'); background-color: ${apt.color}`}></div>
            <div class="apt-card-body">
              <h3>{apt.name}</h3>
              <p class="apt-meta">{t.aptsGuests(apt.guests)} · {t.aptsBedroom(apt.bedrooms)}</p>
              <span class="apt-link">{t.aptsViewBtn}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>



  <section class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{t.whyEyebrow}</span>
        <h2 style="margin-top:0.75rem">{t.whyTitle}</h2>
        <p>{t.whySubtitle}</p>
      </div>
      <div class="perks-grid">
        <div class="perk"><div class="perk-icon">✦</div><h3>{t.perk1Title}</h3><p>{t.perk1Desc}</p></div>
        <div class="perk"><div class="perk-icon">◎</div><h3>{t.perk2Title}</h3><p>{t.perk2Desc}</p></div>
        <div class="perk"><div class="perk-icon">◈</div><h3>{t.perk3Title}</h3><p>{t.perk3Desc}</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">{t.faqEyebrow}</span>
        <h2 style="margin-top:0.75rem">{t.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {t.faqItems.map(item => (
          <div class="faq-item">
            <p class="faq-q">{item.q}</p>
            <p class="faq-a">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- BLOQUE INFORMACIÓN IMPORTANTE -->
  <HostCard />

  <ReviewsCarousel />

  <!-- SEO BLOCK 1: Barri Vell -->
  <section class="section seo-barri-vell">
    <div class="container">
      <div class="seo-grid">
        <div class="seo-text">
          <span class="eyebrow">{t.seoBarriEyebrow}</span>
          <h2>{t.seoBarriTitle}</h2>
          <p>{t.seoBarriText}</p>
        </div>
        <div class="seo-features">
          <div class="seo-feature-item">
            <span class="seo-icon">⛪</span>
            <div>
              <strong>{t.seoBarriFeat1Title}</strong>
              <span>{t.seoBarriFeat1Sub}</span>
            </div>
          </div>
          <div class="seo-feature-item">
            <span class="seo-icon">🕍</span>
            <div>
              <strong>{t.seoBarriFeat2Title}</strong>
              <span>{t.seoBarriFeat2Sub}</span>
            </div>
          </div>
          <div class="seo-feature-item">
            <span class="seo-icon">🌉</span>
            <div>
              <strong>{t.seoBarriFeat3Title}</strong>
              <span>{t.seoBarriFeat3Sub}</span>
            </div>
          </div>
          <div class="seo-feature-item">
            <span class="seo-icon">🚉</span>
            <div>
              <strong>{t.seoBarriFeat4Title}</strong>
              <span>{t.seoBarriFeat4Sub}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO BLOCK 2: Cycling -->
  <section class="section seo-cycling">
    <div class="container">
      <div class="seo-grid reverse">
        <div class="seo-features">
          <div class="seo-feature-item">
            <span class="seo-icon">🚲</span>
            <div>
              <strong>{t.seoCyclingFeat1Title}</strong>
              <span>{t.seoCyclingFeat1Sub}</span>
            </div>
          </div>
          <div class="seo-feature-item">
            <span class="seo-icon">🏔️</span>
            <div>
              <strong>{t.seoCyclingFeat2Title}</strong>
              <span>{t.seoCyclingFeat2Sub}</span>
            </div>
          </div>
          <div class="seo-feature-item">
            <span class="seo-icon">🛗</span>
            <div>
              <strong>{t.seoCyclingFeat3Title}</strong>
              <span>{t.seoCyclingFeat3Sub}</span>
            </div>
          </div>
          <div class="seo-feature-item">
            <span class="seo-icon">👕</span>
            <div>
              <strong>{t.seoCyclingFeat4Title}</strong>
              <span>{t.seoCyclingFeat4Sub}</span>
            </div>
          </div>
        </div>
        <div class="seo-text">
          <span class="eyebrow">{t.seoCyclingEyebrow}</span>
          <h2>{t.seoCyclingTitle}</h2>
          <p>{t.seoCyclingText}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-cream info-banner-section">
    <div class="container">
      <div class="info-banner">
        <div class="info-banner-text">
          <span class="eyebrow">ℹ</span>
          <h2>{t.infoIndexTitle}</h2>
          <p>{t.infoIndexText}</p>
        </div>
        <a href={`${langRoot}/informacion-importante`} class="btn btn-outline-dark">{t.infoIndexBtn} →</a>
      </div>
    </div>
  </section>
  <section class="section faq-cta-section">
    <div class="container" style="text-align:center;">
      <h3 style="font-family:var(--serif); font-size:1.6rem; font-weight:400; margin-bottom:0.75rem;">{t.faqCtaTitle}</h3>
      <p style="color:var(--stone-600); font-size:0.9rem; margin-bottom:1.5rem;">{t.faqCtaDesc}</p>
      <a href={`/${lang}/contacto`} class="btn btn-dark">{t.faqCtaBtn}</a>
    </div>
  </section>

<script is:inline>
  document.getElementById('heroScrollBtn')?.addEventListener('click', function(e) {
    e.preventDefault();
    var target = document.getElementById('anfitrion');
    if (!target) return;
    var top = target.getBoundingClientRect().top + window.pageYOffset - 80;
    window.scrollTo({ top: top, behavior: 'smooth' });
  });
</script>
</BaseLayout>
