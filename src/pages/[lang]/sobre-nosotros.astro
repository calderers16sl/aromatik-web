---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostCard from '../../components/HostCard.astro';
import ReviewsCarousel from '../../components/ReviewsCarousel.astro';
import { getT, NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const t = getT(lang);

const copy: Record<string, {
  eyebrow: string; h1: string;
  p1: string; p2: string; p3: string; p4: string;
  sectionEyebrow: string; sectionH2: string; sectionP: string;
  ctaApts: string; ctaContact: string;
