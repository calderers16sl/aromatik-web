---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostCard from '../../components/HostCard.astro';
import ReviewsCarousel from '../../components/ReviewsCarousel.astro';
import { getT, NON_DEFAULT_LOCALES, type Locale } from '../../i18n/translations';
export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const t = getT(lang);
---
<BaseLayout title={`${t.aboutTitle} — Aromatik Apartments`} lang={lang}>
  <HostCard />
  <ReviewsCarousel />

  <div class="inner-hero">
    <h1>{t.aboutTitle}</h1>
    <p>{t.aboutSubtitle}</p>
  </div>
  <section class="section">
    <div class="container-sm">
      <div class="prose">
          <p>
            Aromatik Apartments es una pequeña colección de apartamentos boutique en el corazón del Barri Vell de Girona,
            gestionados personalmente por Arnau.
          </p>
          <p>
            Nuestro objetivo es sencillo: ofrecer apartamentos cómodos, bien ubicados, con comunicación clara, acceso
            fácil mediante código y el mismo servicio de confianza que encontrarías al reservar a través de Airbnb.
          </p>
          <p>
            Al reservar directamente en nuestra web obtienes el <strong>mejor precio disponible</strong>, sin comisiones de plataforma y con la misma calidad y atención personalizada que encontrarías en Airbnb.
          </p>
          <p>
            Alójate en el centro histórico de Girona, reserva directamente y disfruta de una forma más personal de viajar.
          </p>

        
