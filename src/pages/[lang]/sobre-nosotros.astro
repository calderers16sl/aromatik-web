  en: {
    eyebrow: "Meet the project",
    h1: "About Aromatik Apartments",
    p1: "Aromatik Apartments is a small collection of boutique apartments in the heart of Girona's Barri Vell, personally managed by Arnau.",
    p2: "Our goal is simple: to offer comfortable, well-located apartments with clear communication, easy keycode access and the same trustworthy service you'd find booking through Airbnb.",
    p3: "By booking directly on our website you get the <strong>best available price</strong>, with no platform fees and the same quality and personalised attention you'd find on Airbnb.",
    p4: "Stay in the historic heart of Girona, book directly and enjoy a more personal way to travel.",
    sectionEyebrow: "The apartments",
    sectionH2: "Eight apartments in the Barri Vell of Girona",
    sectionP: "All personally managed. All with direct booking available.",
    ctaApts: "View all apartments",
    ctaContact: "Write to me directly",
  },
  fr: {
    eyebrow: "Le projet",
    h1: "\u00c0 propos d'Aromatik Apartments",
    p1: "Aromatik Apartments est une petite collection d'appartements de charme au c\u0153ur du Barri Vell de G\u00e9rone, g\u00e9r\u00e9s personnellement par Arnau.",
    p2: "Notre objectif est simple\u00a0: proposer des appartements confortables, bien situ\u00e9s, avec une communication claire, un acc\u00e8s facile par code et le m\u00eame service de confiance que vous trouveriez en r\u00e9servant via Airbnb.",
    p3: "En r\u00e9servant directement sur notre site, vous obtenez le <strong>meilleur prix disponible</strong>, sans frais de plateforme et avec la m\u00eame qualit\u00e9 et attention personnalis\u00e9e qu'Airbnb.",
    p4: "S\u00e9journez au c\u0153ur historique de G\u00e9rone, r\u00e9servez directement et profitez d'une fa\u00e7on de voyager plus personnelle.",
    sectionEyebrow: "Les appartements",
    sectionH2: "Huit appartements dans le Barri Vell de G\u00e9rone",
    sectionP: "Tous g\u00e9r\u00e9s personnellement. Tous avec r\u00e9servation directe disponible.",
    ctaApts: "Voir tous les appartements",
    ctaContact: "M'\u00e9crire directement",
  },
  ca: {
    eyebrow: "Coneix el projecte",
    h1: "Sobre Aromatik Apartments",
    p1: "Aromatik Apartments \u00e9s una petita col\u00b7lecci\u00f3 d'apartaments boutique al cor del Barri Vell de Girona, gestionats personalment per l'Arnau.",
    p2: "El nostre objectiu \u00e9s senzill: oferir apartaments c\u00f2modes, ben situats, amb comunicaci\u00f3 clara, acc\u00e9s f\u00e0cil per codi i el mateix servei de confian\u00e7a que trobar\u00edeu reservant a trav\u00e9s d'Airbnb.",
    p3: "En reservar directament al nostre web obteniu el <strong>millor preu disponible</strong>, sense comissions de plataforma i amb la mateixa qualitat i atenci\u00f3 personalitzada que trobar\u00edeu a Airbnb.",
    p4: "Allotgeu-vos al centre hist\u00f2ric de Girona, reserveu directament i gaudiu d'una manera de viatjar m\u00e9s personal.",
    sectionEyebrow: "Els apartaments",
    sectionH2: "Vuit apartaments al Barri Vell de Girona",
    sectionP: "Tots gestionats personalment. Tots amb reserva directa disponible.",
    ctaApts: "Veure tots els apartaments",
    ctaContact: "Escriure'm directament",
  },
  de: {
    eyebrow: "Das Projekt",
    h1: "\u00dcber Aromatik Apartments",
    p1: "Aromatik Apartments ist eine kleine Kollektion von Boutique-Apartments im Herzen des Barri Vell in Girona, pers\u00f6nlich gef\u00fchrt von Arnau.",
    p2: "Unser Ziel ist einfach: komfortable, zentral gelegene Apartments mit klarer Kommunikation, einfachem Code-Zugang und dem gleichen vertrauensw\u00fcrdigen Service zu bieten, den Sie bei einer Buchung \u00fcber Airbnb finden w\u00fcrden.",
    p3: "Bei einer Direktbuchung \u00fcber unsere Website erhalten Sie den <strong>besten verf\u00fcgbaren Preis</strong>, ohne Plattfomgeb\u00fchren und mit der gleichen Qualit\u00e4t und pers\u00f6nlichen Betreuung wie bei Airbnb.",
    p4: "\u00dcbernachten Sie im historischen Herzen von Girona, buchen Sie direkt und genie\u00dfen Sie eine pers\u00f6nlichere Art zu reisen.",
    sectionEyebrow: "Die Apartments",
    sectionH2: "Acht Apartments im Barri Vell von Girona",
    sectionP: "Alle pers\u00f6nlich gef\u00fchrt. Alle mit Direktbuchung verf\u00fcgbar.",
    ctaApts: "Alle Apartments ansehen",
    ctaContact: "Direkt an mich schreiben",
  },
  zh: {
    eyebrow: "\u4e86\u89e3\u9879\u76ee",
    h1: "\u5173\u4e8eAromatik Apartments",
