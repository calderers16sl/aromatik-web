---
import BaseLayout from '../layouts/BaseLayout.astro';
import HostCard from '../components/HostCard.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
---
<BaseLayout
  title="Sobre Aromatik Apartments — Apartamentos boutique en el Barri Vell de Girona"
  description="Aromatik Apartments es una pequeña colección de apartamentos boutique en el Barri Vell de Girona, gestionados personalmente por Arnau. Reserva directo y ahorra un 5%."
>
  <div class="inner-hero">
    <span class="eyebrow">Conoce el proyecto</span>
    <h1 style="margin-top:0.75rem">Sobre Aromatik Apartments</h1>
  </div>

  <section class="section">
    <div class="container">
      <div class="about-grid about-grid--single">
        <div class="prose">
          <p>
            Aromatik Apartments es una pequeña colección de apartamentos boutique en el corazón del Barri Vell de Girona,
            gestionados personalmente por Arnau.
          </p>
          <p>
            Nuestro objetivo es sencillo: ofrecer apartamentos cómodos, bien ubicados, con comunicación clara, acceso
            fácil mediante código y el mismo servicio de confianza que encontrarías al reservar a través de Airbnb.
          </p>
          <p>
            Reservando directamente en nuestra web, obtienes un <strong>5% de descuento</strong> respecto al precio de Airbnb
            y evitas comisiones innecesarias de plataforma, manteniendo el mismo apartamento, la misma calidad y la misma
            atención personalizada.
          </p>
          <p>
            Alójate en el centro histórico de Girona, reserva directamente y disfruta de una forma más personal de viajar.
          </p>
          <a href="/reservar" class="btn btn-dark" style="margin-top:1rem; display:inline-block;">
            Reserva directamente y ahorra un 5% →
          </a>
        </div>
        </div>
      </div>
    </div>
  </section>

  <HostCard />
  <ReviewsCarousel />

  <section class="section bg-cream">
    <div class="container" style="text-align:center;">
      <span class="eyebrow">Los apartamentos</span>
      <h2 style="font-family:var(--serif); font-size:2rem; font-weight:400; margin:0.75rem 0 1rem;">Ocho apartamentos en el Barri Vell de Girona</h2>
      <p style="color:var(--stone-600); margin-bottom:3rem; font-size:0.95rem;">Todos gestionados personalmente. Todos con reserva directa disponible.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/#apartamentos" class="btn btn-dark">Ver todos los apartamentos</a>
        <a href="/contacto" class="btn btn-border">Escribirme directamente</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid--single { grid-template-columns: 1fr !important; max-width: 680px; margin: 0 auto; }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .prose p { margin-bottom: 1.25rem; line-height: 1.8; color: var(--stone-700, #44403c); }
  @media (max-width: 768px) {
    .about-grid--single { grid-template-columns: 1fr !important; max-width: 680px; margin: 0 auto; }
  .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-sidebar { order: -1; }
  }
</style>
