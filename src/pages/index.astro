---
import BaseLayout from '../layouts/BaseLayout.astro';

const apartments = [
  { name: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, img: "/images/apartamentos/ylang-ylang/foto-1.jpg", color: "#C8B89A" },
  { name: "Romaní", slug: "romani", guests: 2, bedrooms: 1, img: "/images/apartamentos/romani/foto-1.jpg", color: "#8EAB85" },
  { name: "Ciprés", slug: "cipres", guests: 2, bedrooms: 1, img: "/images/apartamentos/cipres/foto-1.jpg", color: "#6B9B7E" },
  { name: "Lavanda", slug: "lavanda", guests: 2, bedrooms: 1, img: "/images/apartamentos/lavanda/foto-1.jpg", color: "#A899BB" },
  { name: "Limón", slug: "limon", guests: 2, bedrooms: 1, img: "/images/apartamentos/limon/foto-1.jpg", color: "#C4BC7E" },
  { name: "Bergamota", slug: "bergamota", guests: 6, bedrooms: 3, img: "/images/apartamentos/bergamota/foto-1.jpg", color: "#C4A06E" },
  { name: "Árbol de té", slug: "arbol-de-te", guests: 6, bedrooms: 3, img: "/images/apartamentos/arbol-de-te/foto-1.jpg", color: "#7AAF9E" },
  { name: "Geranio", slug: "geranio", guests: 2, bedrooms: 1, img: "/images/apartamentos/geranio/foto-1.jpg", color: "#C49090" },
];

const perks = [
  { icon: "✦", title: "Mejor precio directo", desc: "Reservando en la web oficial evitas comisiones de plataformas externas y accedes al precio más claro disponible." },
  { icon: "◎", title: "Hablas directamente con el anfitrión", desc: "Antes, durante y después de la estancia puedes escribirme por WhatsApp si tienes dudas sobre el apartamento, el check-in, el parking o cualquier detalle de Girona." },
  { icon: "◈", title: "Más margen para ayudarte", desc: "Si necesitas una hora de llegada especial, vienes con bicicletas, viajas en familia o tienes una petición concreta, es mucho más fácil gestionarlo directamente." },
];

const faqs = [
  { q: "¿Dónde están los apartamentos?", a: "Todos los apartamentos de Aromatik están en el Barri Vell de Girona, a pocos minutos andando de la Catedral, el Call Jueu, los Baños Árabes y el río Onyar. El centro histórico de Girona es completamente visitable a pie desde cualquiera de ellos." },
  { q: "¿Dónde puedo dejar el coche?", a: "Los apartamentos están en zona peatonal. Lo más práctico suele ser el parking La Copa, a unos 10 minutos andando, o los parkings Saba de los alrededores. Si tienes dudas antes de llegar, escríbeme y te indico la opción más cómoda según tu apartamento." },
  { q: "¿Puedo venir con bicicleta?", a: "Sí. Girona es una ciudad muy vinculada al ciclismo y muchos huéspedes vienen con bicicleta. Los apartamentos permiten guardarlas en el interior y los ascensores son amplios, algo que facilita mucho la llegada y la salida." },
  { q: "¿Cómo funciona el check-in?", a: "El check-in está pensado para que sea sencillo y flexible. Antes de la llegada recibirás toda la información necesaria y, si tienes cualquier duda, puedes escribirme directamente. La idea es que no pierdas tiempo al llegar y puedas empezar a disfrutar Girona desde el primer momento." },
  { q: "¿Por qué reservar directamente?", a: "Reservar directamente en la web oficial de Aromatik Apartments te permite evitar comisiones externas y hablar conmigo de forma directa si necesitas resolver cualquier detalle antes de confirmar la estancia." },
];
---
<BaseLayout
  title="Apartamentos turísticos en el Barri Vell de Girona"
  description="Aromatik Apartments — apartamentos turísticos boutique en el centro histórico de Girona. Reserva directa, atención local y alojamientos seleccionados en el Barri Vell."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-brand-wrap">
      <span class="hero-brand-name">Aromatik Apartments</span>
    </div>
  </section>

  <!-- HERO INTRO (below image) -->
  <section class="hero-intro">
    <div class="hero-intro-inner">
      <span class="hero-eyebrow-dark">Barri Vell · Girona, Catalunya</span>
      <h1 class="hero-intro-title">Apartamentos con alma<br>en el Barri Vell de Girona</h1>
      <p class="hero-intro-subtitle">
        Soy Arnau, anfitrión de Aromatik Apartments. Gestiono personalmente una pequeña colección de apartamentos en el centro histórico de Girona, todos cerca de la Catedral, el Call Jueu, los Baños Árabes y el río Onyar.
      </p>
      <div class="hero-intro-actions">
        <a href="#apartamentos" class="btn btn-gold">Ver apartamentos disponibles</a>
        <a href="/contacto" class="btn btn-border">Contactar directamente</a>
      </div>
      <p class="hero-intro-trust">
        Mi objetivo es sencillo: que llegues, lo entiendas todo fácilmente y disfrutes Girona desde un apartamento bien ubicado, cómodo y cuidado.
      </p>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div><span class="trust-num">8</span><span class="trust-label">Apartamentos</span></div>
      <div><span class="trust-num">100%</span><span class="trust-label">Barri Vell</span></div>
      <div><span class="trust-num">★ 4.9</span><span class="trust-label">Valoración media</span></div>
      <div><span class="trust-num">0%</span><span class="trust-label">Comisiones</span></div>
    </div>
  </div>

  <!-- APARTMENTS GRID -->
  <section id="apartamentos" class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Colección Aromatik</span>
        <h2 style="margin-top:0.75rem">Ocho apartamentos, ocho aromas, una misma idea</h2>
        <p>Cada apartamento lleva el nombre de una planta aromática. Algunos para parejas mirando al Onyar, otros para familias o grupos. Todos pensados para vivir Girona andando.</p>
      </div>
      <div class="apts-grid">
        {apartments.map((apt) => (
          <a href={`/apartamentos/${apt.slug}`} class="apt-card">
            <div class="apt-card-img" style={`background-image: url('${apt.img}'); background-color: ${apt.color}`}></div>
            <div class="apt-card-body">
              <h3>{apt.name}</h3>
              <p class="apt-meta">{apt.guests} personas · {apt.bedrooms === 1 ? '1 habitación' : `${apt.bedrooms} habitaciones`}</p>
              <span class="apt-link">Ver apartamento →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND STATEMENT -->
  <div class="brand-statement">
    <blockquote>
      "Aromatik Apartments nace en Girona con una idea sencilla: ofrecer apartamentos turísticos bien ubicados,
      cuidados y gestionados localmente para quienes quieren vivir el Barri Vell desde dentro."
    </blockquote>
    <cite>— Arnau · Aromatik Apartments</cite>
  </div>

  <!-- WHY BOOK DIRECT -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Reserva directa</span>
        <h2 style="margin-top:0.75rem">Reserva directa, trato directo y una estancia más fácil</h2>
        <p>Reservar directamente con nosotros es más sencillo, más claro y más personal que a través de cualquier plataforma.</p>
      </div>
      <div class="perks-grid">
        {perks.map((p) => (
          <div class="perk">
            <div class="perk-icon">{p.icon}</div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- NO SOMOS UNA CADENA -->
  <section class="section">
    <div class="container-sm" style="text-align:center">
      <span class="eyebrow">Gestión personal</span>
      <h2 style="font-family:var(--serif); font-size:clamp(1.8rem,3vw,2.6rem); font-weight:400; margin:0.75rem 0 1.5rem;">No somos una cadena. Y eso se nota.</h2>
      <p style="font-size:1rem; color:var(--stone-600); line-height:1.9; max-width:600px; margin:0 auto 1.25rem;">
        Aromatik Apartments no funciona como un hotel impersonal ni como una agencia enorme. Cada apartamento lo conozco, lo he preparado y lo gestiono con atención al detalle.
      </p>
      <p style="font-size:1rem; color:var(--stone-600); line-height:1.9; max-width:600px; margin:0 auto;">
        Algunos huéspedes vienen por trabajo, otros por una escapada romántica, otros para descubrir Girona en bicicleta o pasar unos días en familia. Mi trabajo es que el apartamento no sea una preocupación, sino una parte agradable del viaje.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">FAQ</span>
        <h2 style="margin-top:0.75rem">Preguntas frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/contacto" class="btn btn-border">¿Más preguntas? Escríbenos</a>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="section bg-black text-center">
    <div class="container-sm">
      <span class="eyebrow" style="color:rgba(255,255,255,0.4)">Reserva directa</span>
      <h2 style="font-family:var(--serif); font-size:clamp(1.8rem,3vw,2.8rem); font-weight:400; color:#fff; margin:1rem 0 1.25rem;">
        Vive el Barri Vell de Girona<br>desde tu propio apartamento boutique
      </h2>
      <p style="color:rgba(255,255,255,0.6); font-size:0.95rem; max-width:480px; margin:0 auto 2.5rem; line-height:1.8;">
        Aromatik Apartments no es una plataforma anónima: somos una marca local especializada en apartamentos turísticos en el Barri Vell de Girona.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/#apartamentos" class="btn btn-white">Ver apartamentos</a>
        <a href="/contacto" class="btn btn-outline-white">Contactar</a>
      </div>
    </div>
  </section>
</BaseLayout>
