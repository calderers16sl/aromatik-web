---
import BaseLayout from '../layouts/BaseLayout.astro';

const apartments = [
  { name: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, smoobuId: 1397576, emoji: "🌸" },
  { name: "Romaní", slug: "romani", guests: 2, bedrooms: 1, smoobuId: 1033021, emoji: "🌿" },
  { name: "Ciprés", slug: "cipres", guests: 4, bedrooms: 2, smoobuId: 1035631, emoji: "🌲" },
  { name: "Lavanda", slug: "lavanda", guests: 2, bedrooms: 1, smoobuId: 1033339, emoji: "💜" },
  { name: "Limón", slug: "limon", guests: 3, bedrooms: 1, smoobuId: 1037266, emoji: "🍋" },
  { name: "Bergamota", slug: "bergamota", guests: 4, bedrooms: 2, smoobuId: 1034422, emoji: "🍊" },
  { name: "Árbol de té", slug: "arbol-de-te", guests: 2, bedrooms: 1, smoobuId: 1315321, emoji: "🌱" },
  { name: "Geranio", slug: "geranio", guests: 4, bedrooms: 2, smoobuId: 1599430, emoji: "🌺" },
];
---
<BaseLayout title="Apartamentos en Girona" description="8 apartamentos de diseño en el casco antiguo de Girona. Reserva directa con el mejor precio.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-tag">Girona · Casco antiguo</p>
      <h1>Despierta en<br/><em>el corazón de Girona</em></h1>
      <p class="hero-desc">8 apartamentos únicos en la ciudad medieval. Cada uno con su propio aroma, su propia personalidad.</p>
      <div class="hero-btns">
        <a href="/#apartamentos" class="btn-white">Ver apartamentos</a>
        <a href="/reservar" class="btn-outline">Reservar ahora</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="section-sm text-center">
      <h2 class="section-title">Apartamentos con alma</h2>
      <p class="section-subtitle">
        Cada apartamento lleva el nombre de una planta aromática. Diseñados con mimo, equipados con todo lo necesario,
        ubicados en el barrio más bonito de Girona. Porque los mejores recuerdos empiezan por un buen sitio donde quedarse.
      </p>
    </div>
  </section>

  <!-- APARTMENTS GRID -->
  <section id="apartamentos" class="section" style="padding-top:0">
    <div class="section-inner">
      <h2 class="section-title text-center mb-8">Nuestros apartamentos</h2>
      <div class="apartments-grid">
        {apartments.map((apt) => (
          <a href={`/apartamentos/${apt.slug}`} class="apt-card">
            <div class="apt-card-img">{apt.emoji}</div>
            <div class="apt-card-body">
              <h3>{apt.name}</h3>
              <p>{apt.guests} personas · {apt.bedrooms} dorm.</p>
              <span class="link">Ver detalles →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY BOOK DIRECT -->
  <section class="section bg-stone">
    <div class="section-inner">
      <h2 class="section-title text-center mb-8">¿Por qué reservar directo?</h2>
      <div class="perks-grid">
        {[
          { icon: "💰", title: "Mejor precio", desc: "Sin comisiones de portales. El precio más bajo, garantizado." },
          { icon: "📞", title: "Atención directa", desc: "Hablas con Arnau, el propietario. Respuesta en menos de 1h." },
          { icon: "🔄", title: "Flexibilidad", desc: "Más opciones de check-in/out y peticiones especiales." }
        ].map(item => (
          <div class="perk-card">
            <div class="perk-icon">{item.icon}</div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-sm">
      <h2 class="section-title text-center mb-8">Preguntas frecuentes</h2>
      {[
        { q: "¿Dónde están los apartamentos?", a: "En el casco antiguo de Girona, a pocos minutos a pie de la Catedral, los baños árabes y el río Onyar." },
        { q: "¿Hay parking?", a: "Los apartamentos están en zona peatonal. El aparcamiento La Copa (gratuito) está a 10 minutos a pie. También hay parkings de pago Saba cerca." },
        { q: "¿Se permiten bicicletas?", a: "Sí, todos los apartamentos permiten guardar bicicletas dentro. Los ascensores son amplios para que quepan." },
        { q: "¿Cuáles son los horarios de check-in/out?", a: "Check-in desde las 15h, check-out hasta las 11h. Para horarios flexibles, contacta con antelación." },
      ].map(faq => (
        <div class="faq-item">
          <h3>{faq.q}</h3>
          <p>{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
