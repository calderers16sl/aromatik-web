---
import BaseLayout from '../layouts/BaseLayout.astro';

const apartments = [
  { name: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, img: "/images/apartamentos/ylang-ylang.jpg", color: "#C8B89A" },
  { name: "Romaní", slug: "romani", guests: 2, bedrooms: 1, img: "/images/apartamentos/romani.jpg", color: "#8EAB85" },
  { name: "Ciprés", slug: "cipres", guests: 4, bedrooms: 2, img: "/images/apartamentos/cipres.jpg", color: "#6B9B7E" },
  { name: "Lavanda", slug: "lavanda", guests: 2, bedrooms: 1, img: "/images/apartamentos/lavanda.jpg", color: "#A899BB" },
  { name: "Limón", slug: "limon", guests: 3, bedrooms: 1, img: "/images/apartamentos/limon.jpg", color: "#C4BC7E" },
  { name: "Bergamota", slug: "bergamota", guests: 4, bedrooms: 2, img: "/images/apartamentos/bergamota.jpg", color: "#C4A06E" },
  { name: "Árbol de té", slug: "arbol-de-te", guests: 2, bedrooms: 1, img: "/images/apartamentos/arbol-de-te.jpg", color: "#7AAF9E" },
  { name: "Geranio", slug: "geranio", guests: 4, bedrooms: 2, img: "/images/apartamentos/geranio.jpg", color: "#C49090" },
];

const perks = [
  { icon: "✦", title: "Mejor precio garantizado", desc: "Reservando directamente en nuestra web siempre tendrás el precio más bajo disponible. Sin comisiones de plataformas externas." },
  { icon: "◎", title: "Atención local y directa", desc: "Tratas directamente con el equipo de Aromatik Apartments. Respuesta rápida antes, durante y después de tu estancia en Girona." },
  { icon: "◈", title: "Flexibilidad y confianza", desc: "Check-in personalizado, peticiones especiales y comunicación transparente desde el primer momento. Sin intermediarios." },
];

const faqs = [
  { q: "¿Dónde están los apartamentos de Aromatik Apartments?", a: "Todos nuestros apartamentos están en el Barri Vell de Girona, a pocos minutos a pie de la Catedral, el Call Jueu, los Baños Árabes y el río Onyar." },
  { q: "¿Hay parking cerca de los apartamentos?", a: "Los apartamentos están en zona peatonal del centro histórico. El aparcamiento La Copa es gratuito y está a unos 10 minutos a pie. También hay parkings de pago Saba en los alrededores." },
  { q: "¿Se pueden guardar bicicletas?", a: "Sí. Todos los apartamentos de Aromatik Apartments permiten guardar bicicletas en el interior. Los ascensores son amplios y están pensados para ello." },
  { q: "¿Cuáles son los horarios de entrada y salida?", a: "El check-in es a partir de las 15h y el check-out hasta las 11h. Si necesitas horarios más flexibles, ponte en contacto con nosotros antes de tu llegada." },
  { q: "¿Por qué reservar directamente con Aromatik Apartments?", a: "Porque al reservar en nuestra web oficial obtienes el mejor precio disponible, tratas directamente con el equipo local y tienes más flexibilidad que a través de cualquier plataforma externa." },
];
---
<BaseLayout
  title="Apartamentos turísticos en el Barri Vell de Girona"
  description="Aromatik Apartments — apartamentos turísticos boutique en el centro histórico de Girona. Reserva directa, atención local y alojamientos seleccionados en el Barri Vell."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <span class="hero-eyebrow">Barri Vell · Girona, Catalunya</span>
      <h1>Apartamentos turísticos<br>en el Barri Vell de Girona</h1>
      <p class="hero-subtitle">
        Descubre Aromatik Apartments, una colección de apartamentos boutique en el centro histórico de Girona,
        pensados para disfrutar de la ciudad con comodidad, estilo y atención local.
      </p>
      <div class="hero-actions">
        <a href="#apartamentos" class="btn btn-white">Ver apartamentos disponibles</a>
        <a href="/sobre-nosotros" class="btn btn-outline-white">Conoce Aromatik Apartments</a>
      </div>
      <p class="hero-trust">
        Reserva directamente con Aromatik Apartments y disfruta de una experiencia más cercana, transparente y sin comisiones innecesarias.
      </p>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div><span class="trust-num">8</span><span class="trust-label">Apartamentos</span></div>
      <div><span class="trust-num">100%</span><span class="trust-label">Barri Vell</span></div>
      <div><span class="trust-num">★ 4.9</span><span class="trust-label">Valoración media</span></div>
      <div><span class="trust-num">0%</span><span class="trust-label">Comisiones</span></div>
    </div>
  </div>

  <!-- APARTMENTS GRID -->
  <section id="apartamentos" class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Colección Aromatik</span>
        <h2 style="margin-top:0.75rem">Nuestros apartamentos en Girona</h2>
        <p>Ocho espacios únicos, cada uno con el nombre de una planta aromática. Todos en el corazón del Barri Vell.</p>
      </div>
      <div class="apts-grid">
        {apartments.map((apt) => (
          <a href={`/apartamentos/${apt.slug}`} class="apt-card">
            <div class="apt-card-img" style={`background-image: url('${apt.img}'); background-color: ${apt.color}`}></div>
            <div class="apt-card-body">
              <h3>{apt.name}</h3>
              <p class="apt-meta">{apt.guests} personas · {apt.bedrooms === 1 ? '1 habitación' : `${apt.bedrooms} habitaciones`}</p>
              <span class="apt-link">Ver apartamento →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND STATEMENT -->
  <div class="brand-statement">
    <blockquote>
      "Aromatik Apartments nace en Girona con una idea sencilla: ofrecer apartamentos turísticos bien ubicados,
      cuidados y gestionados localmente para quienes quieren vivir el Barri Vell desde dentro."
    </blockquote>
    <cite>— Aromatik Apartments · Girona</cite>
  </div>

  <!-- WHY BOOK DIRECT -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Reserva directa</span>
        <h2 style="margin-top:0.75rem">Por qué reservar con Aromatik Apartments</h2>
        <p>Al reservar en la web oficial tratas directamente con el equipo local. Sin intermediarios, sin sorpresas.</p>
      </div>
      <div class="perks-grid">
        {perks.map((p) => (
          <div class="perk">
            <div class="perk-icon">{p.icon}</div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">FAQ</span>
        <h2 style="margin-top:0.75rem">Preguntas frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/contacto" class="btn btn-border">¿Más preguntas? Escríbenos</a>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="section bg-black text-center">
    <div class="container-sm">
      <span class="eyebrow" style="color:rgba(255,255,255,0.4)">Reserva directa</span>
      <h2 style="font-family:var(--serif); font-size:clamp(1.8rem,3vw,2.8rem); font-weight:400; color:#fff; margin:1rem 0 1.25rem;">
        Vive el Barri Vell de Girona<br>desde tu propio apartamento boutique
      </h2>
      <p style="color:rgba(255,255,255,0.6); font-size:0.95rem; max-width:480px; margin:0 auto 2.5rem; line-height:1.8;">
        Aromatik Apartments no es una plataforma anónima: somos una marca local especializada en apartamentos turísticos en el Barri Vell de Girona.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/#apartamentos" class="btn btn-white">Ver apartamentos</a>
        <a href="/contacto" class="btn btn-outline-white">Contactar</a>
      </div>
    </div>
  </section>
</BaseLayout>
