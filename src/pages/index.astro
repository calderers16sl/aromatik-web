---
import BaseLayout from '../layouts/BaseLayout.astro';

const apartments = [
  { name: "Ylang-Ylang", slug: "ylang-ylang", guests: 4, bedrooms: 2, id: 1397576, emoji: "🌸", photos: 21 },
  { name: "Romaní",      slug: "romani",      guests: 2, bedrooms: 1, id: 1033021, emoji: "🌿", photos: 20 },
  { name: "Ciprés",      slug: "cipres",      guests: 4, bedrooms: 2, id: 1035631, emoji: "🌲", photos: 12 },
  { name: "Lavanda",     slug: "lavanda",     guests: 2, bedrooms: 1, id: 1033339, emoji: "💜", photos: 19 },
  { name: "Limón",       slug: "limon",       guests: 3, bedrooms: 1, id: 1037266, emoji: "🍋", photos: 21 },
  { name: "Bergamota",   slug: "bergamota",   guests: 4, bedrooms: 2, id: 1034422, emoji: "🍊", photos: 21 },
  { name: "Árbol de té", slug: "arbol-de-te", guests: 2, bedrooms: 1, id: 1315321, emoji: "🌱", photos: 23 },
  { name: "Geranio",     slug: "geranio",     guests: 4, bedrooms: 2, id: 1599430, emoji: "🌺", photos: 20 },
];

const CARD_PHOTOS = 5; // fotos por carrusel en la grid
---
<BaseLayout title="Apartamentos en Girona" description="8 apartamentos de diseño en el casco antiguo de Girona. Reserva directa con el mejor precio.">

  <!-- ═══════════════════════════════
       HERO
  ════════════════════════════════ -->
  <section class="relative h-[90vh] flex items-center justify-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-stone-800" style="background-image:url('/images/apartamentos/bergamota/foto-1.jpg')"></div>
    <div class="absolute inset-0 bg-black/50 z-10"></div>
    <div class="relative z-20 text-center px-8 py-10 max-w-3xl mx-auto bg-black/25 rounded-3xl backdrop-blur-[2px]">
      <p class="text-sm uppercase tracking-[0.3em] mb-4 text-stone-300">Girona · Casco antiguo</p>
      <h1 class="text-5xl md:text-7xl font-light leading-tight mb-6">
        Despierta en<br/><em>el corazón de Girona</em>
      </h1>
      <p class="text-lg text-stone-200 mb-10 max-w-xl mx-auto">
        8 apartamentos únicos en la ciudad medieval. Cada uno con su propio aroma, su propia personalidad.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#apartamentos" class="bg-white text-stone-900 px-8 py-3 rounded-full font-medium hover:bg-stone-100 transition-colors">
          Ver apartamentos
        </a>
        <a href="/reservar" class="border border-white text-white px-8 py-3 rounded-full font-medium hover:bg-white/10 transition-colors">
          Reservar ahora
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════
       INTRO
  ════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-4 py-20 text-center">
    <h2 class="text-3xl font-light mb-6" style="color:var(--color-primary)">Apartamentos con alma</h2>
    <p class="text-lg text-stone-600 leading-relaxed">
      Cada apartamento lleva el nombre de una planta aromática. Diseñados con mimo, equipados con todo lo necesario,
      ubicados en el barrio más bonito de Girona. Porque los mejores recuerdos empiezan por un buen sitio donde quedarse.
    </p>
  </section>

  <!-- ═══════════════════════════════
       APARTMENTS GRID — carrusel mini
  ════════════════════════════════ -->
  <section id="apartamentos" class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl font-light text-center mb-12" style="color:var(--color-text)">Nuestros apartamentos</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {apartments.map((apt) => {
        const count = Math.min(CARD_PHOTOS, apt.photos);
        const imgs  = Array.from({ length: count }, (_, i) => i + 1);
        return (
          <a
            href={`/apartamentos/${apt.slug}`}
            class="apt-card group block rounded-2xl overflow-hidden border border-stone-200 hover:shadow-xl transition-all duration-300"
            data-slug={apt.slug}
          >
            {/* ── Carrusel de fotos ── */}
            <div class="relative h-48 bg-stone-100 overflow-hidden">

              {imgs.map((n, i) => (
                <img
                  src={`/images/apartamentos/${apt.slug}/foto-${n}.jpg`}
                  alt={`${apt.name} - foto ${n}`}
                  class={`card-img absolute inset-0 w-full h-full object-cover transition-opacity duration-300 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
                  loading={i === 0 ? "eager" : "lazy"}
                />
              ))}

              {/* Flechas — solo se muestran con más de 1 foto */}
              {count > 1 && (
                <>
                  <button
                    class="card-prev absolute left-1.5 top-1/2 -translate-y-1/2 z-10 w-7 h-7 rounded-full bg-black/40 hover:bg-black/65 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-base leading-none"
                    aria-label="Foto anterior"
                  >&#8249;</button>
                  <button
                    class="card-next absolute right-1.5 top-1/2 -translate-y-1/2 z-10 w-7 h-7 rounded-full bg-black/40 hover:bg-black/65 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-base leading-none"
                    aria-label="Foto siguiente"
                  >&#8250;</button>
                </>
              )}

              {/* Puntos indicadores */}
              {count > 1 && (
                <div class="absolute bottom-2 left-0 right-0 flex justify-center gap-1 z-10 pointer-events-none">
                  {imgs.map((_