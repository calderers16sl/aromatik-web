---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}
const {
  title,
  description = "Apartamentos turísticos boutique en el Barri Vell de Girona. Reserva directa, atención local y alojamientos seleccionados en el centro histórico.",
  lang = "es",
  ogImage
} = Astro.props;
const siteUrl = "https://aromatik.apartments";
const canonicalURL = `${siteUrl}${Astro.url.pathname}`;

const schemaOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "Aromatik Apartments",
  "description": "Apartamentos turísticos boutique en el Barri Vell de Girona",
  "url": siteUrl,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Girona",
    "addressRegion": "Cataluña",
    "addressCountry": "ES"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 41.9833, "longitude": 2.8249 },
  "numberOfRooms": 8,
  "priceRange": "€€"
});
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Aromatik Apartments</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="es" href={`${siteUrl}${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="en" href={`${siteUrl}/en${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="ca" href={`${siteUrl}/ca${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="fr" href={`${siteUrl}/fr${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="de" href={`${siteUrl}/de${Astro.url.pathname}`} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} | Aromatik Apartments`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schemaOrg} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --white: #FFFFFF;
      --cream: #FAF8F5;
      --stone-50: #F5F2EE;
      --stone-200: #E2DDD8;
      --stone-400: #B8B0A8;
      --stone-500: #9C9490;
      --stone-600: #6B6560;
      --stone-800: #3A3530;
      --black: #1A1816;
      --gold: #d0b050;
      --gold-hover: #b89a40;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'DM Sans', system-ui, sans-serif;
      --radius: 4px;
      --radius-lg: 12px;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--white); color: var(--black); line-height: 1.6; font-size: 16px; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── HEADER ── */
    .header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 70px; display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); border-bottom: 1px solid var(--stone-200); transition: box-shadow 0.3s; }
    .header.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.08); }
    .header-logo { font-family: var(--serif); font-size: 1.15rem; font-weight: 400; letter-spacing: 0.04em; }
    .header-logo em { font-style: normal; color: var(--gold); }
    .header-nav { display: flex; align-items: center; gap: 2.5rem; position: fixed; top: 0; right: 2rem; height: 70px; z-index: 101; }
    .header-nav a { font-size: 0.825rem; font-weight: 400; color: var(--stone-600); letter-spacing: 0.02em; transition: color 0.2s; }
    .header-nav a:hover { color: var(--black); }
    .nav-cta { background: var(--gold) !important; color: var(--white) !important; padding: 0.55rem 1.4rem; border-radius: var(--radius); font-size: 0.75rem !important; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500 !important; transition: background 0.2s !important; }
    .nav-cta:hover { background: var(--gold-hover) !important; }
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 4px; flex-direction: column; gap: 5px; }
    .hamburger span { display: block; width: 22px; height: 1.5px; background: var(--black); transition: all 0.3s; }
    @media (max-width: 768px) {
      .header-nav { display: none; }
      .hamburger { display: flex; }
      .header-nav.open { display: flex; flex-direction: column; align-items: flex-start; position: fixed; top: 70px; left: 0; right: 0; z-index: 200; background-color: #fff; background: #fff; padding: 1.5rem 2rem 2rem; gap: 1.25rem; border-top: 1px solid #e7e5e4; box-shadow: 0 12px 32px rgba(0,0,0,0.14); }
      .header-nav.open a { font-size: 1.1rem; }
    }

    /* ── HERO ── */
    .hero { position: relative; min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center; color: var(--white); overflow: hidden; padding-top: 70px; }
    .hero-bg { position: absolute; inset: 0; background: linear-gradient(160deg, #1a1510 0%, #2a1f0a 40%, #1e1708 70%, #110e06 100%); background-image: url("/images/hero-girona.jpg"); background-size: cover; background-position: center; }
    .hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.25); }
    /* Hero: brand name only on image */
    .hero-brand-wrap { position: relative; z-index: 1; text-align: center; }
    .hero-brand-name { font-family: var(--serif); font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 300; color: #fff; letter-spacing: 0.12em; text-transform: uppercase; }
    /* Hero intro section below the image */
    .hero-intro { background: var(--cream); padding: 4rem 2rem 3rem; text-align: center; border-bottom: 1px solid var(--stone-200); }
    .hero-intro-inner { max-width: 700px; margin: 0 auto; }
    .hero-eyebrow-dark { display: inline-block; font-size: 0.7rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--stone-500); margin-bottom: 1.5rem; font-weight: 300; }
    .hero-intro-title { font-family: var(--serif); font-size: clamp(1.9rem, 4vw, 3.2rem); font-weight: 400; line-height: 1.25; margin-bottom: 1.5rem; color: var(--stone-900); }
    .hero-intro-subtitle { font-size: 1rem; color: var(--stone-600); max-width: 580px; margin: 0 auto 2rem; line-height: 1.9; font-weight: 300; }
    .hero-intro-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.75rem; }
    .hero-intro-trust { font-size: 0.82rem; color: var(--stone-500); max-width: 480px; margin: 0 auto; line-height: 1.9; font-style: italic; }
    /* Legacy hero-inner kept for other pages if needed */
    .hero-inner { position: relative; z-index: 1; max-width: 820px; padding: 4rem 2rem; }
    .hero-eyebrow { display: inline-block; font-size: 0.7rem; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 2rem; font-weight: 300; }
    .hero h1 { font-family: var(--serif); font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 400; line-height: 1.2; margin-bottom: 1.5rem; }
    .hero-subtitle { font-size: 1rem; color: rgba(255,255,255,0.78); max-width: 580px; margin: 0 auto 2.5rem; line-height: 1.8; font-weight: 300; }
    .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2.5rem; }
    .hero-trust { font-size: 0.75rem; color: rgba(255,255,255,0.45); letter-spacing: 0.02em; max-width: 480px; margin: 0 auto; line-height: 1.8; }

    /* ── BUTTONS ── */
    .btn { display: inline-block; font-family: var(--sans); font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.875rem 2rem; border-radius: var(--radius); transition: all 0.2s; cursor: pointer; border: none; }
    .btn-white { background: var(--white); color: var(--black); }
    .btn-white:hover { background: var(--cream); }
    .btn-outline-white { border: 1px solid rgba(255,255,255,0.5); color: var(--white); }
    .btn-outline-white:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }
    .btn-dark { background: var(--black); color: var(--white); }
    .btn-dark:hover { background: var(--stone-800); }
    .btn-green { background: var(--gold); color: var(--white); }
    .btn-green:hover { background: var(--gold-hover); }
    .btn-border { border: 1px solid var(--stone-200); color: var(--stone-600); background: var(--white); }
    .btn-border:hover { border-color: var(--black); color: var(--black); }
    .btn-gold { background: var(--gold); color: var(--black); }
    .btn-gold:hover { background: var(--gold-hover); }

    /* ── TRUST BAR ── */
    .trust-bar { background: var(--black); color: var(--white); padding: 1.5rem 2rem; }
    .trust-bar-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; text-align: center; }
    .trust-num { display: block; font-family: var(--serif); font-size: 1.6rem; font-weight: 400; }
    .trust-label { display: block; font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-top: 0.3rem; }
    @media (max-width: 600px) { .trust-bar-inner { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }

    /* ── LAYOUT ── */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
    .container-sm { max-width: 760px; margin: 0 auto; padding: 0 2rem; }
    .section { padding: 6rem 0; }
    .section-sm { padding: 4rem 0; }
    .bg-cream { background: var(--cream); }
    .bg-stone { background: var(--stone-50); }
    .bg-black { background: var(--black); color: var(--white); }
    .text-center { text-align: center; }
    .section-header { text-align: center; margin-bottom: 4rem; }
    .section-header h2 { font-family: var(--serif); font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 400; margin-bottom: 1rem; }
    .section-header p { font-size: 0.95rem; color: var(--stone-600); max-width: 520px; margin: 0 auto; line-height: 1.8; }

    /* ── APARTMENTS GRID ── */
    .apts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
    @media (max-width: 1024px) { .apts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 580px) { .apts-grid { grid-template-columns: 1fr 1fr; gap: 1rem; } }

    .apt-card { display: block; border: 1px solid var(--stone-200); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow 0.3s, transform 0.3s; }
    .apt-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.1); transform: translateY(-4px); }
    .apt-card-img { height: 200px; background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; }
    .apt-emoji-placeholder { font-size: 3rem; opacity: 0.5; }
    .apt-card-body { padding: 1.25rem 1.5rem; }
    .apt-card-body h3 { font-family: var(--serif); font-size: 1.1rem; font-weight: 400; margin-bottom: 0.3rem; }
    .apt-meta { font-size: 0.78rem; color: var(--stone-500); margin-bottom: 0.875rem; }
    .apt-link { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); }

    /* ── BRAND STATEMENT ── */
    .brand-statement { padding: 6rem 2rem; text-align: center; background: var(--black); }
    .brand-statement blockquote { font-family: var(--serif); font-size: clamp(1.15rem, 2.5vw, 1.75rem); font-weight: 400; font-style: italic; color: var(--white); max-width: 800px; margin: 0 auto; line-height: 1.7; }
    .brand-statement cite { display: block; margin-top: 1.75rem; font-family: var(--sans); font-style: normal; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.4); }

    /* ── PERKS ── */
    .perks-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    @media (max-width: 768px) { .perks-grid { grid-template-columns: 1fr; } }
    .perk { padding: 2rem 1.75rem; border: 1px solid var(--stone-200); background: var(--white); border-radius: var(--radius-lg); }
    .perk-icon { font-size: 1.6rem; margin-bottom: 1.25rem; }
    .perk h3 { font-family: var(--serif); font-size: 1.05rem; font-weight: 400; margin-bottom: 0.6rem; }
    .perk p { font-size: 0.875rem; color: var(--stone-600); line-height: 1.75; }

    /* ── FAQ ── */
    .faq-list { max-width: 680px; margin: 0 auto; }
    .faq-item { border-top: 1px solid var(--stone-200); padding: 1.75rem 0; }
    .faq-item:last-child { border-bottom: 1px solid var(--stone-200); }
    .faq-q { font-family: var(--serif); font-size: 1rem; font-weight: 400; margin-bottom: 0.75rem; }
    .faq-a { font-size: 0.875rem; color: var(--stone-600); line-height: 1.8; }

    /* ── FOOTER ── */
    .footer { background: var(--black); color: rgba(255,255,255,0.6); padding: 5rem 2rem 2.5rem; }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; max-width: 1200px; margin: 0 auto 3rem; }
    @media (max-width: 900px) { .footer-top { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 520px) { .footer-top { grid-template-columns: 1fr; } }
    .footer-brand h3 { font-family: var(--serif); font-size: 1.25rem; color: var(--white); font-weight: 400; margin-bottom: 0.75rem; }
    .footer-brand p { font-size: 0.825rem; line-height: 1.8; max-width: 280px; }
    .footer-brand .footer-contact-links { margin-top: 1.25rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .footer-brand .footer-contact-links a { font-size: 0.8rem; color: rgba(255,255,255,0.5); transition: color 0.2s; }
    .footer-brand .footer-contact-links a:hover { color: var(--white); }
    .footer-col h4 { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--white); margin-bottom: 1.25rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
    .footer-col a { font-size: 0.825rem; color: rgba(255,255,255,0.5); transition: color 0.2s; }
    .footer-col a:hover { color: var(--white); }
    .footer-bottom { max-width: 1200px; margin: 0 auto; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-bottom p { font-size: 0.75rem; }

    /* ── APARTMENT DETAIL ── */
    .apt-detail-hero { min-height: 55vh; background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; margin-top: 70px; }
    .apt-detail-emoji { font-size: 7rem; opacity: 0.6; }
    .apt-detail-grid { display: grid; grid-template-columns: 1fr 380px; gap: 4rem; align-items: start; }
    @media (max-width: 1024px) { .apt-detail-grid { grid-template-columns: 1fr; } }
    .apt-detail-title { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; margin-bottom: 0.5rem; }
    .apt-detail-meta { font-size: 0.825rem; color: var(--stone-500); margin-bottom: 2rem; letter-spacing: 0.02em; }
    .apt-detail-desc { font-size: 0.975rem; color: var(--stone-600); line-height: 1.9; margin-bottom: 2.5rem; }
    .amenities-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--stone-500); margin-bottom: 1rem; font-weight: 500; }
    .amenities-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; list-style: none; }
    .amenities-grid li { font-size: 0.85rem; color: var(--stone-600); display: flex; align-items: center; gap: 0.5rem; }
    .check-icon { color: var(--gold); font-weight: 600; font-size: 0.8rem; }
    .location-box { background: var(--stone-50); border-radius: var(--radius); padding: 1rem 1.25rem; font-size: 0.85rem; color: var(--stone-600); margin-top: 2rem; line-height: 1.7; }

    .booking-card { position: sticky; top: 90px; border: 1px solid var(--stone-200); border-radius: var(--radius-lg); padding: 2rem; background: var(--white); }
    .booking-card h3 { font-family: var(--serif); font-size: 1.3rem; font-weight: 400; margin-bottom: 0.5rem; }
    .booking-card p { font-size: 0.85rem; color: var(--stone-500); margin-bottom: 1.75rem; line-height: 1.7; }
    .booking-card .btn { display: block; text-align: center; margin-bottom: 0.75rem; width: 100%; }

    .other-apts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    @media (max-width: 768px) { .other-apts-grid { grid-template-columns: repeat(2, 1fr); } }
    .other-apt { text-align: center; padding: 1.25rem 1rem; border: 1px solid var(--stone-200); border-radius: var(--radius-lg); transition: box-shadow 0.2s, transform 0.2s; }
    .other-apt:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }
    .other-apt-emoji { font-size: 2rem; margin-bottom: 0.4rem; }
    .other-apt-name { font-family: var(--serif); font-size: 0.9rem; font-weight: 400; }
    .other-apt-cap { font-size: 0.72rem; color: var(--stone-500); margin-top: 0.2rem; }

    /* ── WHATSAPP FLOAT ── */
    .wa-float { position: fixed; bottom: 5.5rem; right: 1.75rem; z-index: 200; background: #25D366; color: var(--white); width: 54px; height: 54px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(37,211,102,0.35); transition: transform 0.2s, box-shadow 0.2s; }
    .wa-float:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(37,211,102,0.5); }
    @media (max-width: 768px) { .wa-float { bottom: 5.5rem; right: 1.25rem; } }

    /* ── MOBILE STICKY CTA ── */
    .mobile-cta { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 150; background: var(--white); border-top: 1px solid var(--stone-200); padding: 0.875rem 1.5rem; }
    .mobile-cta .btn { width: 100%; text-align: center; }
    @media (max-width: 768px) { .mobile-cta { display: block; } }

    /* ── UTILITIES ── */
    .mt-2 { margin-top: 0.5rem; } .mt-4 { margin-top: 1rem; } .mt-6 { margin-top: 1.5rem; }
    .mt-8 { margin-top: 2rem; } .mt-12 { margin-top: 3rem; } .mt-16 { margin-top: 4rem; }
    .mb-2 { margin-bottom: 0.5rem; } .mb-4 { margin-bottom: 1rem; } .mb-8 { margin-bottom: 2rem; }
    .divider { border: none; border-top: 1px solid var(--stone-200); }
    .eyebrow { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--stone-500); font-weight: 400; }

    /* ── SOBRE NOSOTROS / INNER PAGES ── */
    .inner-hero { margin-top: 70px; background: var(--cream); padding: 5rem 2rem 4rem; text-align: center; border-bottom: 1px solid var(--stone-200); }
    .inner-hero h1 { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 400; margin-bottom: 1rem; }
    .inner-hero p { font-size: 1rem; color: var(--stone-600); max-width: 560px; margin: 0 auto; line-height: 1.8; }
    .prose { font-size: 0.975rem; color: var(--stone-600); line-height: 1.9; max-width: 680px; }
    .prose p + p { margin-top: 1.25rem; }
    .prose h2 { font-family: var(--serif); font-size: 1.5rem; font-weight: 400; color: var(--black); margin: 2.5rem 0 1rem; }

    /* === PÁGINAS LEGALES === */
    .legal-hero {
      margin-top: 70px;
      padding: 4rem 1.5rem 2.5rem;
      background: var(--cream);
      text-align: center;
      border-bottom: 1px solid var(--stone-200);
    }
    .legal-hero h1 {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 400;
      margin-bottom: 0.5rem;
    }
    .legal-hero p { color: var(--stone-500); font-size: 0.95rem; }
    .legal-content {
      max-width: 760px;
      margin: 0 auto;
    }
    .legal-content h2 {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 500;
      margin: 2.5rem 0 0.75rem;
      color: var(--black);
    }
    .legal-content p {
      color: var(--stone-600);
      line-height: 1.85;
      margin-bottom: 0.75rem;
    }
    .legal-content a { color: var(--gold); }
    .legal-note {
      margin-top: 3rem;
      padding: 1.25rem 1.5rem;
      background: var(--cream);
      border-radius: 12px;
      font-size: 0.9rem;
      color: var(--stone-600);
    }
    /* Cancelación */
    .cancel-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      margin: 2rem 0 3rem;
    }
    @media (max-width: 640px) { .cancel-cards { grid-template-columns: 1fr; } }
    .cancel-card {
      padding: 1.5rem;
      border-radius: 16px;
      text-align: center;
    }
    .cancel-card h3 { font-size: 1rem; font-weight: 600; margin: 0.75rem 0 0.5rem; }
    .cancel-card p { font-size: 0.9rem; line-height: 1.6; margin: 0; }
    .cancel-card-icon { font-size: 1.75rem; }
    .cancel-card-green { background: #e8f5e9; color: #2e7d32; }
    .cancel-card-yellow { background: #fff8e1; color: #e65100; }
    .cancel-card-red { background: #fce4ec; color: #b71c1c; }
    /* Normas */
