    .cancel-card h3 { font-size: 1rem; font-weight: 600; margin: 0.75rem 0 0.5rem; }
    .cancel-card p { font-size: 0.9rem; line-height: 1.6; margin: 0; }
    .cancel-card-icon { font-size: 1.75rem; }
    .cancel-card-green { background: #e8f5e9; color: #2e7d32; }
    .cancel-card-yellow { background: #fff8e1; color: #e65100; }
    .cancel-card-red { background: #fce4ec; color: #b71c1c; }
    .rules-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin: 2rem 0; }
    @media (max-width: 640px) { .rules-grid { grid-template-columns: 1fr; } }
    .rule-item { display: flex; gap: 1rem; padding: 1.25rem; border: 1px solid var(--stone-200); border-radius: 12px; font-size: 0.9rem; line-height: 1.6; color: var(--stone-600); }
    .rule-icon { font-size: 1.4rem; flex-shrink: 0; }

    /* ── SEO CONTENT BLOCKS (home) ──────────────────── */
    .seo-barri-vell { background: var(--white); }
    .seo-cycling { background: var(--cream); }
    .seo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    .seo-grid.reverse { direction: rtl; }
    .seo-grid.reverse > * { direction: ltr; }
    @media (max-width: 768px) {
      .seo-grid, .seo-grid.reverse { grid-template-columns: 1fr; gap: 2rem; direction: ltr; }
    }
    .seo-text h2 { font-family: var(--serif); font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 400; margin: 0.75rem 0 1.25rem; }
    .seo-text p { font-size: 0.95rem; line-height: 1.8; color: var(--stone-600); }
    .seo-features { display: flex; flex-direction: column; gap: 1rem; }
    .seo-feature-item { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 1.25rem; background: var(--white); border-radius: 12px; border: 1px solid var(--stone-200); }
    .seo-cycling .seo-feature-item { background: var(--cream); border-color: var(--stone-200); }
    .seo-barri-vell .seo-feature-item { background: var(--cream); }
    .seo-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.1rem; }
    .seo-feature-item div { display: flex; flex-direction: column; gap: 0.15rem; }
    .seo-feature-item strong { font-size: 0.9rem; font-weight: 500; color: var(--black); }
    .seo-feature-item span { font-size: 0.8rem; color: var(--stone-400); }
