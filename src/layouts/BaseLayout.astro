  <script>
    // Sticky header
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => {
      header?.classList.toggle('scrolled', window.scrollY > 30);
    });
    // Mobile menu
    const hamburger = document.getElementById('hamburger');
    const nav = document.getElementById('nav');
    hamburger?.addEventListener('click', () => {
      nav?.classList.toggle('open');
    });
    // Close nav on link click
    nav?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => nav.classList.remove('open'));
    });
    // Smart "Reservar" CTA: si hay widget en la página, hace scroll; si no, navega a /reservar
    document.querySelectorAll('.js-reservar-cta').forEach(function(el) {
      el.addEventListener('click', function(e) {
        var widget = document.getElementById('reservar-widget');
        if (widget) {
          e.preventDefault();
          // Cerrar menú móvil si está abierto
          nav && nav.classList.remove('open');
          widget.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        // Si no hay widget, deja que el enlace navegue a /reservar normalmente
      });
    });

  </script>
