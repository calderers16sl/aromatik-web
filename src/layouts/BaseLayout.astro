    .legal-content p { color: var(--stone-600); line-height: 1.85; margin-bottom: 0.75rem; }
    .legal-content a { color: var(--gold); }
    .legal-note { margin-top: 3rem; padding: 1.25rem 1.5rem; background: var(--cream); border-radius: 12px; font-size: 0.9rem; color: var(--stone-600); }
    .cancel-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin: 2rem 0 3rem; }
    @media (max-width: 640px) { .cancel-cards { grid-template-columns: 1fr; } }
