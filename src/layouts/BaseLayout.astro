    .booking-card { position: sticky; top: 90px; border: 1px solid var(--stone-200); border-radius: var(--radius-lg); padding: 2rem; background: var(--white); }
    .booking-card h3 { font-family: var(--serif); font-size: 1.3rem; font-weight: 400; margin-bottom: 0.5rem; }
    .booking-card p { font-size: 0.85rem; color: var(--stone-500); margin-bottom: 1.75rem; line-height: 1.7; }
    .booking-card .btn { display: block; text-align: center; margin-bottom: 0.75rem; width: 100%; }
    .other-apts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    @media (max-width: 768px) { .other-apts-grid { grid-template-columns: repeat(2, 1fr); } }
    .other-apt { text-align: center; padding: 1.25rem 1rem; border: 1px solid var(--stone-200); border-radius: var(--radius-lg); transition: box-shadow 0.2s, transform 0.2s; }
