---
import { getT, LOCALES, LOCALE_LABELS, type Locale } from '../i18n/translations';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const { title, ogImage } = Astro.props;
const lang = (Astro.props.lang ?? Astro.currentLocale ?? 'es') as Locale;
const t = getT(lang);
const description = Astro.props.description ?? t.metaDescription;

const siteUrl = "https://aromatik.apartments";
const canonicalURL = `${siteUrl}${Astro.url.pathname}`;

// Canonical path without language prefix (for alternate links + lang switcher)
const rawPath = (() => {
  const p = Astro.url.pathname;
  for (const l of ['en','fr','ca','de','zh','ko','pt','nl']) {
    if (p.startsWith(`/${l}/`)) return p.slice(l.length + 1) || '/';
    if (p === `/${l}`) return '/';
  }
  return p;
})();

// getLangUrl: para el switcher de idioma — misma página en otro idioma
const getLangUrl = (targetLang: string) => {
  if (targetLang === 'es') return rawPath;
  const suffix = rawPath === '/' ? '' : rawPath;
  return `/${targetLang}${suffix}`;
};

// langRoot: raíz del idioma actual — para nav y footer
const langRoot = lang === 'es' ? '' : `/${lang}`;

const schemaOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "Aromatik Apartments",
  "description": "Apartamentos turísticos boutique en el Barri Vell de Girona. Cycling friendly, pet friendly, reserva directa al mejor precio.",
  "url": siteUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rambla de la Llibertat, 11",
    "addressLocality": "Girona",
    "addressRegion": "Cataluña",
    "postalCode": "17004",
    "addressCountry": "ES"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 41.9833, "longitude": 2.8249 },
  "numberOfRooms": 8,
  "priceRange": "€€–€€€",
  "telephone": "+34 600 000 000",
  "email": "info@aromatik.apartments",
  "checkinTime": "15:00",
  "checkoutTime": "11:00",
  "petsAllowed": true,
  "smokingAllowed": false,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.71",
    "reviewCount": "2272",
    "bestRating": "5",
    "worstRating": "1"
  },
  "sameAs": [
    "https://www.airbnb.es/users/show/aromatik",
    "https://www.instagram.com/aromatik.apartments",
    "https://www.booking.com/hotel/es/aromatik-apartments.html"
  ],
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "WiFi gratuito", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Aire acondicionado", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Cocina equipada", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Almacenamiento de bicicletas", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Se admiten mascotas", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Ascensor", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Self check-in", "value": true }
  ],
  "image": [
    "https://aromatik.apartments/images/apartamentos/ylang-ylang/foto-1.jpg",
    "https://aromatik.apartments/images/apartamentos/bergamota/foto-1.jpg",
    "https://aromatik.apartments/images/apartamentos/lavanda/foto-1.jpg",
    "https://aromatik.apartments/images/apartamentos/arbol-de-te/foto-1.jpg",
    "https://aromatik.apartments/images/apartamentos/geranio/foto-1.jpg"
  ]
});
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title.includes("Aromatik") ? title : `${title} | Aromatik Apartments`}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="canonical" href={canonicalURL} />
  {LOCALES.map(l => (
    <link rel="alternate" hreflang={l} href={`${siteUrl}${getLangUrl(l)}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${rawPath}`} />
  <meta property="og:site_name" content="Aromatik Apartments" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title.includes("Aromatik") ? title : `${title} | Aromatik Apartments`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schemaOrg} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --white: #FFFFFF;
      --cream: #FAF8F5;
      --stone-50: #F5F2EE;
      --stone-200: #E2DDD8;
      --stone-400: #B8B0A8;
      --stone-500: #9C9490;
      --stone-600: #6B6560;
      --stone-800: #3A3530;
      --black: #1A1816;
      --green: #2C5F2E;
      --green-hover: #224A23;
      --gold: #d0b050;
      --gold-hover: #b89a40;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'DM Sans', system-ui, sans-serif;
      --radius: 4px;
      --radius-lg: 12px;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--white); color: var(--black); line-height: 1.6; font-size: 16px; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* ── HEADER ── */
    .header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 70px; display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); border-bottom: 1px solid var(--stone-200); transition: box-shadow 0.3s; }
    .header.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.08); }
    .header-logo { font-family: var(--serif); font-size: 1.15rem; font-weight: 400; letter-spacing: 0.04em; }
    .header-logo em { font-style: normal; color: var(--gold); }
    .header-nav { display: flex; align-items: center; gap: 2rem; }
    .header-nav a { font-size: 0.825rem; font-weight: 400; color: var(--stone-600); letter-spacing: 0.02em; transition: color 0.2s; }
    .header-nav a:hover { color: var(--black); }
    .nav-cta { background: var(--gold) !important; color: var(--white) !important; padding: 0.55rem 1.4rem; border-radius: var(--radius); font-size: 0.75rem !important; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500 !important; transition: background 0.2s !important; }
    .nav-cta:hover { background: var(--gold-hover) !important; }
    /* Header controls: agrupa lang-switcher + hamburguesa */
    .header-controls { display: flex; align-items: center; gap: 0.75rem; }
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 4px; flex-direction: column; gap: 5px; }
    .hamburger span { display: block; width: 22px; height: 1.5px; background: var(--black); transition: all 0.3s; }

    /* ── LANG SWITCHER ── */
    .lang-switcher { position: relative; display: flex; align-items: center; }
    .lang-btn { display: flex; align-items: center; gap: 0.3rem; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; color: var(--stone-600); background: none; border: 1px solid var(--stone-200); border-radius: 4px; padding: 0.3rem 0.55rem; cursor: pointer; transition: border-color 0.2s, color 0.2s; font-family: var(--sans); }
    .lang-btn:hover { border-color: var(--stone-400); color: var(--black); }
    .lang-btn svg { width: 10px; height: 10px; transition: transform 0.2s; }
    .lang-switcher.open .lang-btn svg { transform: rotate(180deg); }
    .lang-dropdown { position: absolute; top: calc(100% + 6px); right: 0; background: var(--white); border: 1px solid var(--stone-200); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.1); min-width: 120px; padding: 0.4rem 0; z-index: 200;
      opacity: 0; visibility: hidden; transform: translateY(-4px); transition: opacity 0.15s, transform 0.15s, visibility 0.15s; }
    .lang-switcher.open .lang-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
    .lang-dropdown a { display: flex; align-items: center; justify-content: space-between; padding: 0.45rem 0.9rem; font-size: 0.78rem; color: var(--stone-600); transition: background 0.15s, color 0.15s; white-space: nowrap; }
    .lang-dropdown a:hover { background: var(--stone-50); color: var(--black); }
    .lang-dropdown a.lang-active { color: var(--gold); font-weight: 500; }
    .lang-dropdown a.lang-active::after { content: "✓"; font-size: 0.65rem; }

    @media (max-width: 768px) {
      /* — MOBILE NAV: roll-down animation — */
      .header-nav {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        position: fixed;
        top: 70px; left: 0; right: 0;
        z-index: 999;
        background: var(--white);
        border-top: 1px solid #ece8e2;
        box-shadow: 0 12px 32px rgba(0,0,0,0.12);
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        pointer-events: none;
        transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1), opacity 0.28s ease;
      }
      .header-nav.open { max-height: 520px; opacity: 1; pointer-events: auto; }
      .hamburger { display: flex; }
      .header-nav a {
        display: flex; align-items: center;
        font-size: 0.95rem; font-weight: 400;
        padding: 0.95rem 1.5rem;
        color: #3a3631;
        border-bottom: 1px solid #f2ede8;
        letter-spacing: 0.01em;
        transition: background 0.15s, color 0.15s, padding-left 0.18s;
      }
      .header-nav a:hover { background: #faf7f4; color: var(--black); padding-left: 1.85rem; }
      .header-nav a:last-child { border-bottom: none; }
      .header-nav .nav-cta { display: none; }
      /* Hamburger → X */
      .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
      .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
      .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
      /* — LANG SWITCHER — ya funciona como dropdown independiente en header-controls */
      .lang-dropdown { right: 0; left: auto; min-width: 140px; }
    }
    /* — HEADER CONTROLS (lang + hamburger, siempre visibles en móvil) — */
    @media (max-width: 768px) {
      .header-controls { display: flex; align-items: center; gap: 0.75rem; }
    }

    /* ── HERO ── */
    .hero { position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; color: var(--white); overflow: hidden; padding-top: 70px; }
    .hero-bg { position: absolute; inset: 0; background: linear-gradient(160deg, #1a2e1c 0%, #2C5F2E 40%, #1e3d20 70%, #111e12 100%); background-image: url("/images/hero-girona.jpg"); background-size: cover; background-position: center; }
    .hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.25); }
    .hero-inner { position: relative; z-index: 1; max-width: 820px; padding: 4rem 2rem; background: rgba(0,0,0,0.32); border-radius: 20px; backdrop-filter: blur(2px); }
    .hero-eyebrow { display: block; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-top: 1.5rem; font-weight: 300; white-space: normal; overflow-wrap: break-word; text-align: center; }
    @media (max-width: 480px) { .hero-eyebrow { font-size: 0.65rem; letter-spacing: 0.15em; } }
    .hero h1 { font-family: var(--serif); font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 400; line-height: 1.2; margin-bottom: 1.5rem; }
    .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .hero-badges { display: flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; margin-top: 0; }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.3);
      color: rgba(255,255,255,0.9);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.35rem 0.85rem;
      border-radius: 99px;
      backdrop-filter: blur(4px);
    }

    /* ── BUTTONS ── */
    .btn { display: inline-block; font-family: var(--sans); font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.875rem 2rem; border-radius: var(--radius); transition: all 0.2s; cursor: pointer; border: none; }
    .btn-white { background: var(--white); color: var(--black); }
    .btn-white:hover { background: var(--cream); }
    .btn-outline-white { border: 1px solid rgba(255,255,255,0.5); color: var(--white); }
    .btn-outline-white:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }
    .btn-dark { background: var(--black); color: var(--white); }
    .btn-dark:hover { background: #111; }
    .btn-green { background: var(--gold); color: var(--white); }
    .btn-green:hover { background: var(--gold-hover); }
    .btn-outline-dark { border: 1px solid var(--black); color: var(--black); background: transparent; }
    .btn-outline-dark:hover { background: var(--black); color: var(--white); }
    /* INFO BANNER (bloque índice → info importante) */
    .info-banner-section { padding: 2.5rem 0; }
    .info-banner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; background: var(--white); border: 1px solid var(--stone-200); border-radius: var(--radius-lg); padding: 2rem 2.5rem; }
    .info-banner-text .eyebrow { display: block; font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--stone-400); margin-bottom: 0.5rem; }
    .info-banner-text h2 { font-family: var(--serif); font-size: 1.25rem; font-weight: 400; color: var(--black); margin: 0 0 0.5rem; }
    .info-banner-text p { font-size: 0.88rem; color: var(--stone-600); margin: 0; line-height: 1.6; max-width: 480px; }
    @media (max-width: 640px) {
      .info-banner { flex-direction: column; align-items: flex-start; padding: 1.5rem; }
      .info-banner .btn { width: 100%; text-align: center; }
    }
    .btn-border { border: 1px solid var(--black); color: var(--black); background: transparent; }
    .btn-border:hover { background: var(--black); color: var(--white); }

    /* ── TRUST BAR ── */
    .trust-bar { background: var(--black); color: var(--white); padding: 1.5rem 2rem; }
    .trust-bar-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; text-align: center; }
    .trust-num { display: block; font-family: var(--serif); font-size: 1.6rem; font-weight: 400; }
    .trust-label { display: block; font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-top: 0.3rem; }
    @media (max-width: 600px) { .trust-bar-inner { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }

    /* ── LAYOUT ── */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
    .container-sm { max-width: 760px; margin: 0 auto; padding: 0 2rem; }
    .section { padding: 6rem 0; }
    .section-sm { padding: 4rem 0; }
    .bg-cream { background: var(--cream); }
    .bg-stone { background: var(--stone-50); }
    .bg-black { background: var(--black); color: var(--white); }
    .text-center { text-align: center; }
    .section-header { text-align: center; margin-bottom: 4rem; }
    .section-header h2 { font-family: var(--serif); font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 400; margin-bottom: 1rem; }
    .section-header p { font-size: 0.95rem; color: var(--stone-600); max-width: 520px; margin: 0 auto; line-height: 1.8; }

    /* ── APARTMENTS GRID ── */
    .apts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
    @media (max-width: 1024px) { .apts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 580px) { .apts-grid { grid-template-columns: 1fr 1fr; gap: 1rem; } }
    .apt-card { display: block; border: 1px solid var(--stone-200); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow 0.3s, transform 0.3s; }
    .apt-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.1); transform: translateY(-4px); }
    .apt-card-img { height: 200px; position: relative; overflow: hidden; }
    .apt-card-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity 0.3s; }
    .apt-card-img img.c-hidden { opacity: 0; }
    .apt-card-prev, .apt-card-next { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; background: rgba(0,0,0,0.4); color: #fff; border: none; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; opacity: 0; transition: opacity 0.2s; font-size: 1rem; line-height: 1; padding: 0; }
    .apt-card:hover .apt-card-prev, .apt-card:hover .apt-card-next { opacity: 1; }
    .apt-card-prev { left: 6px; }
    .apt-card-next { right: 6px; }
    .apt-card-dots { position: absolute; bottom: 6px; left: 0; right: 0; display: flex; justify-content: center; gap: 4px; z-index: 10; pointer-events: none; }
    .apt-card-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.5); transition: background 0.2s; }
    .apt-card-dot.c-active { background: #fff; }
    .apt-emoji-placeholder { font-size: 3rem; opacity: 0.5; }
    .apt-card-body { padding: 1.25rem 1.5rem; }
    .apt-card-body h3 { font-family: var(--serif); font-size: 1.1rem; font-weight: 400; margin-bottom: 0.3rem; }
    .apt-meta { font-size: 0.78rem; color: var(--stone-500); margin-bottom: 0.875rem; }
    .apt-link { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); }

    /* ── BRAND STATEMENT ── */
    .brand-statement { padding: 6rem 2rem; text-align: center; background: var(--black); }
    .brand-statement blockquote { font-family: var(--serif); font-size: clamp(1.15rem, 2.5vw, 1.75rem); font-weight: 400; font-style: italic; color: var(--white); max-width: 800px; margin: 0 auto; line-height: 1.7; }
    .brand-statement cite { display: block; margin-top: 1.75rem; font-family: var(--sans); font-style: normal; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.4); }

    /* ── PERKS ── */
    .perks-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    @media (max-width: 768px) { .perks-grid { grid-template-columns: 1fr; } }
    .perk { padding: 2rem 1.75rem; border: 1px solid var(--stone-200); background: var(--white); border-radius: var(--radius-lg); }
    .perk-icon { font-size: 1.6rem; margin-bottom: 1.25rem; }
    .perk h3 { font-family: var(--serif); font-size: 1.05rem; font-weight: 400; margin-bottom: 0.6rem; }
    .perk p { font-size: 0.875rem; color: var(--stone-600); line-height: 1.75; }

    /* ── FAQ ── */
    .faq-list { max-width: 680px; margin: 0 auto; }
    .faq-item { border-top: 1px solid var(--stone-200); padding: 1.75rem 0; }
    .faq-item:last-child { border-bottom: 1px solid var(--stone-200); }
    .faq-q { font-family: var(--serif); font-size: 1rem; font-weight: 400; margin-bottom: 0.75rem; }
    .faq-a { font-size: 0.875rem; color: var(--stone-600); line-height: 1.8; }

    /* ── FOOTER ── */
    .footer { background: var(--black); color: rgba(255,255,255,0.6); padding: 5rem 2rem 2.5rem; }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; max-width: 1200px; margin: 0 auto 3rem; }
    @media (max-width: 900px) { .footer-top { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 520px) { .footer-top { grid-template-columns: 1fr; } }
    .footer-brand h3 { font-family: var(--serif); font-size: 1.25rem; color: var(--white); font-weight: 400; margin-bottom: 0.75rem; }
    .footer-brand p { font-size: 0.825rem; line-height: 1.8; max-width: 280px; }
    .footer-brand .footer-contact-links { margin-top: 1.25rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .footer-brand .footer-contact-links a { font-size: 0.8rem; color: rgba(255,255,255,0.5); transition: color 0.2s; }
    .footer-brand .footer-contact-links a:hover { color: var(--white); }
    .footer-col h4 { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--white); margin-bottom: 1.25rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
    .footer-col a { font-size: 0.825rem; color: rgba(255,255,255,0.5); transition: color 0.2s; }
    .footer-col a:hover { color: var(--white); }
    .footer-bottom { max-width: 1200px; margin: 0 auto; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-bottom p { font-size: 0.75rem; }

    /* ── APARTMENT DETAIL ── */
    .apt-detail-hero { min-height: 55vh; background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; margin-top: 70px; }
    .apt-detail-emoji { font-size: 7rem; opacity: 0.6; }
    .apt-detail-grid { display: grid; grid-template-columns: 1fr 380px; gap: 4rem; align-items: start; }
    @media (max-width: 1024px) { .apt-detail-grid { grid-template-columns: 1fr; } }
    .apt-detail-title { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; margin-bottom: 0.5rem; }
    .apt-detail-meta { font-size: 0.825rem; color: var(--stone-500); margin-bottom: 2rem; letter-spacing: 0.02em; }
    .apt-detail-desc { font-size: 0.975rem; color: var(--stone-600); line-height: 1.9; margin-bottom: 2.5rem; }
    .amenities-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--stone-500); margin-bottom: 1rem; font-weight: 500; }
    .amenities-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; list-style: none; }
    .amenities-grid li { font-size: 0.85rem; color: var(--stone-600); display: flex; align-items: center; gap: 0.5rem; }
    .check-icon { color: var(--gold); font-weight: 600; font-size: 0.8rem; }
