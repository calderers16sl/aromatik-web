    /* ── LEGAL PAGES ── */
    .legal-hero { margin-top: 70px; padding: 4rem 1.5rem 2.5rem; background: var(--cream); text-align: center; border-bottom: 1px solid var(--stone-200); }
    .legal-hero h1 { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; margin-bottom: 0.5rem; }
