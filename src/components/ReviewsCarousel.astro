---
// ReviewsCarousel.astro — rating badge only
---

<section class="rc-section">
  <div class="rc-container">
    <span class="eyebrow">Google Reviews</span>
    <div class="rc-rating">
      <span class="rc-score" id="rc-score">4.6</span>
      <div class="rc-right">
        <span class="rc-stars" id="rc-stars">★★★★★</span>
        <span class="rc-count" id="rc-count"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .rc-section {
    background: var(--cream, #f8f4ef);
    padding: 48px 24px;
    text-align: center;
  }
  .rc-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold, #d0b050);
  }
  .rc-rating {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .rc-score {
    font-family: var(--serif, Georgia, serif);
    font-size: 3rem;
    font-weight: 400;
    color: var(--black, #1a1a1a);
    line-height: 1;
  }
  .rc-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }
  .rc-stars {
    font-size: 1.2rem;
    color: var(--gold, #d0b050);
    letter-spacing: 3px;
  }
  .rc-count {
    font-size: 0.78rem;
    color: #888;
  }
</style>

<script>
(async () => {
  try {
    const data = await fetch('/api/reviews').then(r => r.json());
    if (data.error) return;
    const STARS = n => '★'.repeat(n) + '☆'.repeat(5 - n);
    const s = document.getElementById('rc-score');
    const st = document.getElementById('rc-stars');
    const c = document.getElementById('rc-count');
    if (s) s.textContent = data.rating ? data.rating.toFixed(1) : '4.6';
    if (st) st.textContent = STARS(Math.round(data.rating || 5));
    if (c) c.textContent = data.user_ratings_total ? `${data.user_ratings_total} reseñas` : '';
  } catch(e) {}
})();
</script>
