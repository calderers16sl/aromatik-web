---
// ReviewsCarousel.astro — Google Places embed
---

<section class="rc-section">
  <div class="container">
    <div class="section-header" style="margin-bottom:2rem">
      <span class="eyebrow">Google Reviews</span>
      <h2 style="margin-top:0.75rem">Lo que dicen nuestros huéspedes</h2>
    </div>
    <div class="rc-embed-wrap">
      <iframe
        src="https://maps.google.com/maps?q=Aromatik+Apartments+Rambla+de+la+Llibertat+Girona&output=embed&hl=es&z=16"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Aromatik Apartments en Google Maps"
      ></iframe>
    </div>
    <div style="text-align:center; margin-top:1.5rem">
      <a
        href="https://www.google.com/maps/search/Aromatik+Apartments+Girona"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline-dark"
      >Ver todas las reseñas en Google Maps →</a>
    </div>
  </div>
</section>

<style>
  .rc-section {
    background: var(--cream, #f8f4ef);
    padding: 5rem 0;
  }
  .rc-embed-wrap {
    border-radius: 16px;
    overflow: hidden;
    height: 480px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
    border: 1px solid var(--stone-200, #e5e7eb);
  }
</style>
