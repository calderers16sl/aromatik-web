---
export interface Props {
  smoobuId?: string | number;
  lang?: string;
}
const { smoobuId, lang = "es" } = Astro.props;
const customerId = "333907";
const iframeUrl = smoobuId
  ? `https://login.smoobu.com/${lang}/booking-tool/iframe/${customerId}/${smoobuId}`
  : `https://login.smoobu.com/${lang}/booking-tool/iframe/${customerId}`;
const targetId = smoobuId ? `smoobuFrame${smoobuId}` : "smoobuFrameAll";
---
<div id={targetId} class="smoobu-widget-wrap">
  <script type="text/javascript" src="https://login.smoobu.com/js/Settings/BookingToolIframe.js"></script>
  <script define:vars={{ iframeUrl, targetId }}>
    function scrollToWidget(container) {
      var headerH = 80;
      var rect = container.getBoundingClientRect();
      var absoluteTop = rect.top + window.pageYOffset - headerH;
      window.scrollTo({ top: Math.max(0, absoluteTop), behavior: 'smooth' });
    }

    function attachScrollFix(container) {
      var lastHeight = 0;
      var scrollFix = new ResizeObserver(function(entries) {
        var iframe = container.querySelector('iframe');
        if (!iframe) return;
        var h = iframe.offsetHeight || 0;
        // Significant height jump = booking step changed (not just initial load)
        if (lastHeight > 200 && h > 200 && Math.abs(h - lastHeight) > 80) {
          // Small delay so iFrameResize finishes its own scroll first, then override it
          setTimeout(function() { scrollToWidget(container); }, 80);
        }
        lastHeight = h;
      });

      var iframe = container.querySelector('iframe');
      if (iframe) {
        scrollFix.observe(iframe);
      } else {
        // Iframe not yet created — wait for it
        var mo = new MutationObserver(function() {
          var iframeEl = container.querySelector('iframe');
          if (iframeEl) {
            mo.disconnect();
            scrollFix.observe(iframeEl);
          }
        });
        mo.observe(container, { childList: true, subtree: true });
      }
    }

    // GA4 cross-domain linker: ask Google Tag to decorate the URL with the _gl param
    // so the client_id and gclid travel from aromatik.apartments to {login,booking}.smoobu.com.
    // REQUIREMENT: both `login.smoobu.com` AND `booking.smoobu.com` must be configured as
    // cross-domain measurement domains in GA4 Admin -> Data Streams -> Configure your domains.
    function getDecoratedUrl(targetUrl, callback) {
      var done = false;
      var finish = function(url) { if (done) return; done = true; callback(url); };

      if (typeof window.gtag !== 'function') {
        finish(targetUrl);
        return;
      }

      // Create an invisible anchor and click it programmatically.
      // Google Tag's linker plugin auto-decorates the href of <a> elements pointing to
      // configured cross-domain destinations when a click event fires on them.
      var a = null;
      try {
        a = document.createElement('a');
        a.href = targetUrl;
        a.style.position = 'absolute';
        a.style.left = '-9999px';
        a.style.top = '-9999px';
        a.style.pointerEvents = 'none';
        document.body.appendChild(a);

        a.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopImmediatePropagation();
          var decoratedHref = a.href;
          if (a.parentNode) a.parentNode.removeChild(a);
          finish(decoratedHref);
        }, { once: true, capture: true });

        a.click();
      } catch (e) {
        if (a && a.parentNode) a.parentNode.removeChild(a);
      }

      // Safety fallback: if the click handler didn't fire within 1.5s, proceed undecorated.
      setTimeout(function() { finish(targetUrl); }, 1500);
    }

    function initSmoobuWithUrl(url) {
      if (typeof BookingToolIframe !== 'undefined') {
        BookingToolIframe.initialize({
          url: url,
          baseUrl: "https://login.smoobu.com",
          target: "#" + targetId
        });
        var container = document.getElementById(targetId);
        if (container) attachScrollFix(container);
      }
    }

    function initSmoobu() {
      // Decorate URL with GA4 cross-domain linker before initializing the widget,
      // so the client_id and gclid travel through to the Smoobu iframe.
      getDecoratedUrl(iframeUrl, function(decoratedUrl) {
        initSmoobuWithUrl(decoratedUrl);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSmoobu);
    } else {
      initSmoobu();
    }
  </script>
</div>

<style is:global>
.smoobu-widget-wrap {
  width: 100%;
  min-height: 600px;
}
.smoobu-widget-wrap iframe {
  width: 100%;
  border: none;
}
</style>
