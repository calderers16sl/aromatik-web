---
// GoogleReviews.astro — fetches from /api/reviews on the client
// No props needed; the Cloudflare Function handles the API call
---

<section class="reviews-section">
  <div class="container">
    <div class="reviews-header">
      <div class="reviews-badge" id="reviews-badge">
        <span class="reviews-score" id="reviews-score">—</span>
        <div class="reviews-stars" id="reviews-stars"></div>
        <span class="reviews-count" id="reviews-count"></span>
      </div>
      <div class="reviews-title-block">
        <p class="eyebrow">Google Reviews</p>
        <h2>Lo que dicen nuestros huéspedes</h2>
      </div>
    </div>
    <div class="reviews-grid" id="reviews-grid">
      <div class="reviews-loading">Cargando reseñas…</div>
    </div>
    <a
      href="https://www.google.com/maps/place/Aromatik+Apartments/@41.9852,2.8239,17z/data=!4m8!3m7!1s0x12b9e7c4b490a155:0x678c983819092403!8m2!3d41.9852!4d2.8239!9m1!1b1"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-outline-dark reviews-cta"
    >
      Ver todas las reseñas en Google →
    </a>
  </div>
</section>

<style>
  .reviews-section {
    padding: 80px 0;
    background: var(--cream, #f8f4ef);
  }

  .reviews-header {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .reviews-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--black, #1a1a1a);
    color: var(--white, #fff);
    border-radius: 16px;
    padding: 20px 28px;
    min-width: 120px;
    gap: 6px;
  }

  .reviews-score {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1;
    color: var(--gold, #d0b050);
  }

  .reviews-stars {
    display: flex;
    gap: 3px;
    font-size: 1rem;
  }

  .reviews-count {
    font-size: 0.75rem;
    opacity: 0.7;
    text-align: center;
  }

  .reviews-title-block .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold, #d0b050);
    margin-bottom: 4px;
  }

  .reviews-title-block h2 {
    font-size: 1.9rem;
    font-weight: 600;
    margin: 0;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-bottom: 40px;
  }

  .reviews-loading {
    grid-column: 1 / -1;
    text-align: center;
    color: #888;
    padding: 40px;
  }

  .review-card {
    background: var(--white, #fff);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }

  .review-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .review-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--gold, #d0b050);
  }

  .review-avatar-fallback {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gold, #d0b050);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white, #fff);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .review-meta {
    flex: 1;
    min-width: 0;
  }

  .review-author {
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-time {
    font-size: 0.78rem;
    color: #888;
  }

  .review-stars {
    color: var(--gold, #d0b050);
    font-size: 0.9rem;
  }

  .review-text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #444;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .reviews-cta {
    display: block;
    width: fit-content;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .reviews-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (async function() {
    const STARS = (n) => '★'.repeat(n) + '☆'.repeat(5 - n);

    try {
      const res = await fetch('/api/reviews');
      const data = await res.json();

      if (data.error) throw new Error(data.error);

      // Update badge
      const score = document.getElementById('reviews-score');
      const stars = document.getElementById('reviews-stars');
      const count = document.getElementById('reviews-count');
      if (score) score.textContent = data.rating ? data.rating.toFixed(1) : '—';
      if (stars) stars.innerHTML = `<span style="color:var(--gold,#d0b050)">${STARS(Math.round(data.rating || 0))}</span>`;
      if (count) count.textContent = data.user_ratings_total ? `${data.user_ratings_total} reseñas` : '';

      const grid = document.getElementById('reviews-grid');
      if (!grid) return;

      if (!data.reviews || data.reviews.length === 0) {
        grid.innerHTML = '<div class="reviews-loading">Sé el primero en dejar una reseña en Google.</div>';
        return;
      }

      grid.innerHTML = data.reviews.map(r => {
        const initial = r.author ? r.author.charAt(0).toUpperCase() : '?';
        const avatarHtml = r.avatar
          ? `<img class="review-avatar" src="${r.avatar}" alt="${r.author}" loading="lazy">`
          : `<div class="review-avatar-fallback">${initial}</div>`;
        return `
          <div class="review-card">
            <div class="review-top">
              ${avatarHtml}
              <div class="review-meta">
                <div class="review-author">${r.author || 'Huésped'}</div>
                <div class="review-time">${r.time || ''}</div>
              </div>
            </div>
            <div class="review-stars">${STARS(r.rating || 5)}</div>
            <p class="review-text">${r.text || ''}</p>
          </div>
        `;
      }).join('');

    } catch (err) {
      const grid = document.getElementById('reviews-grid');
      if (grid) grid.innerHTML = '';
      console.warn('Reviews load error:', err);
    }
  })();
</script>
